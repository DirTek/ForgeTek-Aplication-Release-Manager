<Window x:Class="SetupBootstrapper.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Setup" Height="740" Width="660"
        MinHeight="680" MinWidth="560"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Loaded="Window_Loaded">
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Banner image (collapsed when no banner) -->
        <Border x:Name="BannerBorder" Grid.Row="0" Margin="0,0,0,16"
                CornerRadius="6" BorderThickness="0"
                Visibility="Collapsed" MaxHeight="120">
            <Image x:Name="BannerImage" Stretch="UniformToFill"/>
        </Border>

        <!-- Header -->
        <StackPanel Grid.Row="1" Margin="0,0,0,20">
            <TextBlock x:Name="TitleText" Text="ForgeTek Setup"
                       FontSize="22" FontWeight="Bold"
                       Foreground="{StaticResource TextBrush}"/>
            <TextBlock x:Name="SubtitleText" Text=""
                       FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Content -->
        <Grid Grid.Row="2">
            <!-- ═══ EULA PAGE ═══ -->
             <Grid x:Name="PageEula" Visibility="Visible">
                <TextBlock x:Name="EulaLoadingText" Text="Loading setup information…"
                           FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Margin="0,60,0,0"/>
                <Grid x:Name="EulaContent" Visibility="Collapsed" RowDefinitions="*,Auto">
                    <Grid Grid.Row="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="License Agreement" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}" Margin="0,0,0,10"/>
                        <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}" CornerRadius="6"
                                Padding="14,10" BorderThickness="1" BorderBrush="{StaticResource BorderBrush}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <TextBlock x:Name="EulaBody" TextWrapping="Wrap" FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           LineHeight="18"/>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                    <CheckBox x:Name="EulaAcceptCheck" Content="I accept the terms of the License Agreement"
                              FontSize="13" Foreground="{StaticResource TextBrush}"
                              Margin="0,14,0,0" Grid.Row="1"
                              Checked="EulaAcceptCheck_Changed" Unchecked="EulaAcceptCheck_Changed"/>
                </Grid>
            </Grid>

            <!-- ═══ PATH SELECTION PAGE ═══ -->
            <Grid x:Name="PagePath" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="Select installation location:" FontSize="13"
                               Foreground="{StaticResource TextBrush}" Margin="0,0,0,6"/>
                    <TextBlock x:Name="DefaultPathText" FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,10"/>

                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="InstallPathBox" Grid.Column="0"
                                 Text="" FontSize="13"
                                 IsReadOnly="False"
                                 Padding="10,8" Margin="0,0,8,0"/>
                        <Button Grid.Column="1" Content="Browse…"
                                Style="{StaticResource SecondaryButton}"
                                Click="Browse_Click" Padding="16,8"/>
                    </Grid>
                </StackPanel>

                <TextBlock Grid.Row="1" Text="Applications to install:" FontSize="13"
                           Foreground="{StaticResource TextBrush}" Margin="0,0,0,6"/>

                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="AppList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource SurfaceBrush}"
                                        CornerRadius="6" Padding="12,10" Margin="0,0,0,6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextBrush}"/>
                                            <TextBlock Text="{Binding SubPath}"
                                                       FontSize="11"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <!-- ═══ PREREQUISITES PAGE ═══ -->
            <StackPanel x:Name="PagePrereq" Visibility="Collapsed">
                <TextBlock Text="Prerequisites" FontSize="14" FontWeight="SemiBold"
                           Foreground="{StaticResource TextBrush}" Margin="0,0,0,10"/>
                <TextBlock x:Name="PrereqSummaryText" FontSize="13"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,14"/>

                <ItemsControl x:Name="PrereqList" Margin="0,0,0,6">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource SurfaceBrush}" CornerRadius="6"
                                    Padding="12,10" Margin="0,0,0,6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding StatusIcon}"
                                               FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextBrush}"/>
                                        <TextBlock Text="{Binding StatusText}"
                                                   FontSize="11"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock x:Name="PrereqNoteText" FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap" Margin="0,4,0,0"
                           Text="Missing prerequisites will be installed automatically before the application files."/>
            </StackPanel>

            <!-- ═══ REDIST PROGRESS PAGE ═══ -->
            <StackPanel x:Name="PageRedist" Visibility="Collapsed">
                <TextBlock x:Name="RedistStatus" Text="Installing prerequisites..."
                           FontSize="13" Foreground="{StaticResource TextBrush}"
                           Margin="0,0,0,12"/>
                <ProgressBar x:Name="RedistProgress" Height="6"/>
                <TextBlock x:Name="RedistFileText" Text=""
                           FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,8,0,0"/>
            </StackPanel>

            <!-- ═══ FILE INSTALL PROGRESS PAGE ═══ -->
            <StackPanel x:Name="PageProgress" Visibility="Collapsed">
                <TextBlock x:Name="ProgressStatus" Text="Installing applications..."
                           FontSize="13" Foreground="{StaticResource TextBrush}"
                           Margin="0,0,0,12"/>
                <ProgressBar x:Name="InstallProgress" Height="6"/>
                <TextBlock x:Name="ProgressFileText" Text=""
                           FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,8,0,0"/>
            </StackPanel>

            <!-- ═══ UNINSTALL PAGE ═══ -->
            <StackPanel x:Name="PageUninstall" Visibility="Collapsed"
                        VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Uninstall Application"
                           FontSize="20" FontWeight="Bold"
                           Foreground="{StaticResource TextBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,12"/>
                <TextBlock x:Name="UninstallInfoText"
                           FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap" TextAlignment="Center"
                           Margin="0,0,0,24"/>
                <Button x:Name="UninstallBtn" Content="Uninstall"
                        Style="{StaticResource DangerButton}"
                        Padding="24,10" HorizontalAlignment="Center"
                        Click="UninstallBtn_Click"/>
            </StackPanel>

            <!-- ═══ UNINSTALL PROGRESS PAGE ═══ -->
            <StackPanel x:Name="PageUninstallProgress" Visibility="Collapsed"
                        VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock x:Name="UninstallStatusText" Text="Uninstalling..."
                           FontSize="14" Foreground="{StaticResource TextBrush}"
                           HorizontalAlignment="Center" Margin="0,0,0,12"/>
                <ProgressBar x:Name="UninstallProgress" Height="6" Width="300"/>
            </StackPanel>

            <!-- ═══ UNINSTALL COMPLETE PAGE ═══ -->
            <StackPanel x:Name="PageUninstallComplete" Visibility="Collapsed"
                        VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="✔ Uninstall Complete"
                           FontSize="20" FontWeight="Bold"
                           Foreground="{StaticResource AddedBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,12"/>
                <TextBlock x:Name="UninstallCompleteText"
                           FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap" TextAlignment="Center"/>
                <Button x:Name="UninstallFinishBtn" Content="Finish"
                        Style="{StaticResource PrimaryButton}"
                        Padding="24,10" HorizontalAlignment="Center"
                        Margin="0,20,0,0"
                        Click="UninstallFinishBtn_Click"/>
            </StackPanel>

            <!-- ═══ MAINTENANCE PAGE (Repair / Remove) ═══ -->
            <StackPanel x:Name="PageMaintenance" Visibility="Collapsed">
                <TextBlock Text="Maintenance" FontSize="16" FontWeight="Bold"
                           Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                <TextBlock x:Name="MaintenanceInfoText"
                           FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap" Margin="0,0,0,14"/>
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="6"
                        Padding="14,10" Margin="0,0,0,18">
                    <StackPanel x:Name="MaintenanceAppList"/>
                </Border>
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="RepairBtn" Content="Repair"
                            Style="{StaticResource PrimaryButton}"
                            Padding="22,9" Click="RepairBtn_Click"/>
                    <Button x:Name="RemoveBtn" Content="Remove"
                            Style="{StaticResource DangerButton}"
                            Padding="22,9" Margin="10,0,0,0" Click="RemoveBtn_Click"/>
                </StackPanel>
            </StackPanel>

            <!-- ═══ COMPLETE PAGE ═══ -->
            <StackPanel x:Name="PageComplete" Visibility="Collapsed"
                        VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock x:Name="CompleteHeaderText" Text="✔ Installation Complete"
                           FontSize="20" FontWeight="Bold"
                           Foreground="{StaticResource AddedBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,12"/>
                <TextBlock x:Name="CompleteText"
                           FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap" TextAlignment="Center"/>
                <CheckBox x:Name="LaunchCheckbox" Content="Launch after closing"
                          Foreground="{StaticResource TextBrush}"
                          Margin="0,20,0,0" HorizontalAlignment="Center"
                          Visibility="Collapsed"/>
            </StackPanel>
        </Grid>

        <!-- Footer -->
        <StackPanel Grid.Row="3" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button x:Name="CancelBtn" Content="Cancel"
                    Style="{StaticResource SecondaryButton}"
                    Click="Cancel_Click" Margin="0,0,8,0"
                    IsEnabled="True"/>
            <Button x:Name="BackBtn" Content="← Back"
                    Style="{StaticResource SecondaryButton}"
                    Click="BackBtn_Click" Visibility="Collapsed"
                    Margin="0,0,8,0"/>
            <Button x:Name="ActionBtn" Content="Next"
                    Style="{StaticResource PrimaryButton}"
                    Click="ActionBtn_Click" IsEnabled="False"/>
            <Button x:Name="FinishBtn" Content="Finish"
                    Style="{StaticResource PrimaryButton}"
                    Click="Finish_Click" Visibility="Collapsed"/>
        </StackPanel>
    </Grid>
</Window>
