<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Dark theme palette. Keys match Themes/Light.xaml exactly; swapped at runtime by ThemeService. -->
    <SolidColorBrush x:Key="BackgroundBrush"     Color="#1C1C1E"/>
    <SolidColorBrush x:Key="SidebarBrush"        Color="#111113"/>
    <SolidColorBrush x:Key="SurfaceBrush"        Color="#2C2C2E"/>
    <SolidColorBrush x:Key="SurfaceHoverBrush"   Color="#3A3A3C"/>
    <!-- Recessed fill for editable controls (TextBox/ComboBox/etc.) so they read distinctly
         against SurfaceBrush cards and the page background. -->
    <SolidColorBrush x:Key="InputBrush"          Color="#242426"/>
    <SolidColorBrush x:Key="AccentBrush"         Color="#0A84FF"/>
    <SolidColorBrush x:Key="AccentHoverBrush"    Color="#409CFF"/>
    <SolidColorBrush x:Key="TextBrush"           Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TextSecondaryBrush"  Color="#98989D"/>
    <SolidColorBrush x:Key="BorderBrush"         Color="#3A3A3C"/>
    <SolidColorBrush x:Key="AddedBrush"          Color="#30D158"/>
    <SolidColorBrush x:Key="ModifiedBrush"       Color="#FF9F0A"/>
    <SolidColorBrush x:Key="RemovedBrush"        Color="#FF453A"/>
    <SolidColorBrush x:Key="DebugBrush"          Color="#BF5AF2"/>
    <SolidColorBrush x:Key="DangerBrush"         Color="#CC2222"/>

    <!-- Fixed: text/glyphs that sit on colored (accent/danger/added) fills. White in both themes. -->
    <SolidColorBrush x:Key="OnAccentBrush"       Color="#FFFFFF"/>

    <!-- Soft tints for banners / sub-panels / selection. Dark: translucent over dark surfaces. -->
    <SolidColorBrush x:Key="AccentSoftBrush"     Color="#1A0A84FF"/>
    <SolidColorBrush x:Key="SuccessSoftBrush"    Color="#1A30D158"/>
    <SolidColorBrush x:Key="SubtlePanelBrush"    Color="#1A285080"/>
    <SolidColorBrush x:Key="SelectionBrush"      Color="#33285080"/>

</ResourceDictionary>
