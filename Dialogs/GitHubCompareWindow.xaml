<Window x:Class="ForgeTekApplicationReleaseManager.Dialogs.GitHubCompareWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Str.GhCompare.Title}" Width="820" Height="700" MinWidth="700" MinHeight="540"
        WindowStartupLocation="CenterOwner" WindowStyle="SingleBorderWindow" ShowInTaskbar="False"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource TextBrush}">
    <Window.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="{DynamicResource Str.GhCompare.Title}" FontSize="18" FontWeight="Bold"
                       Foreground="{DynamicResource TextBrush}"/>
            <TextBlock x:Name="SubtitleText" FontSize="12" Margin="0,4,0,0"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Text="{DynamicResource Str.GhCompare.Subtitle}"/>
        </StackPanel>

        <!-- Local path + branch -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" x:Name="LocalBox" VerticalContentAlignment="Center"
                     ToolTip="{DynamicResource Str.GhCompare.LocalTip}"/>
            <Button Grid.Column="1" Content="{DynamicResource Str.Common.Browse}" Style="{StaticResource SecondaryButton}"
                    Padding="14,6" Margin="8,0,0,0" Click="Browse_Click"/>
        </Grid>
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="{DynamicResource Str.GhCompare.Branch}" Style="{StaticResource FieldLabel}" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <ComboBox x:Name="BranchBox" Width="200" FontSize="12"/>
            <Button x:Name="CompareBtn" Content="{DynamicResource Str.Compare.Compare}" Style="{StaticResource PrimaryButton}"
                    Padding="20,6" Margin="12,0,0,0" Click="Compare_Click"/>
            <CheckBox x:Name="DiffOnly" Content="{DynamicResource Str.Compare.DifferencesOnly}" VerticalAlignment="Center"
                      Margin="16,0,0,0" Foreground="{DynamicResource TextBrush}"
                      Checked="DiffOnly_Changed" Unchecked="DiffOnly_Changed"/>
        </StackPanel>

        <!-- Results -->
        <Border Grid.Row="3" Background="{DynamicResource SurfaceBrush}" CornerRadius="6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" x:Name="SummaryText" Margin="12,10,12,0" FontSize="13" FontWeight="SemiBold"
                           Visibility="Collapsed"/>
                <Grid Grid.Row="1" Margin="12,8,12,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{DynamicResource Str.Compare.ColFile}" Style="{StaticResource FieldLabel}"/>
                    <TextBlock Grid.Column="1" Text="{DynamicResource Str.GhCompare.LocalCol}" Style="{StaticResource FieldLabel}"/>
                    <TextBlock Grid.Column="2" Text="{DynamicResource Str.GhCompare.RepoCol}" Style="{StaticResource FieldLabel}"/>
                    <TextBlock Grid.Column="3" Text="{DynamicResource Str.Compare.ColStatus}" Style="{StaticResource FieldLabel}"/>
                </Grid>
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="12,0,12,10">
                    <StackPanel>
                        <TextBlock x:Name="EmptyText" FontSize="12" Margin="0,8,0,0"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Text="{DynamicResource Str.GhCompare.EmptyText}"/>
                        <ItemsControl x:Name="ResultsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,3,0,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="120"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Path}" FontSize="12"
                                                   Foreground="{DynamicResource TextBrush}" TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding Path}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Local}" FontFamily="Consolas" FontSize="11"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Repo}" FontFamily="Consolas" FontSize="11"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        <TextBlock Grid.Column="3" Text="{Binding Status}" FontSize="12"
                                                   FontWeight="SemiBold" Foreground="{Binding StatusBrush}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Footer -->
        <Grid Grid.Row="4" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="StatusText" Grid.Column="0" VerticalAlignment="Center"
                       FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                       TextWrapping="Wrap"
                       Text="{DynamicResource Str.GhCompare.FooterNote}"/>
            <Button Grid.Column="1" Content="{DynamicResource Str.Common.Close}" Style="{StaticResource SecondaryButton}"
                    Padding="20,8" Margin="12,0,0,0" VerticalAlignment="Center" Click="Close_Click"/>
        </Grid>
    </Grid>
</Window>
