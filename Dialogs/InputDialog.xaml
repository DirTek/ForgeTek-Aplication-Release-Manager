<Window x:Class="ForgeTekApplicationReleaseManager.Dialogs.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="420" SizeToContent="Height"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner"
        WindowStyle="ToolWindow" ShowInTaskbar="False"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource TextBrush}">
    <StackPanel Margin="24,20,24,24">

        <TextBlock x:Name="TitleText"
                   FontSize="16" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextBrush}"
                   TextWrapping="Wrap"/>

        <TextBlock x:Name="PromptText"
                   FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"
                   TextWrapping="Wrap" Margin="0,8,0,0"/>

        <TextBox x:Name="InputBox" Height="34" Margin="0,12,0,0"
                 VerticalContentAlignment="Center"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Cancel" Style="{StaticResource SecondaryButton}"
                    Padding="18,8" Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button x:Name="OkBtn" Content="OK" Style="{StaticResource PrimaryButton}"
                    Padding="28,8" Click="Ok_Click" IsDefault="True"/>
        </StackPanel>
    </StackPanel>
</Window>
