<Window x:Class="ForgeTekApplicationReleaseManager.Dialogs.SetupPublishSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Str.SetupPublish.Title}" Width="620" Height="660" MinWidth="560" MinHeight="520"
        WindowStartupLocation="CenterOwner" WindowStyle="SingleBorderWindow" ShowInTaskbar="False"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource TextBrush}">
    <Window.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="{DynamicResource Str.SetupPublish.Title}" FontSize="18" FontWeight="Bold"
                       Foreground="{DynamicResource TextBrush}"/>
            <TextBlock x:Name="SubtitleText" FontSize="12" Margin="0,4,0,0"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Text="{DynamicResource Str.SetupPublish.Subtitle}"/>
        </StackPanel>

        <!-- Copy from app -->
        <Border Grid.Row="1" Background="{DynamicResource SurfaceBrush}" CornerRadius="6"
                Padding="12,10" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{DynamicResource Str.SetupPublish.CopyFromApp}" FontSize="12" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,8,0"/>
                <ComboBox x:Name="CopyFromAppBox" Width="220" FontSize="12"
                          DisplayMemberPath="Name"/>
                <Button Content="{DynamicResource Str.SetupPublish.CopySettings}" Style="{StaticResource SecondaryButton}"
                        Padding="14,6" Margin="8,0,0,0" Click="CopyFromApp_Click"/>
            </StackPanel>
        </Border>

        <!-- Provider -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,4">
            <TextBlock Text="{DynamicResource Str.PublishSetup.Provider}" FontSize="12" VerticalAlignment="Center"
                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,8,0"/>
            <ComboBox x:Name="ProviderBox" Width="200" FontSize="12"
                      SelectionChanged="Provider_SelectionChanged">
                <ComboBoxItem Content="Ftp"/>
                <ComboBoxItem Content="Sftp"/>
                <ComboBoxItem Content="S3"/>
                <ComboBoxItem Content="GitHubReleases"/>
            </ComboBox>
        </StackPanel>

        <!-- Provider fields -->
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" Padding="0,8,12,0">
            <StackPanel>
                <!-- FTP -->
                <StackPanel x:Name="FtpPanel" Visibility="Collapsed">
                    <TextBlock Text="{DynamicResource Str.SetupPublish.Host}" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="FtpHostBox" Margin="0,0,0,8"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{DynamicResource Str.SetupPublish.Username}" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="FtpUserBox"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="{DynamicResource Str.SetupPublish.Password}" Style="{StaticResource FieldLabel}"/>
                            <PasswordBox x:Name="FtpPassBox"/>
                        </StackPanel>
                    </Grid>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{DynamicResource Str.SetupPublish.RemotePath}" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="FtpPathBox"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="{DynamicResource Str.SetupPublish.Port}" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="FtpPortBox"/>
                        </StackPanel>
                    </Grid>
                    <TextBlock Text="{DynamicResource Str.SetupPublish.PublicBaseUrl}" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="FtpBaseUrlBox"/>
                </StackPanel>

                <!-- SFTP -->
                <StackPanel x:Name="SftpPanel" Visibility="Collapsed">
                    <TextBlock Text="{DynamicResource Str.SetupPublish.Host}" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="SftpHostBox" Margin="0,0,0,8"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{DynamicResource Str.SetupPublish.Username}" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="SftpUserBox"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="{DynamicResource Str.SetupPublish.Password}" Style="{StaticResource FieldLabel}"/>
                            <PasswordBox x:Name="SftpPassBox"/>
                        </StackPanel>
                    </Grid>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{DynamicResource Str.SetupPublish.RemotePath}" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="SftpPathBox"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="{DynamicResource Str.SetupPublish.Port}" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="SftpPortBox"/>
                        </StackPanel>
                    </Grid>
                    <TextBlock Text="{DynamicResource Str.SetupPublish.PublicBaseUrl}" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="SftpBaseUrlBox"/>
                </StackPanel>

                <!-- S3 -->
                <StackPanel x:Name="S3Panel" Visibility="Collapsed">
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{DynamicResource Str.SetupPublish.Bucket}" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="S3BucketBox"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="{DynamicResource Str.SetupPublish.Region}" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="S3RegionBox"/>
                        </StackPanel>
                    </Grid>
                    <TextBlock Text="{DynamicResource Str.SetupPublish.Endpoint}" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="S3EndpointBox" Margin="0,0,0,8"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{DynamicResource Str.SetupPublish.AccessKey}" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="S3AccessKeyBox"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="{DynamicResource Str.SetupPublish.SecretKey}" Style="{StaticResource FieldLabel}"/>
                            <PasswordBox x:Name="S3SecretBox"/>
                        </StackPanel>
                    </Grid>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="2*"/></Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{DynamicResource Str.SetupPublish.Prefix}" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="S3PrefixBox"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="{DynamicResource Str.SetupPublish.PublicBaseUrl}" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="S3PublicBaseUrlBox"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <!-- GitHub Releases -->
                <StackPanel x:Name="GitHubPanel" Visibility="Collapsed">
                    <TextBlock Text="{DynamicResource Str.SetupPublish.Repository}" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="GhRepoBox" Margin="0,0,0,8"/>
                    <TextBlock Text="{DynamicResource Str.SetupPublish.Token}" Style="{StaticResource FieldLabel}"/>
                    <PasswordBox x:Name="GhTokenBox" Margin="0,0,0,8"/>
                    <TextBlock Text="{DynamicResource Str.SetupPublish.ReleaseTagPattern}" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="GhReleaseTagBox"/>
                    <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                               TextWrapping="Wrap" Margin="0,10,0,0"
                               Text="{DynamicResource Str.SetupPublish.GhNote}"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Actions -->
        <Grid Grid.Row="4" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="StatusText" Grid.Column="0" VerticalAlignment="Center"
                       FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                       TextTrimming="CharacterEllipsis"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button x:Name="TestBtn" Content="{DynamicResource Str.SetupPublish.Test}" Style="{StaticResource SecondaryButton}"
                        Padding="20,8" Click="Test_Click"/>
                <Button Content="{DynamicResource Str.Common.Save}" Style="{StaticResource PrimaryButton}"
                        Padding="22,8" Margin="8,0,0,0" Click="Save_Click"/>
                <Button Content="{DynamicResource Str.Common.Cancel}" Style="{StaticResource SecondaryButton}"
                        Padding="20,8" Margin="8,0,0,0" Click="Cancel_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
