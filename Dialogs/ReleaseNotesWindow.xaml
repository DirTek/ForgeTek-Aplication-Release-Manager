<Window x:Class="ForgeTekUpdatePackager.Dialogs.ReleaseNotesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Generate Release Notes" Width="900" Height="720" MinWidth="760" MinHeight="560"
        WindowStartupLocation="CenterOwner" WindowStyle="SingleBorderWindow" ShowInTaskbar="False"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource TextBrush}">
    <Window.Resources>
        <!-- The app's global ComboBox template has no editable text site, so editable combos render
             blank. This template adds a PART_EditableTextBox so selected/typed refs are visible. -->
        <Style x:Key="EditableCombo" TargetType="ComboBox">
            <Setter Property="Background"      Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Foreground"      Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="IsEditable"      Value="True"/>
            <Setter Property="IsSynchronizedWithCurrentItem" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="32"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="bd" Grid.ColumnSpan="2"
                                    Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="6"/>
                            <TextBox x:Name="PART_EditableTextBox" Grid.Column="0" Style="{x:Null}"
                                     Margin="9,0,0,0" Padding="0" BorderThickness="0"
                                     Background="Transparent"
                                     Foreground="{DynamicResource TextBrush}"
                                     CaretBrush="{DynamicResource TextBrush}"
                                     VerticalContentAlignment="Center"
                                     IsReadOnly="{TemplateBinding IsReadOnly}"/>
                            <ToggleButton Grid.Column="1" Focusable="False" Cursor="Hand"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay,
                                                      RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent">
                                            <Path Data="M 4 5 L 8 9 L 12 5"
                                                  Stroke="{DynamicResource TextSecondaryBrush}"
                                                  StrokeThickness="1.5"
                                                  StrokeEndLineCap="Round" StrokeStartLineCap="Round"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="Popup" Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Border Background="{DynamicResource SurfaceBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1" CornerRadius="6"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ComboBox}}">
                                    <ScrollViewer MaxHeight="220" VerticalScrollBarVisibility="Auto">
                                        <StackPanel IsItemsHost="True"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Draggable note row -->
        <DataTemplate x:Key="NoteItemTemplate">
            <Border Background="Transparent" Padding="2,1">
                <TextBlock Text="{Binding}" TextWrapping="Wrap" FontSize="12"
                           Foreground="{DynamicResource TextBrush}"/>
            </Border>
        </DataTemplate>

        <!-- List the notes are dragged between -->
        <Style x:Key="NoteList" TargetType="ListBox">
            <Setter Property="Background"      Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="AllowDrop"       Value="True"/>
            <Setter Property="ItemTemplate"    Value="{StaticResource NoteItemTemplate}"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>

        <Style x:Key="BucketHeader" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="Margin"     Value="2,8,0,4"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20,16,20,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0" x:Name="Tabs">

            <!-- ══ ORGANIZE ══════════════════════════════════════════════════ -->
            <TabItem Header="Organize">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextWrapping="Wrap">
                            Generate the commits, then drag each line into a section. Leave “from” blank
                            (or pick the same ref on both sides) to use the last N commits on the “to” branch.
                        </TextBlock>
                        <Border x:Name="LastCommitBox" Margin="0,8,0,0" Padding="10,7" CornerRadius="6"
                                Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1" Visibility="Collapsed">
                            <TextBlock x:Name="LastCommitText" FontSize="12" TextTrimming="CharacterEllipsis"
                                       Foreground="{DynamicResource TextBrush}"/>
                        </Border>
                    </StackPanel>

                    <!-- Ref pickers + Generate -->
                    <Grid Grid.Row="1" Margin="0,0,0,12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="FROM (optional — tag/branch)" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                            <ComboBox x:Name="FromCombo" Height="34" Style="{StaticResource EditableCombo}"/>
                        </StackPanel>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="→" VerticalAlignment="Bottom" Margin="0,0,0,6" FontSize="16"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <StackPanel Grid.Row="0" Grid.Column="2" Margin="8,0,8,0">
                            <TextBlock Text="TO (tag/branch)" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                            <ComboBox x:Name="ToCombo" Height="34" Style="{StaticResource EditableCombo}"/>
                        </StackPanel>
                        <Button Grid.Row="0" Grid.Column="3" x:Name="GenerateBtn" Content="Generate"
                                Style="{StaticResource PrimaryButton}" Padding="18,8" VerticalAlignment="Bottom"
                                Click="Generate_Click"/>

                        <StackPanel Grid.Row="1" Grid.ColumnSpan="4" Orientation="Horizontal" Margin="0,8,0,0">
                            <TextBlock Text="When “from” is blank, use the last" FontSize="11" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBox x:Name="CountBox" Text="20" Width="72" Height="32" Margin="6,0,6,0"
                                     Padding="8,4" VerticalContentAlignment="Center" TextAlignment="Center"/>
                            <TextBlock Text="commits on the “to” branch." FontSize="11" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Suggestions  |  category buckets -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0.42*"/>
                            <ColumnDefinition Width="0.58*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Suggestions pool -->
                        <DockPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock DockPanel.Dock="Top" Text="SUGGESTIONS (drag into a section →)"
                                       Style="{StaticResource BucketHeader}" Margin="2,0,0,4"/>
                            <ListBox x:Name="SuggestionsList" Style="{StaticResource NoteList}"/>
                        </DockPanel>

                        <!-- Buckets -->
                        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="ADDED" Style="{StaticResource BucketHeader}" Margin="2,0,0,4"/>
                                <ListBox x:Name="AddedList" Style="{StaticResource NoteList}" MinHeight="74"/>
                                <TextBlock Text="CHANGED" Style="{StaticResource BucketHeader}"/>
                                <ListBox x:Name="ChangedList" Style="{StaticResource NoteList}" MinHeight="74"/>
                                <TextBlock Text="IMPROVED" Style="{StaticResource BucketHeader}"/>
                                <ListBox x:Name="ImprovedList" Style="{StaticResource NoteList}" MinHeight="74"/>
                                <TextBlock Text="REMOVED" Style="{StaticResource BucketHeader}"/>
                                <ListBox x:Name="RemovedList" Style="{StaticResource NoteList}" MinHeight="74"/>
                                <TextBlock Text="FIXED" Style="{StaticResource BucketHeader}"/>
                                <ListBox x:Name="FixedList" Style="{StaticResource NoteList}" MinHeight="74"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <!-- Version + date + build -->
                    <Grid Grid.Row="3" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Version" FontSize="12" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,8,0"/>
                        <TextBox Grid.Column="1" x:Name="VersionBox" Width="150" Height="32"
                                 VerticalContentAlignment="Center" Padding="8,0"
                                 ToolTip="e.g. 0.1.0"/>
                        <TextBlock Grid.Column="2" Text="Date" FontSize="12" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="16,0,8,0"/>
                        <DatePicker Grid.Column="3" x:Name="DatePick" Height="32" Width="150"
                                    VerticalContentAlignment="Center"/>
                        <Button Grid.Column="5" Content="Build Draft →" Style="{StaticResource PrimaryButton}"
                                Padding="18,8" Click="BuildDraft_Click"/>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ══ DRAFT ═════════════════════════════════════════════════════ -->
            <TabItem Header="Draft">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                               TextWrapping="Wrap" Margin="0,0,0,10"
                               Text="Final Markdown — edit freely, then copy, save, or publish to a GitHub release."/>
                    <Border Grid.Row="1" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" CornerRadius="6" Padding="2">
                        <TextBox x:Name="NotesBox" AcceptsReturn="True" AcceptsTab="True" TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto" Background="Transparent" BorderThickness="0"
                                 FontFamily="Consolas" FontSize="13" Padding="8"
                                 Foreground="{DynamicResource TextBrush}"/>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Status -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,0">
            <ProgressBar x:Name="Spinner" IsIndeterminate="True" Width="110" Height="4"
                         VerticalAlignment="Center" Margin="0,0,10,0" Visibility="Collapsed"/>
            <TextBlock x:Name="StatusText" FontSize="12" VerticalAlignment="Center"
                       Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Actions -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button x:Name="CopyBtn" Content="Copy" Style="{StaticResource SecondaryButton}"
                    Padding="16,8" Margin="0,0,8,0" Click="Copy_Click" IsEnabled="False"/>
            <Button x:Name="SaveBtn" Content="Save .md…" Style="{StaticResource SecondaryButton}"
                    Padding="16,8" Margin="0,0,8,0" Click="Save_Click" IsEnabled="False"/>
            <Button x:Name="ChangelogBtn" Content="Add to Changelog" Style="{StaticResource PrimaryButton}"
                    Padding="16,8" Margin="0,0,8,0" Click="AddToChangelog_Click"
                    IsEnabled="False" Visibility="Collapsed"/>
            <Button x:Name="PublishBtn" Content="Publish to GitHub…" Style="{StaticResource SecondaryButton}"
                    Padding="16,8" Margin="0,0,8,0" Click="Publish_Click" IsEnabled="False"/>
            <Button Content="Close" Style="{StaticResource SecondaryButton}"
                    Padding="16,8" Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
