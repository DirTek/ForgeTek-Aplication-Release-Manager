<Window x:Class="ForgeTekApplicationReleaseManager.Dialogs.ConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="420" SizeToContent="Height"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner"
        WindowStyle="ToolWindow" ShowInTaskbar="False"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource TextBrush}">
    <StackPanel Margin="24,20,24,24">

        <TextBlock x:Name="TitleText"
                   FontSize="16" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextBrush}"
                   TextWrapping="Wrap"/>

        <TextBlock x:Name="MessageText"
                   FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"
                   TextWrapping="Wrap" Margin="0,12,0,0"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,0">
            <Button Content="Cancel" Style="{StaticResource SecondaryButton}"
                    Padding="20,9" Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button x:Name="ConfirmBtn" Style="{StaticResource DangerButton}"
                    Padding="20,9" Click="Confirm_Click"/>
        </StackPanel>

    </StackPanel>
</Window>
