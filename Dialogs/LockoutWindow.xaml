<Window x:Class="ForgeTekApplicationReleaseManager.Dialogs.LockoutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Str.App.Title}" Width="460"
        SizeToContent="Height" ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen" WindowStyle="SingleBorderWindow"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource TextBrush}">
    <StackPanel Margin="28,24,28,24">

        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="&#xE72E;" FontFamily="Segoe Fluent Icons" FontSize="22"
                       Foreground="{DynamicResource RemovedBrush}" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBlock Text="{DynamicResource Str.Lockout.Title}" FontSize="22" FontWeight="Bold"
                       Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
        </StackPanel>

        <TextBlock FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                   TextWrapping="Wrap" Margin="0,0,0,16"
                   Text="{DynamicResource Str.Lockout.Desc}"/>

        <TextBlock x:Name="ErrorText" FontSize="12" Foreground="{DynamicResource RemovedBrush}"
                   TextWrapping="Wrap" Margin="0,0,0,12" Visibility="Collapsed"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{DynamicResource Str.Lockout.Exit}" Style="{StaticResource SecondaryButton}"
                    Padding="20,9" Margin="0,0,8,0" Click="Exit_Click"/>
            <Button Content="{DynamicResource Str.Lockout.Restore}" Style="{StaticResource PrimaryButton}"
                    Padding="20,9" Click="Restore_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
