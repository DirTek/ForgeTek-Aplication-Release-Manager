<Window x:Class="ForgeTekUpdatePackager.Dialogs.LockoutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ForgeTek Release Manager" Width="460"
        SizeToContent="Height" ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen" WindowStyle="SingleBorderWindow"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource TextBrush}">
    <StackPanel Margin="28,24,28,24">

        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="&#xE72E;" FontFamily="Segoe Fluent Icons" FontSize="22"
                       Foreground="{DynamicResource RemovedBrush}" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBlock Text="Access locked" FontSize="22" FontWeight="Bold"
                       Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
        </StackPanel>

        <TextBlock FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                   TextWrapping="Wrap" Margin="0,0,0,16">
            Access protection is enabled, but the user database is missing or corrupt.
            Restore a backup that includes your users (created after this update), then the app will relaunch.
        </TextBlock>

        <TextBlock x:Name="ErrorText" FontSize="12" Foreground="{DynamicResource RemovedBrush}"
                   TextWrapping="Wrap" Margin="0,0,0,12" Visibility="Collapsed"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Exit" Style="{StaticResource SecondaryButton}"
                    Padding="20,9" Margin="0,0,8,0" Click="Exit_Click"/>
            <Button Content="Restore from backup…" Style="{StaticResource PrimaryButton}"
                    Padding="20,9" Click="Restore_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
