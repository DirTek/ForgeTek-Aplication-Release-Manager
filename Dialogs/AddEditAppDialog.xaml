<Window x:Class="ForgeTekUpdatePackager.Dialogs.AddEditAppDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:colorpicker="clr-namespace:ColorPicker;assembly=ColorPicker"
        Title="Application" Width="500"
        SizeToContent="Height"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource TextBrush}">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/ColorPicker;component/Styles/DefaultColorPickerStyle.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <StackPanel Margin="24,20,24,24">

        <!-- Application Name -->
        <TextBlock Text="Application Name"
                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
        <TextBox x:Name="NameBox" Height="36" Margin="0,6,0,0"/>

        <!-- Folder Path -->
        <TextBlock Text="Folder Path"
                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,14,0,0"/>
        <Grid Margin="0,6,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" x:Name="PathBox" Height="36"/>
            <Button  Grid.Column="2" Content="Browse…" Height="36" Padding="14,0"
                     Style="{StaticResource SecondaryButton}" Click="Browse_Click"/>
        </Grid>

        <!-- Main Executable (Add mode only) -->
        <TextBlock x:Name="ExeLabel" Text="Main Executable"
                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,14,0,0"/>
        <Grid Margin="0,6,0,0">
            <ProgressBar x:Name="ScanProgress" IsIndeterminate="True" Height="36"
                         Visibility="Collapsed"/>
            <ComboBox x:Name="ExeBox" Height="36" IsEnabled="False"
                      SelectionChanged="ExeBox_SelectionChanged"/>
            <TextBlock x:Name="ScanErrorText" Foreground="{StaticResource RemovedBrush}"
                       FontSize="12" VerticalAlignment="Center"
                       Visibility="Collapsed"/>
        </Grid>

        <!-- Accent Color -->
        <TextBlock Text="Accent Color"
                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,14,0,0"/>
        <Grid Margin="0,6,0,0" HorizontalAlignment="Left">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="36"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <colorpicker:PortableColorPicker Grid.Column="0" x:Name="ColorPicker"
                                              ShowAlpha="False"
                                              Width="36" Height="30"
                                              Style="{StaticResource DefaultColorPickerStyle}"
                                              ColorChanged="ColorPicker_ColorChanged" />
            <Button Grid.Column="2" Content="Choose Color…" Height="36" Padding="14,0"
                    Style="{StaticResource SecondaryButton}" Click="ChooseColor_Click"/>
        </Grid>

        <!-- Initial Version (Add mode only) -->
        <TextBlock x:Name="VersionLabel" Text="Initial Version"
                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,14,0,0"/>
        <TextBox x:Name="VersionBox" Height="36" Margin="0,6,0,0" Text="1.0.0"/>

        <!-- Inline validation error -->
        <TextBlock x:Name="ErrorText" Foreground="{StaticResource RemovedBrush}"
                   FontSize="12" TextWrapping="Wrap"
                   Margin="0,14,0,-6" Visibility="Collapsed"/>

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Cancel" Style="{StaticResource SecondaryButton}"
                    Padding="20,9" Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button Content="Add Application" x:Name="SaveBtn" Style="{StaticResource PrimaryButton}"
                    Padding="20,9" Click="Save_Click"/>
        </StackPanel>

    </StackPanel>
</Window>
