<Window x:Class="ForgeTekApplicationReleaseManager.Dialogs.BackupDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Str.Backup.Title}" Width="580"
        SizeToContent="Height"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner"
        WindowStyle="ToolWindow" ShowInTaskbar="False"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource TextBrush}">
    <StackPanel Margin="24,20,24,24">

        <TextBlock FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                   TextWrapping="Wrap" Margin="0,0,0,16"
                   Text="{DynamicResource Str.Backup.Desc}"/>

        <!-- What to include -->
        <TextBlock Text="{DynamicResource Str.Backup.Include}" FontSize="10" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>
        <StackPanel Margin="0,0,0,18">
            <CheckBox x:Name="IncludeAppsCheck" IsChecked="True" FontSize="13"
                      Foreground="{DynamicResource TextBrush}"
                      Content="{DynamicResource Str.Backup.AppsOption}"/>
            <CheckBox x:Name="IncludeSetupsCheck" IsChecked="True" FontSize="13" Margin="0,8,0,0"
                      Foreground="{DynamicResource TextBrush}"
                      Content="{DynamicResource Str.Backup.SetupsOption}"/>
        </StackPanel>

        <!-- Output path -->
        <TextBlock Text="{DynamicResource Str.Backup.OutputFile}" FontSize="10" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
        <Grid Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" x:Name="OutputPathBox" Height="36" IsReadOnly="True"/>
            <Button  Grid.Column="2" x:Name="BrowseBtn" Content="{DynamicResource Str.Common.Browse}" Height="36" Padding="14,0"
                     Style="{StaticResource SecondaryButton}" Click="Browse_Click"/>
        </Grid>

        <!-- Create button -->
        <Button x:Name="CreateBackupBtn" Content="{DynamicResource Str.Backup.CreateBackup}"
                Style="{StaticResource PrimaryButton}"
                Padding="20,10" HorizontalAlignment="Left" Margin="0,0,0,16"
                Click="CreateBackup_Click"/>

        <!-- Progress log -->
        <Border x:Name="LogBorder" Background="{DynamicResource SurfaceBrush}"
                CornerRadius="6" Padding="12,10" MaxHeight="320"
                Margin="0,0,0,16" Visibility="Collapsed">
            <ScrollViewer x:Name="LogScroller" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="LogItems">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="12"
                                       Foreground="{DynamicResource TextBrush}" TextWrapping="Wrap"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Close -->
        <Button Content="{DynamicResource Str.Common.Close}" Style="{StaticResource SecondaryButton}"
                Padding="20,9" HorizontalAlignment="Right"
                Click="Close_Click"/>

    </StackPanel>
</Window>
