<Window x:Class="ForgeTekApplicationReleaseManager.Dialogs.GenerateUpdaterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Str.GenUpdater.Title}" Width="620" Height="520" MinWidth="540" MinHeight="440"
        WindowStartupLocation="CenterOwner" WindowStyle="SingleBorderWindow" ShowInTaskbar="False"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource TextBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="{DynamicResource Str.GenUpdater.Title}" FontSize="18" FontWeight="Bold"
                       Foreground="{DynamicResource TextBrush}"/>
            <TextBlock x:Name="SubtitleText" FontSize="12" Margin="0,4,0,0"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
        </StackPanel>

        <!-- Config -->
        <Border Grid.Row="1" Background="{DynamicResource SurfaceBrush}" CornerRadius="6"
                Padding="14,12" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- App exe -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource Str.GenUpdater.AppExe}"
                           FontSize="12" VerticalAlignment="Center" Margin="0,0,0,8"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <ComboBox x:Name="AppExeBox" Grid.Row="0" Grid.Column="1"
                          FontSize="12" Margin="0,0,8,8" SelectionChanged="AppExeBox_SelectionChanged"/>
                <Button Grid.Row="0" Grid.Column="2" Content="{DynamicResource Str.Common.Browse}"
                        Style="{StaticResource SecondaryButton}" Padding="12,6" Margin="0,0,0,8"
                        Click="BrowseExe_Click"/>

                <!-- Package extension (read-only) -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource Str.GenUpdater.Extension}"
                           FontSize="12" VerticalAlignment="Center" Margin="0,0,0,8"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <TextBlock x:Name="ExtensionText" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
                           FontSize="12" VerticalAlignment="Center" Margin="0,0,0,8"
                           Foreground="{DynamicResource TextBrush}"/>

                <!-- Icon -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource Str.GenUpdater.Icon}"
                           FontSize="12" VerticalAlignment="Center" Margin="0,0,0,8"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <TextBox x:Name="IconBox" Grid.Row="2" Grid.Column="1" FontSize="12" Margin="0,0,8,8"/>
                <Button Grid.Row="2" Grid.Column="2" Content="{DynamicResource Str.Common.Browse}"
                        Style="{StaticResource SecondaryButton}" Padding="12,6" Margin="0,0,0,8"
                        Click="BrowseIcon_Click"/>

                <!-- Output folder -->
                <TextBlock Grid.Row="3" Grid.Column="0" Text="{DynamicResource Str.GenUpdater.OutputFolder}"
                           FontSize="12" VerticalAlignment="Center" Margin="0,0,0,8"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <TextBox x:Name="OutputBox" Grid.Row="3" Grid.Column="1" FontSize="12" Margin="0,0,8,8"/>
                <Button Grid.Row="3" Grid.Column="2" Content="{DynamicResource Str.Common.Browse}"
                        Style="{StaticResource SecondaryButton}" Padding="12,6" Margin="0,0,0,8"
                        Click="BrowseOutput_Click"/>

                <!-- Sign -->
                <CheckBox x:Name="SignCheck" Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2"
                          Content="{DynamicResource Str.GenUpdater.Sign}" FontSize="12"
                          Foreground="{DynamicResource TextBrush}" Visibility="Collapsed"/>
            </Grid>
        </Border>

        <!-- Log -->
        <Border Grid.Row="2" Background="{DynamicResource SurfaceBrush}" CornerRadius="6" Padding="10,8">
            <DockPanel>
                <ProgressBar x:Name="GenBar" DockPanel.Dock="Top" Height="6" IsIndeterminate="False"
                             Margin="0,0,0,8" Visibility="Collapsed"/>
                <ScrollViewer x:Name="LogScroller" VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="LogText" FontFamily="Consolas" FontSize="11" TextWrapping="Wrap"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Result -->
        <Grid Grid.Row="3" Margin="0,12,0,0" x:Name="ResultPanel" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="ResultBox" Grid.Column="0" IsReadOnly="True"
                     Foreground="{DynamicResource TextBrush}"/>
            <Button Grid.Column="1" Content="{DynamicResource Str.GenUpdater.Reveal}" Style="{StaticResource SecondaryButton}"
                    Padding="14,6" Margin="8,0,0,0" Click="Reveal_Click"/>
        </Grid>

        <!-- Actions -->
        <Grid Grid.Row="4" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="StatusText" Grid.Column="0" VerticalAlignment="Center"
                       FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                       TextTrimming="CharacterEllipsis"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button x:Name="GenerateBtn" Content="{DynamicResource Str.GenUpdater.Generate}" Style="{StaticResource PrimaryButton}"
                        Padding="22,8" Click="Generate_Click"/>
                <Button x:Name="CloseBtn" Content="{DynamicResource Str.Common.Close}" Style="{StaticResource SecondaryButton}"
                        Padding="22,8" Margin="8,0,0,0" Click="Close_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
