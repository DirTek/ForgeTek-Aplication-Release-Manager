<Window x:Class="ForgeTekUpdatePackager.Dialogs.WingetManifestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Winget Manifest" Width="720" Height="760" MinWidth="640" MinHeight="560"
        WindowStartupLocation="CenterOwner" WindowStyle="SingleBorderWindow" ShowInTaskbar="False"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource TextBrush}">
    <Window.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Generate Winget Manifest" FontSize="18" FontWeight="Bold"
                       Foreground="{DynamicResource TextBrush}"/>
            <TextBlock x:Name="SubtitleText" FontSize="12" Margin="0,4,0,0"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
        </StackPanel>

        <!-- Form -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,12,0">
            <StackPanel>
                <TextBlock Text="Package identifier" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="IdentifierBox" Margin="0,0,0,10"/>

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Publisher" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="PublisherBox"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Package name" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="PackageNameBox"/>
                    </StackPanel>
                </Grid>

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Version" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="VersionBox"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Moniker (winget install &lt;moniker&gt;)" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="MonikerBox"/>
                    </StackPanel>
                </Grid>

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="License (required)" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="LicenseBox"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="License URL" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="LicenseUrlBox"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="Short description (required)" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="ShortDescriptionBox" Margin="0,0,0,10"/>

                <TextBlock Text="Description (optional)" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="DescriptionBox" Margin="0,0,0,10"
                         AcceptsReturn="True" TextWrapping="Wrap" MinHeight="48" MaxHeight="96"
                         VerticalScrollBarVisibility="Auto"/>

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Package URL (home page)" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="PackageUrlBox"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Tags (comma-separated)" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="TagsBox"/>
                    </StackPanel>
                </Grid>

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Publisher URL" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="PublisherUrlBox"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Publisher support URL" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="PublisherSupportUrlBox"/>
                    </StackPanel>
                </Grid>

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Architecture" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="ArchitectureBox">
                            <ComboBoxItem Content="x64"/>
                            <ComboBoxItem Content="x86"/>
                            <ComboBoxItem Content="arm64"/>
                            <ComboBoxItem Content="neutral"/>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Installer type" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="InstallerTypeBox">
                            <ComboBoxItem Content="exe"/>
                            <ComboBoxItem Content="inno"/>
                            <ComboBoxItem Content="nullsoft"/>
                            <ComboBoxItem Content="msi"/>
                            <ComboBoxItem Content="burn"/>
                            <ComboBoxItem Content="portable"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <TextBlock Text="Installer URL (public https)" Style="{StaticResource FieldLabel}"/>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="InstallerUrlBox" Grid.Column="0"/>
                    <Button x:Name="SuggestUrlBtn" Grid.Column="1" Content="Suggest" Margin="8,0,0,0"
                            Padding="14,6" Style="{StaticResource SecondaryButton}"
                            Click="SuggestUrl_Click"/>
                </Grid>

                <TextBlock Text="Installer SHA256" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="Sha256Box" Margin="0,0,0,10" IsReadOnly="True"
                         Foreground="{DynamicResource TextSecondaryBrush}"/>

                <TextBlock Text="Output folder" Style="{StaticResource FieldLabel}"/>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="OutputFolderBox" Grid.Column="0"/>
                    <Button Grid.Column="1" Content="Browse…" Margin="8,0,0,0"
                            Padding="14,6" Style="{StaticResource SecondaryButton}"
                            Click="BrowseOutput_Click"/>
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <!-- Output log -->
        <Border Grid.Row="2" Background="{DynamicResource SurfaceBrush}" CornerRadius="6"
                Margin="0,12,0,0" Padding="10,8" MaxHeight="120"
                Visibility="Collapsed" x:Name="LogPanel">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="LogText" FontFamily="Consolas" FontSize="11" TextWrapping="Wrap"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
            </ScrollViewer>
        </Border>

        <!-- Actions -->
        <Grid Grid.Row="3" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="StatusText" Grid.Column="0" VerticalAlignment="Center"
                       FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                       TextTrimming="CharacterEllipsis"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button x:Name="GenerateBtn" Content="Generate" Style="{StaticResource PrimaryButton}"
                        Padding="20,8" Click="Generate_Click"/>
                <Button x:Name="ValidateBtn" Content="Validate" Style="{StaticResource SecondaryButton}"
                        Padding="20,8" Margin="8,0,0,0" Click="Validate_Click"/>
                <Button x:Name="SubmitBtn" Content="Submit…" Style="{StaticResource SecondaryButton}"
                        Padding="20,8" Margin="8,0,0,0" Click="Submit_Click"/>
                <Button Content="Close" Style="{StaticResource SecondaryButton}"
                        Padding="20,8" Margin="8,0,0,0" Click="Close_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
