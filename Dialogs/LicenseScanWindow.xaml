<Window x:Class="ForgeTekApplicationReleaseManager.Dialogs.LicenseScanWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Str.License.Title}" Width="820" Height="720" MinWidth="680" MinHeight="560"
        WindowStartupLocation="CenterOwner" WindowStyle="SingleBorderWindow" ShowInTaskbar="False"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource TextBrush}">
    <Window.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="{DynamicResource Str.License.Title}" FontSize="18" FontWeight="Bold"
                       Foreground="{DynamicResource TextBrush}"/>
            <TextBlock x:Name="SubtitleText" FontSize="12" Margin="0,4,0,0"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
        </StackPanel>

        <!-- Path + scan -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="PathBox" Grid.Column="0" VerticalContentAlignment="Center"
                     ToolTip="{DynamicResource Str.VulnScan.PathTip}"/>
            <Button Grid.Column="1" Content="{DynamicResource Str.Common.Browse}" Style="{StaticResource SecondaryButton}"
                    Padding="14,6" Margin="8,0,0,0" Click="Browse_Click"/>
            <Button x:Name="ScanBtn" Grid.Column="2" Content="{DynamicResource Str.VulnScan.Scan}" Style="{StaticResource PrimaryButton}"
                    Padding="20,6" Margin="8,0,0,0" Click="Scan_Click"/>
        </Grid>

        <!-- Verdict + summary -->
        <Border Grid.Row="2" x:Name="VerdictPanel" CornerRadius="6" Padding="12,10" Margin="0,0,0,12"
                Visibility="Collapsed" Background="{DynamicResource SurfaceBrush}">
            <StackPanel>
                <TextBlock x:Name="VerdictText" FontSize="14" FontWeight="SemiBold"/>
                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                    <TextBlock x:Name="BlockedText" FontSize="12" Margin="0,0,16,0" Foreground="#FF6B6B"/>
                    <TextBlock x:Name="WarnText" FontSize="12" Margin="0,0,16,0" Foreground="#FFD166"/>
                    <TextBlock x:Name="AllowedText" FontSize="12" Foreground="{DynamicResource AddedBrush}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Results -->
        <Border Grid.Row="3" Background="{DynamicResource SurfaceBrush}" CornerRadius="6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="12,10,12,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="90"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{DynamicResource Str.License.ColPackage}" Style="{StaticResource FieldLabel}"/>
                    <TextBlock Grid.Column="1" Text="{DynamicResource Str.License.ColVersion}" Style="{StaticResource FieldLabel}"/>
                    <TextBlock Grid.Column="2" Text="{DynamicResource Str.License.ColLicense}" Style="{StaticResource FieldLabel}"/>
                    <TextBlock Grid.Column="3" Text="{DynamicResource Str.License.ColStatus}" Style="{StaticResource FieldLabel}"/>
                </Grid>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="12,0,12,10">
                    <StackPanel>
                        <TextBlock x:Name="EmptyText" FontSize="12" Margin="0,8,0,0"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Text="{DynamicResource Str.VulnScan.EmptyText}"/>
                        <ItemsControl x:Name="ResultsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,4,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="90"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Id}" FontSize="12"
                                                       Foreground="{DynamicResource TextBrush}" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{DynamicResource Str.VulnScan.Transitive}" FontSize="10"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       Visibility="{Binding Transitive, Converter={StaticResource BoolToVisibility}}"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{Binding Version}" FontSize="12"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{Binding License}" FontSize="12"
                                                   Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="3" Text="{Binding Status}" FontSize="12"
                                                   FontWeight="SemiBold" Foreground="{Binding StatusBrush}" VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Policy editor + export -->
        <Border Grid.Row="4" Background="{DynamicResource SurfaceBrush}" CornerRadius="6"
                Padding="12,10" Margin="0,12,0,0">
            <StackPanel>
                <TextBlock Text="{DynamicResource Str.License.PolicyLabel}"
                           Style="{StaticResource FieldLabel}"/>
                <Grid Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{DynamicResource Str.License.Allowed}" FontSize="11" Foreground="{DynamicResource AddedBrush}"/>
                        <TextBox x:Name="AllowedBox" Height="48" AcceptsReturn="True" TextWrapping="Wrap" FontSize="11"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="{DynamicResource Str.License.Warn}" FontSize="11" Foreground="#FFD166"/>
                        <TextBox x:Name="WarnBox" Height="48" AcceptsReturn="True" TextWrapping="Wrap" FontSize="11"/>
                    </StackPanel>
                    <StackPanel Grid.Column="4">
                        <TextBlock Text="{DynamicResource Str.License.Block}" FontSize="11" Foreground="#FF6B6B"/>
                        <TextBox x:Name="BlockBox" Height="48" AcceptsReturn="True" TextWrapping="Wrap" FontSize="11"/>
                    </StackPanel>
                </Grid>
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <TextBlock Text="{DynamicResource Str.License.UnknownLicense}" FontSize="11" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,8,0"/>
                    <ComboBox x:Name="UnknownPolicy" Width="90" FontSize="11"/>
                    <Button Content="{DynamicResource Str.VulnScan.ApplyPolicy}" Style="{StaticResource PrimaryButton}"
                            Padding="14,6" Margin="16,0,0,0" Click="ApplyPolicy_Click"
                            ToolTip="{DynamicResource Str.License.ApplyPolicyTip}"/>
                    <Button Content="{DynamicResource Str.VulnScan.SavePolicy}" Style="{StaticResource SecondaryButton}"
                            Padding="14,6" Margin="8,0,0,0" Click="SavePolicy_Click"/>
                    <Button Content="{DynamicResource Str.License.ExportTxt}" Style="{StaticResource SecondaryButton}"
                            Padding="14,6" Margin="8,0,0,0" Click="ExportTxt_Click"/>
                    <Button Content="{DynamicResource Str.License.ExportHtml}" Style="{StaticResource SecondaryButton}"
                            Padding="14,6" Margin="8,0,0,0" Click="ExportHtml_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Status + close -->
        <Grid Grid.Row="5" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="StatusText" Grid.Column="0" VerticalAlignment="Center"
                       FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                       TextTrimming="CharacterEllipsis"/>
            <Button Grid.Column="1" Content="{DynamicResource Str.Common.Close}" Style="{StaticResource SecondaryButton}"
                    Padding="20,8" Click="Close_Click"/>
        </Grid>
    </Grid>
</Window>
