<UserControl x:Class="ForgeTekUpdatePackager.Dialogs.NoChangesDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource SurfaceBrush}"
             Width="420">
    <Grid Margin="28,24,28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="No Changes Detected" FontSize="18" FontWeight="Bold"
                   Foreground="{StaticResource TextBrush}" Margin="0,0,0,16"/>

        <!-- Message -->
        <StackPanel Grid.Row="1">
            <TextBlock Text="No new or modified files were detected since the last scan."
                       FontSize="13" Foreground="{StaticResource TextBrush}" TextWrapping="Wrap"/>
            <TextBlock Text="If files were signed, their checksums may have changed — try scanning again."
                       FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"
                       Margin="0,12,0,0"/>
        </StackPanel>

        <!-- OK button -->
        <Button Grid.Row="2" Content="OK" Style="{StaticResource PrimaryButton}"
                Padding="32,8" HorizontalAlignment="Right" Margin="0,24,0,0"
                Click="OkButton_Click"/>
    </Grid>
</UserControl>
