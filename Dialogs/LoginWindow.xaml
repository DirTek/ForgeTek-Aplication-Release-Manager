<Window x:Class="ForgeTekApplicationReleaseManager.Dialogs.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Str.App.Title}" Width="400"
        SizeToContent="Height" ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen" WindowStyle="SingleBorderWindow"
        ShowInTaskbar="True"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource TextBrush}">
    <StackPanel Margin="28,24,28,24">

        <TextBlock Text="{DynamicResource Str.Login.SignIn}" FontSize="22" FontWeight="Bold"
                   Foreground="{DynamicResource TextBrush}"/>
        <TextBlock Text="{DynamicResource Str.Login.Subtitle}"
                   FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,20"/>

        <TextBlock Text="{DynamicResource Str.Login.Username}" FontSize="10" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
        <TextBox x:Name="UsernameBox" Height="36" Margin="0,0,0,14"/>

        <TextBlock Text="{DynamicResource Str.Login.Password}" FontSize="10" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
        <PasswordBox x:Name="PasswordBox" Height="36" Margin="0,0,0,12"/>

        <TextBlock x:Name="ErrorText" FontSize="12" Foreground="{DynamicResource RemovedBrush}"
                   TextWrapping="Wrap" Margin="0,0,0,12" Visibility="Collapsed"/>

        <Button Content="{DynamicResource Str.Login.SignIn}" Style="{StaticResource PrimaryButton}"
                Padding="0,10" IsDefault="True" Click="SignIn_Click"/>
    </StackPanel>
</Window>
