<Window x:Class="ForgeTekUpdatePackager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ForgeTekUpdatePackager.ViewModels"
        Title="ForgeTek Update Packager"
        Height="720" Width="1400" MinHeight="560" MinWidth="1300"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="1"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ── Sidebar ──────────────────────────────────────────── -->
        <Grid Grid.Column="0" Background="{StaticResource SidebarBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Branding -->
            <StackPanel Grid.Row="0" Margin="16,20,16,14">
                <TextBlock Text="ForgeTek" FontSize="20" FontWeight="Bold"
                           Foreground="{StaticResource TextBrush}"/>
                <TextBlock Text="Update Packager" FontSize="11"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0"/>
            </StackPanel>

            <!-- Divider -->
            <Rectangle Grid.Row="1" Height="1" Fill="{StaticResource BorderBrush}" Margin="16,0"/>

            <!-- App list label -->

            <!-- App list -->
            <ListBox Grid.Row="2" Margin="8,8,8,0"
                     ItemsSource="{Binding Apps}"
                     SelectedItem="{Binding SelectedApp}"
                     Background="Transparent" BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ItemContainerStyle="{StaticResource SidebarItemStyle}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel>
                            <TextBlock Text="{Binding Name}" FontSize="13"
                                       Foreground="{StaticResource TextBrush}" FontWeight="SemiBold"/>

                            <!-- Version display — switches template based on DisplayMode -->
                            <ContentControl Content="{Binding}" Focusable="False" Margin="0,2,0,0">
                                <ContentControl.Style>
                                    <Style TargetType="ContentControl">

                                        <!-- Default: Published — show current version -->
                                        <Setter Property="ContentTemplate">
                                            <Setter.Value>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding CurrentVersionText}" FontSize="11"
                                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                                </DataTemplate>
                                            </Setter.Value>
                                        </Setter>

                                        <Style.Triggers>

                                            <!-- None: no versions yet -->
                                            <DataTrigger Binding="{Binding DisplayMode}" Value="None">
                                                <Setter Property="ContentTemplate">
                                                    <Setter.Value>
                                                        <DataTemplate>
                                                            <TextBlock Text="No versions" FontSize="11"
                                                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                                                        </DataTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>

                                            <!-- InProgress: 0.1.1 → 0.1.2 (with status color on next) -->
                                            <DataTrigger Binding="{Binding DisplayMode}" Value="InProgress">
                                                <Setter Property="ContentTemplate">
                                                    <Setter.Value>
                                                        <DataTemplate>
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="{Binding CurrentVersionText}" FontSize="11"
                                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                                           Visibility="{Binding HasCurrentVersion, Converter={StaticResource BoolToVisibility}}"/>
                                                                <TextBlock Text=" → " FontSize="11"
                                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                                           Visibility="{Binding HasCurrentVersion, Converter={StaticResource BoolToVisibility}}"/>
                                                                <TextBlock Text="{Binding NextVersionText}" FontSize="11">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding NextVersionStatus}" Value="Signed">
                                                                                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding NextVersionStatus}" Value="Packed">
                                                                                    <Setter Property="Foreground" Value="{StaticResource AddedBrush}"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>

                                            <!-- Retracted: ~~0.1.2~~ → 0.1.1 -->
                                            <DataTrigger Binding="{Binding DisplayMode}" Value="Retracted">
                                                <Setter Property="ContentTemplate">
                                                    <Setter.Value>
                                                        <DataTemplate>
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="{Binding RetractedVersionText}" FontSize="11"
                                                                           Foreground="{StaticResource RemovedBrush}"
                                                                           TextDecorations="Strikethrough"/>
                                                                <TextBlock Text=" → " FontSize="11"
                                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                                           Visibility="{Binding HasPreviousVersion, Converter={StaticResource BoolToVisibility}}"/>
                                                                <TextBlock Text="{Binding PreviousVersionText}" FontSize="11"
                                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                                           Visibility="{Binding HasPreviousVersion, Converter={StaticResource BoolToVisibility}}"/>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>

                                        </Style.Triggers>
                                    </Style>
                                </ContentControl.Style>
                            </ContentControl>

                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Bottom actions -->
            <StackPanel Grid.Row="3">
                <Rectangle Height="1" Fill="{StaticResource BorderBrush}" Margin="16,0"/>
                <Button Content="Options" Style="{StaticResource SecondaryButton}"
                        Margin="12,8,12,4" Padding="0,10"
                        Click="Options_Click"/>
                <Button Content="+ Add Application" Style="{StaticResource PrimaryButton}"
                        Margin="12,4,12,16" Padding="0,10"
                        Click="AddApp_Click"/>
            </StackPanel>
        </Grid>

        <!-- ── Sidebar / Content divider ────────────────────────── -->
        <Rectangle Grid.Column="1" Fill="{StaticResource BorderBrush}"/>

        <!-- ── Content area (driven by DataTemplates) ───────────── -->
        <ContentControl Grid.Column="2" Content="{Binding CurrentView}"/>
    </Grid>
</Window>
