<Window x:Class="ForgeTekUpdatePackager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ForgeTekUpdatePackager.ViewModels"
        Title="ForgeTek Release Manager"
        Height="720" Width="1400" MinHeight="560" MinWidth="1300"
        Background="{DynamicResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="1"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ── Sidebar ──────────────────────────────────────────── -->
        <Grid Grid.Column="0" Background="{DynamicResource SidebarBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Branding -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="16,20,16,14">
                <Image Source="/forgetek-logo.png" Width="36" Height="36"
                       Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,10,0"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="ForgeTek" FontSize="20" FontWeight="Bold"
                               Foreground="{DynamicResource TextBrush}"/>
                    <TextBlock Text="Release Manager" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>

            <!-- Divider -->
            <Rectangle Grid.Row="1" Height="1" Fill="{DynamicResource BorderBrush}" Margin="16,0"/>

            <!-- App list label -->

            <!-- Sidebar content -->
            <Grid Grid.Row="2" Margin="8,8,8,0">

                <!-- App list (main mode) -->
                <Grid Visibility="{Binding IsNotShowingOptions, Converter={StaticResource BoolToVisibility}}">
                    <ListBox x:Name="AppListBox" ItemsSource="{Binding Apps}"
                             SelectedItem="{Binding SelectedApp}"
                             Background="Transparent" BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             PreviewMouseLeftButtonDown="AppListBox_PreviewMouseLeftButtonDown"
                             PreviewKeyDown="AppListBox_PreviewKeyDown"
                             ItemContainerStyle="{StaticResource AppSidebarItemStyle}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}" FontSize="13"
                                               Foreground="{DynamicResource TextBrush}" FontWeight="SemiBold"/>

                                    <!-- Version display — switches template based on DisplayMode -->
                                    <ContentControl Content="{Binding}" Focusable="False" Margin="0,2,0,0">
                                        <ContentControl.Style>
                                            <Style TargetType="ContentControl">

                                                <!-- Default: Published — show current version -->
                                                <Setter Property="ContentTemplate">
                                                    <Setter.Value>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding CurrentVersionText}" FontSize="11"
                                                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                        </DataTemplate>
                                                    </Setter.Value>
                                                </Setter>

                                                <Style.Triggers>

                                                    <!-- None: no versions yet -->
                                                    <DataTrigger Binding="{Binding DisplayMode}" Value="None">
                                                        <Setter Property="ContentTemplate">
                                                            <Setter.Value>
                                                                <DataTemplate>
                                                                    <TextBlock Text="No versions" FontSize="11"
                                                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                                </DataTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </DataTrigger>

                                                    <!-- InProgress: 0.1.1 → 0.1.2 (with status color on next) -->
                                                    <DataTrigger Binding="{Binding DisplayMode}" Value="InProgress">
                                                        <Setter Property="ContentTemplate">
                                                            <Setter.Value>
                                                                <DataTemplate>
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <TextBlock Text="{Binding CurrentVersionText}" FontSize="11"
                                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                                   Visibility="{Binding HasCurrentVersion, Converter={StaticResource BoolToVisibility}}"/>
                                                                        <TextBlock Text=" → " FontSize="11"
                                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                                   Visibility="{Binding HasCurrentVersion, Converter={StaticResource BoolToVisibility}}"/>
                                                                        <TextBlock Text="{Binding NextVersionText}" FontSize="11">
                                                                            <TextBlock.Style>
                                                                                <Style TargetType="TextBlock">
                                                                                    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding NextVersionStatus}" Value="Signed">
                                                                                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                                                                        </DataTrigger>
                                                                                        <DataTrigger Binding="{Binding NextVersionStatus}" Value="Packed">
                                                                                            <Setter Property="Foreground" Value="{DynamicResource AddedBrush}"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </TextBlock.Style>
                                                                        </TextBlock>
                                                                    </StackPanel>
                                                                </DataTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </DataTrigger>

                                                    <!-- Retracted: ~~0.1.2~~ → 0.1.1 -->
                                                    <DataTrigger Binding="{Binding DisplayMode}" Value="Retracted">
                                                        <Setter Property="ContentTemplate">
                                                            <Setter.Value>
                                                                <DataTemplate>
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <TextBlock Text="{Binding RetractedVersionText}" FontSize="11"
                                                                                   Foreground="{DynamicResource RemovedBrush}"
                                                                                   TextDecorations="Strikethrough"/>
                                                                        <TextBlock Text=" → " FontSize="11"
                                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                                   Visibility="{Binding HasPreviousVersion, Converter={StaticResource BoolToVisibility}}"/>
                                                                        <TextBlock Text="{Binding PreviousVersionText}" FontSize="11"
                                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                                   Visibility="{Binding HasPreviousVersion, Converter={StaticResource BoolToVisibility}}"/>
                                                                    </StackPanel>
                                                                </DataTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </DataTrigger>

                                                </Style.Triggers>
                                            </Style>
                                        </ContentControl.Style>
                                    </ContentControl>

                                </StackPanel>
                            </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>

                <!-- Options sections (options mode) -->
                <Grid Visibility="{Binding IsShowingOptions, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel>
                        <TextBlock Text="Options" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextBrush}" Margin="4,0,0,8"/>
                        <Rectangle Height="1" Fill="{DynamicResource BorderBrush}"/>

                        <ListBox Margin="0,8,0,0"
                                 ItemsSource="{Binding CurrentView.Categories}"
                                 SelectedItem="{Binding CurrentView.SelectedCategory, Mode=TwoWay}"
                                 Background="Transparent" BorderThickness="0"
                                 ItemContainerStyle="{StaticResource SidebarItemStyle}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" FontSize="12"
                                               Foreground="{DynamicResource TextBrush}"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Grid>

                <!-- Setups sections (setups mode) -->
                <Grid Visibility="{Binding IsShowingSetups, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel>
                        <TextBlock Text="Setups" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextBrush}" Margin="4,0,0,8"/>
                        <Rectangle Height="1" Fill="{DynamicResource BorderBrush}"/>

                        <ListBox Margin="0,8,0,0"
                                 ItemsSource="{Binding CurrentView.Categories}"
                                 SelectedItem="{Binding CurrentView.SelectedCategory, Mode=TwoWay}"
                                 Background="Transparent" BorderThickness="0"
                                 ItemContainerStyle="{StaticResource SidebarItemStyle}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" FontSize="12"
                                               Foreground="{DynamicResource TextBrush}"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Grid>

            </Grid>

            <!-- Bottom actions -->
            <StackPanel Grid.Row="3">
                <Rectangle Height="1" Fill="{DynamicResource BorderBrush}" Margin="16,0"/>
                <StackPanel Visibility="{Binding ShowBottomButtons, Converter={StaticResource BoolToVisibility}}">
                    <Button Content="{Binding SetupsButtonText}" Style="{StaticResource SecondaryButton}"
                            Margin="12,8,12,4" Padding="0,10"
                            Visibility="{Binding Session.CanManageSetups, Converter={StaticResource BoolToVisibility}}"
                            Click="Setups_Click"/>
                    <Button Content="Options" Style="{StaticResource SecondaryButton}"
                            Margin="12,4,12,4" Padding="0,10"
                            Click="Options_Click"/>
                    <Button Content="+ Add Application" Style="{StaticResource PrimaryButton}"
                            Margin="12,4,12,16" Padding="0,10"
                            Visibility="{Binding Session.CanScan, Converter={StaticResource BoolToVisibility}}"
                            Click="AddApp_Click"/>
                </StackPanel>

                <!-- Signed-in user + sign out (only when access protection is on) -->
                <Border Visibility="{Binding IsProtected, Converter={StaticResource BoolToVisibility}}"
                        Margin="12,0,12,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding CurrentUserName}" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextBrush}" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding Session.Current.Role}" FontSize="10"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="Sign out" Style="{StaticResource SecondaryButton}"
                                Padding="10,6" FontSize="11" Click="SignOut_Click"/>
                    </Grid>
                </Border>
            </StackPanel>
        </Grid>

        <!-- ── Sidebar / Content divider ────────────────────────── -->
        <Rectangle Grid.Column="1" Fill="{DynamicResource BorderBrush}"/>

        <!-- ── Content area (driven by DataTemplates) ───────────── -->
        <ContentControl Grid.Column="2" Content="{Binding CurrentView, NotifyOnTargetUpdated=True}">
            <!-- Subtle fade whenever the active view changes. -->
            <ContentControl.Triggers>
                <EventTrigger RoutedEvent="Binding.TargetUpdated">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                             From="0" To="1" Duration="0:0:0.18"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </ContentControl.Triggers>
        </ContentControl>
    </Grid>
</Window>
