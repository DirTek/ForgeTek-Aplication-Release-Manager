<UserControl x:Class="ForgeTekUpdatePackager.Views.ScanView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ForgeTekUpdatePackager.Converters"
             Background="{StaticResource BackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="28,24,28,16"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel>
                <TextBlock FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextBrush}">
                    <Run Text="Initial Scan — "/>
                    <Run Text="{Binding AppName, Mode=OneWay}"/>
                </TextBlock>
                <TextBlock Text="{Binding AppPath}" FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                <TextBlock FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,6,0,0">
                    <Run Text="{Binding FileCount, Mode=OneWay}"/>
                    <Run Text=" files found — check boxes below to mark debug/dev-only files"/>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Column headers -->
        <Grid Grid.Row="1" Margin="28,12,28,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="28"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="160"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="DBG" FontSize="11" FontWeight="SemiBold"
                       Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="1" Text="FILE PATH" FontSize="11" FontWeight="SemiBold"
                       Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="2" Text="DATE MODIFIED" FontSize="11" FontWeight="SemiBold"
                       Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
        </Grid>

        <!-- File list -->
        <ScrollViewer Grid.Row="2" Margin="28,0,28,0"
                      VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding Files}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border CornerRadius="5" Margin="0,1"
                                Background="{Binding IsDebug, Converter={x:Static conv:DebugRowBackgroundConverter.Instance}}">
                            <Grid Margin="0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="160"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0" IsChecked="{Binding IsDebug}"
                                          VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding Path}"
                                           FontSize="13" Foreground="{StaticResource TextBrush}"
                                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Grid.Column="2" Text="{Binding DateModified}"
                                           FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Footer: approve bar -->
        <Border Grid.Row="3" Background="{StaticResource SidebarBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="28,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Version:" VerticalAlignment="Center"
                           FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,10,0"/>
                <TextBox Grid.Column="1" Text="{Binding VersionNumber, UpdateSourceTrigger=PropertyChanged}"
                         Height="36" FontSize="14"/>
                <StackPanel Grid.Column="3" Orientation="Horizontal">
                    <Button Content="Approve &amp; Save" Style="{StaticResource PrimaryButton}"
                            Padding="18,8" Margin="0,0,8,0"
                            Command="{Binding ApproveCommand}"/>
                    <Button Content="Cancel" Style="{StaticResource SecondaryButton}"
                            Padding="14,8" Command="{Binding CancelCommand}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
