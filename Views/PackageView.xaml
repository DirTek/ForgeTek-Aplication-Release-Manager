<UserControl x:Class="ForgeTekApplicationReleaseManager.Views.PackageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">
    <!-- Pipeline stepper styles (StepCircle/StepGlyph/StepLabel/StepConnector)
         are shared and defined in App.xaml. -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Header -->
        <Border Grid.Row="0" Padding="28,24,28,16"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel>
                <TextBlock FontSize="22" FontWeight="Bold" Foreground="{DynamicResource TextBrush}">
                    <Run Text="{DynamicResource Str.Package.HeaderPrefix}"/><Run Text="{Binding AppName, Mode=OneWay}"/>
                </TextBlock>
                <TextBlock Text="{Binding VersionLabel}" FontSize="12"
                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Row 1: Pipeline stepper -->
        <Border Grid.Row="1" Padding="28,16,28,16"
                Background="{DynamicResource SidebarBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid HorizontalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/><ColumnDefinition Width="48"/>
                    <ColumnDefinition Width="Auto"/><ColumnDefinition Width="48"/>
                    <ColumnDefinition Width="Auto"/><ColumnDefinition Width="48"/>
                    <ColumnDefinition Width="Auto"/><ColumnDefinition Width="48"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Circles + connectors -->
                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource StepCircle}" Tag="{Binding SignState}">
                    <TextBlock Text="1" Style="{StaticResource StepGlyph}" Tag="{Binding SignState}"/>
                </Border>
                <Rectangle Grid.Row="0" Grid.Column="1" Style="{StaticResource StepConnector}" Tag="{Binding SignState}"/>
                <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource StepCircle}" Tag="{Binding ManifestState}">
                    <TextBlock Text="2" Style="{StaticResource StepGlyph}" Tag="{Binding ManifestState}"/>
                </Border>
                <Rectangle Grid.Row="0" Grid.Column="3" Style="{StaticResource StepConnector}" Tag="{Binding ManifestState}"/>
                <Border Grid.Row="0" Grid.Column="4" Style="{StaticResource StepCircle}" Tag="{Binding PackageState}">
                    <TextBlock Text="3" Style="{StaticResource StepGlyph}" Tag="{Binding PackageState}"/>
                </Border>
                <Rectangle Grid.Row="0" Grid.Column="5" Style="{StaticResource StepConnector}" Tag="{Binding PackageState}"/>
                <Border Grid.Row="0" Grid.Column="6" Style="{StaticResource StepCircle}" Tag="{Binding JsonState}">
                    <TextBlock Text="4" Style="{StaticResource StepGlyph}" Tag="{Binding JsonState}"/>
                </Border>
                <Rectangle Grid.Row="0" Grid.Column="7" Style="{StaticResource StepConnector}" Tag="{Binding JsonState}"/>
                <Border Grid.Row="0" Grid.Column="8" Style="{StaticResource StepCircle}" Tag="{Binding FtpState}">
                    <TextBlock Text="5" Style="{StaticResource StepGlyph}" Tag="{Binding FtpState}"/>
                </Border>

                <!-- Labels -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource Str.Package.StepSign}"     Style="{StaticResource StepLabel}" Tag="{Binding SignState}"/>
                <TextBlock Grid.Row="1" Grid.Column="2" Text="{DynamicResource Str.Package.StepManifest}" Style="{StaticResource StepLabel}" Tag="{Binding ManifestState}"/>
                <TextBlock Grid.Row="1" Grid.Column="4" Text="{DynamicResource Str.Package.StepPackage}"  Style="{StaticResource StepLabel}" Tag="{Binding PackageState}"/>
                <TextBlock Grid.Row="1" Grid.Column="6" Text="{DynamicResource Str.Package.StepCatalog}"  Style="{StaticResource StepLabel}" Tag="{Binding JsonState}"/>
                <TextBlock Grid.Row="1" Grid.Column="8" Text="{DynamicResource Str.Package.StepUpload}"   Style="{StaticResource StepLabel}" Tag="{Binding FtpState}"/>
            </Grid>
        </Border>

        <!-- Row 2: Step content -->
        <Grid Grid.Row="2">

            <!-- Sign step content -->
            <StackPanel Margin="28,20,28,0"
                        Visibility="{Binding IsSignCurrent, Converter={StaticResource BoolToVisibility}}">

                <!-- Global cert active banner -->
                <Border CornerRadius="6" Padding="12,10" Margin="0,0,0,12"
                        Background="{DynamicResource AccentSoftBrush}" BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1"
                        Visibility="{Binding IsGlobalCertActive, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Str.Package.GlobalCertActive}" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextBrush}"/>
                        <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,3,0,0">
                            <Run Text="{DynamicResource Str.Package.UsingPrefix}"/>
                            <Run Text="{Binding GlobalCertFileName, Mode=OneWay}"
                                 Foreground="{DynamicResource TextBrush}" FontWeight="SemiBold"/>
                            <Run Text="{DynamicResource Str.Package.UsingSuffix}"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Cert fields — always visible, disabled when global cert overrides -->
                <TextBlock Text="{DynamicResource Str.Package.Certificate}" FontSize="10" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                <Grid Margin="0,0,0,16" IsEnabled="{Binding IsGlobalCertInactive}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Text="{Binding PfxPath, UpdateSourceTrigger=PropertyChanged}"
                             Height="36" Margin="0,0,8,0"
                             Visibility="{Binding UseStoreCert, Converter={StaticResource InvertVisibility}}"/>
                    <TextBox Grid.Column="0"
                             Text="{Binding StoreThumbprint, Mode=OneWay}"
                             Height="36" Margin="0,0,8,0" IsReadOnly="True"
                             Visibility="{Binding UseStoreCert, Converter={StaticResource BoolToVisibility}}"/>
                    <Button Grid.Column="1" Content="{DynamicResource Str.Common.Browse}" Style="{StaticResource SecondaryButton}"
                            Padding="14,8" Margin="0,0,8,0"
                            Command="{Binding BrowsePfxCommand}"/>
                    <Button Grid.Column="2" Content="{DynamicResource Str.Package.FromStore}" Style="{StaticResource SecondaryButton}"
                            Padding="14,8"
                            Command="{Binding BrowseStoreCertCommand}"/>
                </Grid>

                <TextBlock Text="{DynamicResource Str.Package.Password}" FontSize="10" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                <PasswordBox x:Name="PfxPasswordBox" Height="36" Margin="0,0,0,16"
                             IsEnabled="{Binding IsGlobalCertInactive}"
                             PasswordChanged="PfxPasswordBox_PasswordChanged"/>

                <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="6">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="14,10,14,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{DynamicResource Str.Package.FilesToSign}" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="{Binding FilesLabel}" FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="  ·  " Foreground="{DynamicResource BorderBrush}"
                                           FontSize="11" VerticalAlignment="Center"/>
                                <Button Content="{DynamicResource Str.Filter.All}" Style="{StaticResource SecondaryButton}"
                                        Padding="8,3" FontSize="11" Margin="0,0,4,0"
                                        Command="{Binding SelectAllCommand}"/>
                                <Button Content="{DynamicResource Str.Common.None}" Style="{StaticResource SecondaryButton}"
                                        Padding="8,3" FontSize="11"
                                        Command="{Binding DeselectAllCommand}"/>
                            </StackPanel>
                        </Grid>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                      MaxHeight="180" Margin="0,0,0,10">
                            <ItemsControl ItemsSource="{Binding SignableFiles}" Margin="8,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="6,3">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="26"/>
                                                <ColumnDefinition Width="20"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}"
                                                      VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding BadgeText}"
                                                       FontSize="13" FontWeight="Bold" VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource AddedBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding BadgeText}" Value="~">
                                                                <Setter Property="Foreground" Value="{DynamicResource ModifiedBrush}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding BadgeText}" Value="">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Grid.Column="2" Text="{Binding RelativePath}"
                                                       FontSize="12" VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSelected}" Value="False">
                                                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                                                <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </StackPanel>

            <!-- Manifest step content -->
            <StackPanel Margin="28,20,28,0"
                        Visibility="{Binding IsManifestCurrent, Converter={StaticResource BoolToVisibility}}">
                <TextBlock Text="{DynamicResource Str.Package.OutputPath}" FontSize="10" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Text="{Binding ManifestOutputPath, UpdateSourceTrigger=PropertyChanged}"
                             Height="36" Margin="0,0,8,0"/>
                    <Button Grid.Column="1" Content="{DynamicResource Str.Common.Browse}" Style="{StaticResource SecondaryButton}"
                            Padding="14,8" Command="{Binding BrowseManifestOutputCommand}"/>
                </Grid>
            </StackPanel>

            <!-- Package step content -->
            <StackPanel Margin="28,20,28,0"
                        Visibility="{Binding IsPackageCurrent, Converter={StaticResource BoolToVisibility}}">
                <TextBlock Text="{DynamicResource Str.Package.PackageType}" FontSize="10" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,10"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <Border CornerRadius="6" Padding="14,8" Margin="0,0,8,0" Cursor="Hand">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                <Setter Property="BorderThickness" Value="2"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsIncrementalSelected}" Value="True">
                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsIncrementalAvailable}" Value="False">
                                        <Setter Property="Opacity" Value="0.4"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <RadioButton IsChecked="{Binding IsIncrementalSelected}"
                                         IsEnabled="{Binding IsIncrementalAvailable}"
                                         VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Str.Package.Incremental}" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}"/>
                                <TextBlock Text="{DynamicResource Str.Package.IncrementalDesc}" FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <Border CornerRadius="6" Padding="14,8" Cursor="Hand">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                <Setter Property="BorderThickness" Value="2"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsFullSelected}" Value="True">
                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <RadioButton IsChecked="{Binding IsFullSelected}"
                                         VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Str.Package.Full}" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}"/>
                                <TextBlock Text="{DynamicResource Str.Package.FullDesc}" FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <TextBlock Text="{Binding PackageFilesLabel}" FontSize="11"
                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,18"/>

                <Border CornerRadius="6" Padding="12,10" Margin="0,0,0,16"
                        Background="{DynamicResource SurfaceBrush}">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasManifest}" Value="False">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap">
                        <Run Text="{DynamicResource Str.Package.NoManifestWarn}"/>
                        <Run Text="{DynamicResource Str.Package.NoManifestHint}"/>
                    </TextBlock>
                </Border>

                <TextBlock Text="{DynamicResource Str.Package.OutputPath}" FontSize="10" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Text="{Binding PackageOutputPath, UpdateSourceTrigger=PropertyChanged}"
                             Height="36" Margin="0,0,8,0"/>
                    <Button Grid.Column="1" Content="{DynamicResource Str.Common.Browse}" Style="{StaticResource SecondaryButton}"
                            Padding="14,8" Command="{Binding BrowsePackageOutputCommand}"/>
                </Grid>
            </StackPanel>

            <!-- JSON step content -->
            <StackPanel Margin="28,20,28,0"
                        Visibility="{Binding IsJsonCurrent, Converter={StaticResource BoolToVisibility}}">

                <TextBlock Text="{DynamicResource Str.Package.UpdateCatalog}" FontSize="10" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>

                <TextBlock FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                           TextWrapping="Wrap" Margin="0,0,0,16">
                    <Run Text="{DynamicResource Str.Package.CatalogDescPre}"/><Run Text="{Binding AppName, Mode=OneWay}" Foreground="{DynamicResource TextBrush}"/><Run Text="{DynamicResource Str.Package.CatalogDescPost}"/>
                </TextBlock>

                <!-- Info grid -->
                <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="6" Padding="14,12" Margin="0,0,0,0">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{DynamicResource Str.Package.LocalCatalog}" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Top"/>
                            <TextBlock Grid.Column="1" Text="{Binding CatalogLocalPath}" FontSize="11"
                                       Foreground="{DynamicResource TextBrush}" TextWrapping="Wrap"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{DynamicResource Str.Package.FtpCatalogPath}" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Top"/>
                            <TextBlock Grid.Column="1" Text="{Binding CatalogRemotePath}" FontSize="11"
                                       Foreground="{DynamicResource TextBrush}" TextWrapping="Wrap"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{DynamicResource Str.Package.PackageUrl}" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Top"/>
                            <TextBlock Grid.Column="1" Text="{Binding PackageDownloadUrl}" FontSize="11"
                                       Foreground="{DynamicResource TextBrush}" TextWrapping="Wrap"/>
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>

            <!-- FTP step content -->
            <StackPanel Margin="28,20,28,0"
                        Visibility="{Binding IsFtpCurrent, Converter={StaticResource BoolToVisibility}}">

                <TextBlock Text="{DynamicResource Str.Package.UploadToFtp}" FontSize="10" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>

                <!-- No FTP warning -->
                <Border CornerRadius="6" Padding="12,10" Margin="0,0,0,12"
                        Background="{DynamicResource SurfaceBrush}">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasFtpSettings}" Value="False">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap">
                        <Run Text="{DynamicResource Str.Package.NoFtpWarn}"/>
                        <Run Text="{DynamicResource Str.Package.NoFtpHint}"/>
                        <LineBreak/>
                        <Run Text="{DynamicResource Str.Package.NoFtpSkipHint}"/>
                    </TextBlock>
                </Border>

                <!-- FTP summary -->
                <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="6" Padding="14,12">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{DynamicResource Str.Package.Server}" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Top"/>
                            <TextBlock Grid.Column="1" Text="{Binding FtpSummary}" FontSize="11"
                                       Foreground="{DynamicResource TextBrush}" TextWrapping="Wrap"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{DynamicResource Str.Package.PackageToFtp}" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Top"/>
                            <TextBlock Grid.Column="1" Text="{Binding PackageRemotePath}" FontSize="11"
                                       Foreground="{DynamicResource TextBrush}" TextWrapping="Wrap"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{DynamicResource Str.Package.CatalogToFtp}" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Top"/>
                            <TextBlock Grid.Column="1" Text="{Binding CatalogRemotePath}" FontSize="11"
                                       Foreground="{DynamicResource TextBrush}" TextWrapping="Wrap"/>
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>

        </Grid>

        <!-- Row 3: Log area -->
        <Border Grid.Row="3" Margin="28,16,28,0" Background="{DynamicResource SurfaceBrush}"
                CornerRadius="6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="{DynamicResource Str.Package.Output}" FontSize="10" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="14,10,14,6"/>
                <ScrollViewer x:Name="LogScrollViewer" Grid.Row="1"
                              VerticalScrollBarVisibility="Auto" Margin="0,0,0,10">
                    <ItemsControl ItemsSource="{Binding Log}" Margin="14,0,14,4">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" FontSize="12" FontFamily="Consolas"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,1" TextWrapping="Wrap"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Row 4: Footer -->
        <Border Grid.Row="4" Background="{DynamicResource SidebarBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="28,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Progress labels -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="{DynamicResource Str.Package.ProgSigning}" FontSize="13"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Visibility="{Binding IsSigning, Converter={StaticResource BoolToVisibility}}"/>
                    <TextBlock Text="{DynamicResource Str.Package.ProgManifest}" FontSize="13"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Visibility="{Binding IsGenerating, Converter={StaticResource BoolToVisibility}}"/>
                    <TextBlock Text="{DynamicResource Str.Package.ProgPackaging}" FontSize="13"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Visibility="{Binding IsPackaging, Converter={StaticResource BoolToVisibility}}"/>
                    <TextBlock Text="{DynamicResource Str.Package.ProgJson}" FontSize="13"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Visibility="{Binding IsGeneratingJson, Converter={StaticResource BoolToVisibility}}"/>
                    <TextBlock Text="{DynamicResource Str.Package.ProgUploading}" FontSize="13"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Visibility="{Binding IsUploading, Converter={StaticResource BoolToVisibility}}"/>
                </StackPanel>

                <!-- Action buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">

                    <!-- Sign Files -->
                    <Button Content="{DynamicResource Str.Package.SignFiles}" Style="{StaticResource PrimaryButton}"
                            Padding="18,8" Margin="0,0,8,0"
                            Command="{Binding SignCommand}"
                            Visibility="{Binding IsSignStepIdle, Converter={StaticResource BoolToVisibility}}"/>

                    <!-- Generate Manifest -->
                    <Button Content="{DynamicResource Str.Package.GenerateManifest}" Style="{StaticResource PrimaryButton}"
                            Padding="18,8" Margin="0,0,8,0"
                            Command="{Binding GenerateManifestCommand}"
                            Visibility="{Binding IsManifestStepIdle, Converter={StaticResource BoolToVisibility}}"/>

                    <!-- Build Package -->
                    <Button Content="{DynamicResource Str.Package.BuildPackage}" Style="{StaticResource PrimaryButton}"
                            Padding="18,8" Margin="0,0,8,0"
                            Command="{Binding BuildPackageCommand}"
                            Visibility="{Binding IsPackageStepIdle, Converter={StaticResource BoolToVisibility}}"/>

                    <!-- Generate JSON -->
                    <Button Content="{DynamicResource Str.Package.GenerateJson}" Style="{StaticResource PrimaryButton}"
                            Padding="18,8" Margin="0,0,8,0"
                            Command="{Binding GenerateUpdateJsonCommand}"
                            Visibility="{Binding IsJsonStepIdle, Converter={StaticResource BoolToVisibility}}"/>

                    <!-- Upload to FTP -->
                    <Button Content="{DynamicResource Str.Package.UploadFtpButton}" Style="{StaticResource PrimaryButton}"
                            Padding="18,8" Margin="0,0,8,0"
                            Command="{Binding UploadToFtpCommand}"
                            Visibility="{Binding IsFtpStepIdle, Converter={StaticResource BoolToVisibility}}"/>

                    <!-- Next → / Finish ✔ -->
                    <Button Content="{Binding AdvanceLabel}" Style="{StaticResource PrimaryButton}"
                            Padding="18,8" Margin="0,0,8,0"
                            Command="{Binding AdvanceCommand}"
                            Visibility="{Binding IsReadyToAdvance, Converter={StaticResource BoolToVisibility}}"/>

                    <!-- Stop -->
                    <Button Content="{DynamicResource Str.Package.Stop}" Style="{StaticResource SecondaryButton}"
                            Padding="14,8" Margin="0,0,8,0"
                            Command="{Binding StopOperationCommand}"
                            Visibility="{Binding IsOperationInProgress, Converter={StaticResource BoolToVisibility}}"/>

                    <!-- Skip → (Sign or FTP) -->
                    <Button Content="{DynamicResource Str.Package.Skip}" Style="{StaticResource SecondaryButton}"
                            Padding="14,8" Margin="0,0,8,0"
                            Command="{Binding SkipCommand}"
                            Visibility="{Binding IsSkipVisible, Converter={StaticResource BoolToVisibility}}"/>

                    <!-- Cancel -->
                    <Button Content="{DynamicResource Str.Common.Cancel}" Style="{StaticResource DangerButton}"
                            Padding="14,8"
                            Command="{Binding CancelPipelineCommand}"/>

                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</UserControl>
