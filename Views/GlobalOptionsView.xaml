<UserControl x:Class="ForgeTekUpdatePackager.Views.GlobalOptionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="28,24,28,16"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel>
                <TextBlock Text="Options" FontSize="22" FontWeight="Bold"
                           Foreground="{DynamicResource TextBrush}"/>
                <TextBlock Text="Global configuration" FontSize="12"
                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Body — category panels switched by the sidebar selection -->
        <Grid Grid.Row="1" Margin="28,16,28,0">

            <!-- ══ GENERAL ════════════════════════════════════════════════ -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,16,12,0"
                          Visibility="{Binding SelectedCategory, Converter={StaticResource StringMatchToVisibility}, ConverterParameter='General'}">
                <StackPanel>

                        <!-- ══ COMPANY NAME ═══════════════════════════════════════ -->
                        <TextBlock Text="COMPANY NAME" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>

                        <TextBlock FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,0,0,8" TextWrapping="Wrap">
                            Used as the publisher name in Add/Remove Programs and as the parent folder under Program Files.
                        </TextBlock>

                        <TextBox Text="{Binding CompanyName, UpdateSourceTrigger=PropertyChanged}"
                                 Height="36" Margin="0,0,0,28"
                                 ToolTip="e.g. Contoso Inc."/>

                        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Margin="0,0,0,28"/>

                        <!-- ══ APPEARANCE ═════════════════════════════════════════ -->
                        <TextBlock Text="APPEARANCE" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>

                        <TextBlock FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,0,0,12" TextWrapping="Wrap">
                            Theme used across the app. “System” follows your Windows light/dark setting and updates automatically.
                        </TextBlock>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,28">
                            <TextBlock Text="Theme:" FontSize="13" Width="60"
                                       Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                            <ComboBox Width="180" Height="34"
                                      ItemsSource="{Binding ThemeOptions}"
                                      SelectedItem="{Binding SelectedTheme, Mode=TwoWay}"/>
                        </StackPanel>

                </StackPanel>
            </ScrollViewer>

            <!-- ══ GITHUB ═════════════════════════════════════════════════ -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,16,12,0"
                          Visibility="{Binding SelectedCategory, Converter={StaticResource StringMatchToVisibility}, ConverterParameter='GitHub'}">
                <StackPanel>
                    <TextBlock Text="GITHUB ACCOUNT" FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                    <TextBlock FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                               TextWrapping="Wrap" Margin="0,0,0,14">
                        Connect once with your GitHub account; every app then uses this connection to check for
                        newer releases (per app you only set the repository). Sign-in uses the browser-based
                        device flow — no password or token is typed here.
                    </TextBlock>

                    <!-- Connected state -->
                    <Border Background="{DynamicResource SuccessSoftBrush}" CornerRadius="6" Padding="12,10" Margin="0,0,0,14"
                            Visibility="{Binding IsGitHubConnected, Converter={StaticResource BoolToVisibility}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Connected" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource AddedBrush}"/>
                                <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0">
                                    <Run Text="Signed in as @"/><Run Text="{Binding GitHubLogin, Mode=OneWay}"/>
                                </TextBlock>
                            </StackPanel>
                            <Button Grid.Column="1" Content="Disconnect" Style="{StaticResource SecondaryButton}"
                                    Padding="14,7" Command="{Binding DisconnectGitHubCommand}"/>
                        </Grid>
                    </Border>

                    <TextBlock Text="OAUTH APP CLIENT ID" FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                    <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                               TextWrapping="Wrap" Margin="0,0,0,6">
                        Register a GitHub OAuth App (github.com/settings/developers) with “Enable Device Flow” on,
                        then paste its Client ID here. The Client ID is public — no client secret is needed or stored.
                    </TextBlock>
                    <TextBox Text="{Binding GitHubClientId, UpdateSourceTrigger=PropertyChanged}"
                             Height="36" Margin="0,0,0,12" ToolTip="e.g. Iv1.abcdef0123456789"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                        <Button Content="Connect GitHub" Style="{StaticResource PrimaryButton}"
                                Padding="18,9" Command="{Binding ConnectGitHubCommand}"/>
                    </StackPanel>

                    <!-- PAT alternative -->
                    <TextBlock Text="OR USE A PERSONAL ACCESS TOKEN" FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                    <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                               TextWrapping="Wrap" Margin="0,0,0,6">
                        Prefer not to register an OAuth App? Generate a token at
                        github.com/settings/tokens (scope “repo”) and paste it here — it's stored encrypted (DPAPI)
                        and used account-wide, just like the Connect option.
                    </TextBlock>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <PasswordBox Grid.Column="0" x:Name="GitHubPatBox" Height="36"
                                     PasswordChanged="GitHubPatBox_PasswordChanged"/>
                        <Button Grid.Column="2" Content="Use token" Style="{StaticResource SecondaryButton}"
                                Padding="16,8" Command="{Binding UseGitHubTokenCommand}"/>
                    </Grid>

                    <TextBlock Text="{Binding GitHubMessage}" FontSize="11" TextWrapping="Wrap"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,28"/>
                </StackPanel>
            </ScrollViewer>

            <!-- ══ SIGNING ════════════════════════════════════════════════ -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,16,12,0"
                          Visibility="{Binding SelectedCategory, Converter={StaticResource StringMatchToVisibility}, ConverterParameter='Signing'}">
                <StackPanel>

                        <!-- ══ GLOBAL SIGNING CERTIFICATE ══════════════════════════ -->
                        <TextBlock Text="GLOBAL SIGNING CERTIFICATE" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>

                        <TextBlock FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,0,0,16" TextWrapping="Wrap">
                            Set a single certificate used across all apps. When enabled, this overrides
                            any per-app certificate configured in App Settings.
                        </TextBlock>

                        <!-- Source toggle -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <RadioButton Content="PFX File" GroupName="CertSource"
                                         IsChecked="{Binding UseStoreCert, Converter={StaticResource InvertBool}}"
                                         FontSize="13" Foreground="{DynamicResource TextBrush}" Margin="0,0,24,0"/>
                            <RadioButton Content="Windows Store" GroupName="CertSource"
                                         IsChecked="{Binding UseStoreCert}"
                                         FontSize="13" Foreground="{DynamicResource TextBrush}"/>
                        </StackPanel>

                        <!-- PFX source -->
                        <StackPanel Visibility="{Binding UseStoreCert, Converter={StaticResource InvertVisibility}}">
                            <TextBlock Text="CERTIFICATE" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                            <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,0,0,8" TextWrapping="Wrap">
                                <Run Text="Lists all .pfx files found in "/>
                                <Run Text="{Binding CertificateFolderPath, Mode=OneWay}"
                                     Foreground="{DynamicResource TextBrush}"/>
                                <Run Text="."/>
                            </TextBlock>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox Grid.Column="0" Height="36" Margin="0,0,8,0"
                                          ItemsSource="{Binding AvailableCerts}"
                                          SelectedItem="{Binding SelectedCertFileName, Mode=TwoWay}"/>
                                <Button Grid.Column="1" Content="Browse…" Style="{StaticResource SecondaryButton}"
                                        Padding="14,8" Margin="0,0,8,0" ToolTip="Copy a certificate into the Certificates folder"
                                        Command="{Binding BrowseAndCopyCertCommand}"/>
                                <Button Grid.Column="2" Content="Clear" Style="{StaticResource SecondaryButton}"
                                        Padding="10,8"
                                        Command="{Binding ClearGlobalCertCommand}"/>
                            </Grid>

                            <Border CornerRadius="6" Padding="10,7" Margin="0,0,0,14"
                                    Background="{DynamicResource SuccessSoftBrush}" BorderBrush="{DynamicResource AddedBrush}" BorderThickness="1"
                                    Visibility="{Binding HasGlobalCert, Converter={StaticResource BoolToVisibility}}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="✔  " Foreground="{DynamicResource AddedBrush}" FontWeight="SemiBold" FontSize="12"/>
                                    <TextBlock Text="{Binding GlobalCertFileName}"
                                               Foreground="{DynamicResource AddedBrush}" FontWeight="SemiBold" FontSize="12"/>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="CERTIFICATE PASSWORD" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                            <PasswordBox x:Name="CertPasswordBox" Height="36" Margin="0,0,0,14"
                                         PasswordChanged="CertPasswordBox_PasswordChanged"/>
                        </StackPanel>

                        <!-- Windows Store source -->
                        <StackPanel Visibility="{Binding UseStoreCert, Converter={StaticResource BoolToVisibility}}">
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ListBox Grid.Column="0" Height="120" Margin="0,0,8,0"
                                         ItemsSource="{Binding StoreCertificates}"
                                         SelectedValue="{Binding SelectedStoreThumbprint, Mode=TwoWay}"
                                         SelectedValuePath="Thumbprint"
                                         Background="{DynamicResource SurfaceBrush}" BorderThickness="0">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Subject}" FontSize="12"
                                                           Foreground="{DynamicResource TextBrush}"/>
                                                <TextBlock Text="{Binding DisplayName}" FontSize="11"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <Button Grid.Column="1" Content="Refresh" Style="{StaticResource SecondaryButton}"
                                        Padding="14,8" VerticalAlignment="Top"
                                        Command="{Binding RefreshStoreCertListCommand}"/>
                            </Grid>
                        </StackPanel>

                        <!-- Use globally toggle -->
                        <CheckBox IsChecked="{Binding UseGlobalCert}" Margin="0,0,0,6" FontSize="13">
                            Use this certificate for all apps
                        </CheckBox>
                        <TextBlock Text="{Binding UseGlobalCertHint}" FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,0,0,28" TextWrapping="Wrap"/>

                        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Margin="0,0,0,28"/>

                        <!-- ══ GENERATE NEW CERTIFICATE ════════════════════════════ -->
                        <TextBlock Text="GENERATE NEW CERTIFICATE" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>

                        <TextBlock FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,0,0,12" TextWrapping="Wrap">
                            <Run Text="Creates a self-signed code-signing certificate and saves it to "/>
                            <Run Text="{Binding CertificateFolderPath, Mode=OneWay}"
                                 Foreground="{DynamicResource TextBrush}"/>
                            <Run Text="."/>
                        </TextBlock>

                        <CheckBox IsChecked="{Binding KeepInCertStore}" Margin="0,0,0,16" FontSize="13">
                            Keep in Windows Certificate Store after export
                        </CheckBox>

                        <!-- Subject + Friendly Name side by side -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="SUBJECT (CN)" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                                <TextBox Text="{Binding SubjectName, UpdateSourceTrigger=PropertyChanged}"
                                         Height="36"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="FRIENDLY NAME" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                                <TextBox Text="{Binding FriendlyName, UpdateSourceTrigger=PropertyChanged}"
                                         Height="36"/>
                            </StackPanel>
                        </Grid>

                        <!-- Password for the certificate to be generated -->
                        <TextBlock Text="CERTIFICATE PASSWORD" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                        <PasswordBox x:Name="GeneratePasswordBox" Height="36" Margin="0,0,0,4"
                                     PasswordChanged="GeneratePasswordBox_PasswordChanged"/>
                        <TextBlock Text="This password will protect the generated PFX file and will be saved as the global certificate password."
                                   FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,0,0,12" TextWrapping="Wrap"/>

                        <!-- Generate button + spinner -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Button Content="Generate Certificate" Style="{StaticResource PrimaryButton}"
                                    Padding="16,10" Margin="0,0,12,0"
                                    Command="{Binding GenerateCertCommand}"/>
                            <TextBlock Text="Generating…" FontSize="13"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsGenerating}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>

                        <!-- Generation log (shown once generation has produced output) -->
                        <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="6"
                                Padding="12,10" Margin="0,0,0,28"
                                Visibility="{Binding HasGenerateLog, Converter={StaticResource BoolToVisibility}}">
                            <ItemsControl ItemsSource="{Binding GenerateLog}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="12"
                                                   Foreground="{DynamicResource TextBrush}" TextWrapping="Wrap"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>

                        <!-- ══ SHARED CERTIFICATES (networked only) ════════════════ -->
                        <StackPanel Visibility="{Binding ShowSharedCertificates, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="SHARED CERTIFICATES" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                            <TextBlock FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"
                                       Margin="0,0,0,12"
                                       Text="Certificates generated here are stored in the shared database (the password is not). On each machine, Download the .pfx or Register it into your Windows store, then select it above to sign."/>

                            <ItemsControl ItemsSource="{Binding SharedCertificates}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}"
                                                BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,0,8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Subject}" FontSize="13" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource TextBrush}"/>
                                                    <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                                               TextWrapping="Wrap" Margin="0,2,0,0">
                                                        <Run Text="{Binding Thumbprint, Mode=OneWay}"/>
                                                        <Run Text=" · "/>
                                                        <Run Text="{Binding CreatedBy, Mode=OneWay}"/>
                                                    </TextBlock>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                    <Button Content="Download" Style="{StaticResource SecondaryButton}" Padding="14,7"
                                                            Command="{Binding DataContext.DownloadCertCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}"/>
                                                    <Button Content="Register" Style="{StaticResource PrimaryButton}" Padding="14,7" Margin="8,0,0,0"
                                                            Command="{Binding DataContext.RegisterCertCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Text="No shared certificates yet — generate one above."
                                       FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,28"
                                       Visibility="{Binding SharedCertificates.Count, Converter={StaticResource ZeroToVisible}}"/>
                        </StackPanel>

                </StackPanel>
            </ScrollViewer>

            <!-- ══ BACKUP & DATA ══════════════════════════════════════════ -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,16,12,0"
                          Visibility="{Binding SelectedCategory, Converter={StaticResource StringMatchToVisibility}, ConverterParameter='Backup &amp; Data'}">
                <StackPanel>

                        <!-- ══ BACKUP & MIGRATE ════════════════════════════════════ -->
                        <TextBlock Text="BACKUP &amp; MIGRATE" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>

                        <TextBlock FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,0,0,16" TextWrapping="Wrap">
                            Export all app data, certificates, and logs into a single ZIP archive.
                            Use this to migrate to a new machine or create a point-in-time backup.
                        </TextBlock>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <Button Content="Create Backup…" Style="{StaticResource SecondaryButton}"
                                    Padding="16,10" Command="{Binding CreateBackupCommand}"/>
                            <Button Content="Restore Backup…" Style="{StaticResource SecondaryButton}"
                                    Padding="16,10" Margin="12,0,0,0"
                                    Command="{Binding RestoreBackupCommand}"
                                    IsEnabled="{Binding IsRestoring, Converter={StaticResource InvertBool}}"/>
                            <TextBlock Text="Restoring…" FontSize="13" VerticalAlignment="Center" Margin="12,0,0,0"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Visibility="{Binding IsRestoring, Converter={StaticResource BoolToVisibility}}"/>
                        </StackPanel>

                        <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"
                                   Margin="0,0,0,28"
                                   Text="Restore overwrites current data with the backup's contents and restarts the app. Works across modes — a standalone (SQLite) backup can be restored into a networked SQL Server."/>

                </StackPanel>
            </ScrollViewer>

            <!-- ══ DATABASE / CONNECTION ══════════════════════════════════════ -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,16,12,0"
                          Visibility="{Binding SelectedCategory, Converter={StaticResource StringMatchToVisibility}, ConverterParameter='Database'}">
                <StackPanel>
                    <TextBlock Text="DATABASE" FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                    <TextBlock FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,4"
                               Text="Where app data is stored. Standalone keeps a local SQLite database — the default, works with no server. Networked points every operator at one shared SQL Server so they work against the same data at once."/>
                    <TextBlock Margin="0,0,0,16" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}">
                        <Run Text="Currently using: "/><Run Text="{Binding CurrentStorageMode, Mode=OneWay}" FontWeight="SemiBold"/>
                    </TextBlock>

                    <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            CornerRadius="8" Padding="14" Margin="0,0,0,16">
                        <StackPanel>
                            <RadioButton GroupName="StorageMode" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,4"
                                         Foreground="{DynamicResource TextBrush}"
                                         IsChecked="{Binding UseNetworkedDatabase, Converter={StaticResource InvertBool}}"
                                         Content="Standalone — local SQLite database"/>
                            <RadioButton GroupName="StorageMode" FontSize="13" FontWeight="SemiBold"
                                         Foreground="{DynamicResource TextBrush}"
                                         IsEnabled="{Binding CanUseNetworked}"
                                         IsChecked="{Binding UseNetworkedDatabase}"
                                         Content="Networked — shared SQL Server"/>
                            <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"
                                       Margin="22,2,0,0"
                                       Visibility="{Binding CanUseNetworked, Converter={StaticResource InvertVisibility}}"
                                       Text="Create at least one Admin user before switching to a shared server, so the shared store has an owner."/>

                            <StackPanel Margin="22,12,0,0"
                                        Visibility="{Binding IsNetworkedSelected, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="SQL Server connection string" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding SqlServerConnectionString, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="8,6" FontFamily="Consolas"
                                         ToolTip="e.g. Server=HOST;Database=ForgeTek;User Id=svc_forgetek;Password=…;TrustServerCertificate=True"/>
                                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                    <Button Content="Test connection" Style="{StaticResource SecondaryButton}" Padding="16,8"
                                            Command="{Binding TestConnectionCommand}" IsEnabled="{Binding IsTestingConnection, Converter={StaticResource InvertBool}}"/>
                                </StackPanel>
                                <TextBlock Text="{Binding ConnectionStatus}" Margin="0,8,0,0" FontSize="12" TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <TextBlock FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,12"
                               Text="On first connection to an empty SQL Server, your existing local data is imported automatically. Note: shared secret encryption isn't configured yet, so saved credentials (FTP/SFTP/S3/cert/GitHub) stay local and aren't copied to the shared database — re-enter them per machine for now. Changing mode restarts the app."/>

                    <Button Content="Save &amp; Restart…" Style="{StaticResource PrimaryButton}"
                            Padding="16,10" HorizontalAlignment="Left" Margin="0,0,0,28"
                            Command="{Binding SaveConnectionCommand}"/>
                </StackPanel>
            </ScrollViewer>

            <!-- ══ LOGS ═══════════════════════════════════════════════════════ -->
            <Grid Visibility="{Binding SelectedCategory, Converter={StaticResource StringMatchToVisibility}, ConverterParameter='Logs'}"
                  Margin="0,16,12,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="ACTIVITY LOG" FontSize="10" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>

                <StackPanel Grid.Row="1" Margin="0,0,0,12">
                    <!-- Period presets + custom date range -->
                    <WrapPanel Orientation="Horizontal">
                        <Button Content="Today" Style="{StaticResource SecondaryButton}"
                                Padding="14,7" Command="{Binding LogsTodayCommand}"/>
                        <Button Content="Last 7 days" Style="{StaticResource SecondaryButton}"
                                Padding="14,7" Margin="8,0,0,0" Command="{Binding LogsLast7Command}"/>
                        <Button Content="Last 30 days" Style="{StaticResource SecondaryButton}"
                                Padding="14,7" Margin="8,0,0,0" Command="{Binding LogsLast30Command}"/>

                        <TextBlock Text="From" VerticalAlignment="Center" Margin="20,0,6,0"
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                        <DatePicker SelectedDate="{Binding LogFrom}" VerticalAlignment="Center" Width="130"/>
                        <TextBlock Text="To" VerticalAlignment="Center" Margin="12,0,6,0"
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                        <DatePicker SelectedDate="{Binding LogTo}" VerticalAlignment="Center" Width="130"/>

                        <TextBlock Text="Category" VerticalAlignment="Center" Margin="20,0,6,0"
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                        <ComboBox ItemsSource="{Binding LogCategories}" SelectedItem="{Binding SelectedLogCategory}"
                                  VerticalAlignment="Center" Width="160"/>
                    </WrapPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <Button Content="Refresh" Style="{StaticResource SecondaryButton}"
                                Padding="16,8" Command="{Binding RefreshLogsCommand}"/>
                        <Button Content="Open log folder" Style="{StaticResource SecondaryButton}"
                                Padding="16,8" Margin="8,0,0,0" Command="{Binding OpenLogFolderCommand}"/>
                        <TextBlock VerticalAlignment="Center" Margin="14,0,0,0" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}">
                            <Run Text="{Binding LogEntries.Count, Mode=OneWay}"/><Run Text=" line(s)"/>
                        </TextBlock>
                    </StackPanel>
                </StackPanel>

                <Border Grid.Row="2" Background="{DynamicResource SurfaceBrush}" CornerRadius="6"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="2">
                    <ListBox ItemsSource="{Binding LogEntries}"
                             Background="Transparent" BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                             FontFamily="Consolas" FontSize="12">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" TextWrapping="NoWrap"
                                           Foreground="{DynamicResource TextBrush}"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>

                <TextBlock Grid.Row="2" Text="No log entries for the selected period." VerticalAlignment="Center" HorizontalAlignment="Center"
                           Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"
                           Visibility="{Binding HasLogEntries, Converter={StaticResource InvertVisibility}}"/>
            </Grid>

            <!-- ══ USERS ══════════════════════════════════════════════════════ -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,16,12,0"
                          Visibility="{Binding SelectedCategory, Converter={StaticResource StringMatchToVisibility}, ConverterParameter='Users'}">
                <StackPanel>
                    <TextBlock Text="USERS &amp; ACCESS" FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                    <TextBlock FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,16"
                               Text="Local accounts that can sign in. Roles control what each user may do; passwords are stored only as salted hashes. This is app-level access control, not OS or file-system security."/>

                    <!-- Release approval gate -->
                    <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            CornerRadius="8" Padding="14" Margin="0,0,0,18">
                        <StackPanel>
                            <CheckBox IsChecked="{Binding RequireReleaseApproval}" FontSize="13" FontWeight="SemiBold"
                                      Content="Require release approval before publishing"/>
                            <TextBlock FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="24,6,0,0"
                                       Text="When on, a version update or generated setup can't be published until an Admin and a QA Tester both approve it (on the version's Approvals panel). Other roles can leave review notes. Only enforced while access protection is on."/>
                        </StackPanel>
                    </Border>

                    <!-- First-run hint -->
                    <Border Background="{DynamicResource AccentSoftBrush}" CornerRadius="6" Padding="12,10" Margin="0,0,0,16"
                            Visibility="{Binding ProtectionEnabled, Converter={StaticResource InvertVisibility}}">
                        <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource TextBrush}"
                                   Text="No users yet — the app is unprotected. Create the first user to enable login. The first user becomes the administrator."/>
                    </Border>

                    <!-- Add user -->
                    <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            CornerRadius="8" Padding="14" Margin="0,0,0,18">
                        <StackPanel>
                            <TextBlock Text="Add user" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,10"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Height="34" VerticalContentAlignment="Center"
                                         Text="{Binding NewUsername, UpdateSourceTrigger=PropertyChanged}" ToolTip="Username"/>
                                <PasswordBox Grid.Column="2" Height="34" x:Name="NewUserPasswordBox"
                                             PasswordChanged="NewUserPasswordBox_PasswordChanged"/>
                                <ComboBox Grid.Column="4" Height="34" MinWidth="130" VerticalContentAlignment="Center"
                                          ItemsSource="{Binding RoleOptions}" SelectedItem="{Binding NewUserRole}"/>
                                <Button Grid.Column="6" Content="Add" Style="{StaticResource PrimaryButton}"
                                        Padding="18,8" Command="{Binding AddUserCommand}"/>
                            </Grid>
                            <TextBlock Text="{Binding UserMessage}" FontSize="11" Margin="0,10,0,0" TextWrapping="Wrap"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </Border>

                    <!-- Accounts -->
                    <TextBlock Text="ACCOUNTS" FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"
                               Visibility="{Binding ProtectionEnabled, Converter={StaticResource BoolToVisibility}}"/>
                    <ListBox ItemsSource="{Binding Users}" SelectedItem="{Binding SelectedUser}"
                             Background="Transparent" BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Margin" Value="0,0,0,6"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Background" Value="Transparent"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1" CornerRadius="8" Padding="12,9">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Username}" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextBrush}"/>
                                            <Border CornerRadius="4" Padding="6,1" Margin="8,0,0,0" Background="{DynamicResource AccentSoftBrush}"
                                                    Visibility="{Binding IsCurrent, Converter={StaticResource BoolToVisibility}}">
                                                <TextBlock Text="you" FontSize="10" Foreground="{DynamicResource AccentBrush}"/>
                                            </Border>
                                        </StackPanel>
                                        <ComboBox Grid.Column="1" MinWidth="130" Margin="0,0,8,0" VerticalContentAlignment="Center"
                                                  ItemsSource="{Binding DataContext.RoleOptions, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  SelectedItem="{Binding Role, Mode=TwoWay}"/>
                                        <Button Grid.Column="2" Content="Delete" Style="{StaticResource DangerButton}"
                                                Padding="12,6" FontSize="11"
                                                Command="{Binding DataContext.DeleteUserCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Reset password for the selected account -->
                    <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            CornerRadius="8" Padding="14" Margin="0,8,0,28"
                            Visibility="{Binding HasSelectedUser, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,10">
                                <Run Text="Reset password for "/><Run Text="{Binding SelectedUser.Username, Mode=OneWay}" FontWeight="Bold"/>
                            </TextBlock>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <PasswordBox Grid.Column="0" Height="34" x:Name="ResetPasswordBox"
                                             PasswordChanged="ResetPasswordBox_PasswordChanged"/>
                                <Button Grid.Column="2" Content="Reset password" Style="{StaticResource SecondaryButton}"
                                        Padding="16,8"
                                        Command="{Binding ResetUserPasswordCommand}" CommandParameter="{Binding SelectedUser}"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

        </Grid>

        <!-- Footer -->
        <Border Grid.Row="2" Background="{DynamicResource SidebarBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="28,14">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Save" Style="{StaticResource SecondaryButton}"
                        Padding="14,8" Margin="0,0,8,0"
                        Command="{Binding SaveCommand}"/>
                <Button Content="Close" Style="{StaticResource SecondaryButton}"
                        Padding="14,8" Margin="0,0,8,0"
                        Command="{Binding CloseCommand}"/>
                <Button Content="Save and Close" Style="{StaticResource PrimaryButton}"
                        Padding="18,8"
                        Command="{Binding SaveAndCloseCommand}"/>
            </StackPanel>
        </Border>

    </Grid>
</UserControl>
