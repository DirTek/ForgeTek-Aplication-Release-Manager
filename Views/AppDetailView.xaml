<UserControl x:Class="ForgeTekUpdatePackager.Views.AppDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="28,24,28,16" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding AppName}" FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource TextBrush}"/>
                    <TextBlock Text="{Binding AppPath}" FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Scan Now" Style="{StaticResource PrimaryButton}"
                            Padding="18,8" Margin="0,0,8,0"
                            Command="{Binding ScanNowCommand}"/>
                    <Button Content="Settings" Style="{StaticResource SecondaryButton}"
                            Padding="14,8" Margin="0,0,8,0"
                            Command="{Binding OpenAppSettingsCommand}"/>
                    <Button Content="Edit" Style="{StaticResource SecondaryButton}"
                            Padding="14,8" Margin="0,0,8,0"
                            Command="{Binding EditAppCommand}"/>
                    <Button Content="Delete" Style="{StaticResource DangerButton}"
                            Padding="14,8"
                            Command="{Binding DeleteAppCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Scanning overlay -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="#CC111113" Visibility="{Binding IsScanning, Converter={StaticResource BoolToVisibility}}"
                Panel.ZIndex="10">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Scanning folder…" FontSize="18"
                           Foreground="{StaticResource TextBrush}" HorizontalAlignment="Center"/>
                <TextBlock Text="Computing checksums, please wait." FontSize="13"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" Margin="0,8,0,0"/>
            </StackPanel>
        </Border>

        <!-- Section label row -->
        <Grid Grid.Row="1" Margin="28,20,28,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="VERSION HISTORY"
                       FontSize="11" FontWeight="SemiBold"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="Start Packing" Style="{StaticResource PrimaryButton}"
                        Padding="14,6" FontSize="12" Margin="0,0,8,0"
                        Command="{Binding StartPackingCommand}"/>
                <Button Content="View Changes" Style="{StaticResource SecondaryButton}"
                        Padding="14,6" FontSize="12" Margin="0,0,8,0"
                        Command="{Binding ViewVersionDiffCommand}"/>
                <Button Content="Retract" Style="{StaticResource DangerButton}"
                        Padding="14,6" FontSize="12" Margin="0,0,8,0"
                        Command="{Binding RetractVersionCommand}"
                        ToolTip="Delete uploaded FTP files and un-publish this version"/>
                <Button Content="Scrap" Style="{StaticResource DangerButton}"
                        Padding="14,6" FontSize="12" Margin="0,0,8,0"
                        Command="{Binding ScrapVersionCommand}"
                        ToolTip="Permanently discard this retracted version"/>
                <Button Content="Delete Version" Style="{StaticResource DangerButton}"
                        Padding="14,6" FontSize="12"
                        Command="{Binding DeleteVersionCommand}"/>
            </StackPanel>
        </Grid>

        <!-- Version history DataGrid -->
        <DataGrid Grid.Row="2" Margin="28,0,28,24"
                  ItemsSource="{Binding Versions}"
                  SelectedItem="{Binding SelectedVersion}"
                  IsReadOnly="True" AutoGenerateColumns="False"
                  CanUserAddRows="False" CanUserDeleteRows="False"
                  SelectionMode="Single" SelectionUnit="FullRow"
                  GridLinesVisibility="Horizontal"
                  HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
            <DataGrid.Columns>

                <DataGridTextColumn Header="Version"   Width="90"
                                    Binding="{Binding VersionNumber, StringFormat='v\{0\}'}"/>

                <!-- Status badge -->
                <DataGridTemplateColumn Header="Status" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border x:Name="badge" CornerRadius="4" Padding="8,3"
                                    Margin="8,0" HorizontalAlignment="Left" VerticalAlignment="Center"
                                    Background="{StaticResource SurfaceBrush}">
                                <TextBlock x:Name="badgeText" Text="{Binding Status}"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                            </Border>
                            <DataTemplate.Triggers>
                                <!-- Status-based colours (evaluated first, may be overridden by IsInitial below) -->
                                <DataTrigger Binding="{Binding Status}" Value="Signed">
                                    <Setter TargetName="badge"     Property="Background" Value="{StaticResource AccentBrush}"/>
                                    <Setter TargetName="badgeText" Property="Foreground" Value="{StaticResource TextBrush}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="Packed">
                                    <Setter TargetName="badge"     Property="Background" Value="{StaticResource ModifiedBrush}"/>
                                    <Setter TargetName="badgeText" Property="Foreground" Value="{StaticResource TextBrush}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="Published">
                                    <Setter TargetName="badge"     Property="Background" Value="{StaticResource AddedBrush}"/>
                                    <Setter TargetName="badgeText" Property="Foreground" Value="{StaticResource TextBrush}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="Retracted">
                                    <Setter TargetName="badge"     Property="Background" Value="{StaticResource RemovedBrush}"/>
                                    <Setter TargetName="badgeText" Property="Foreground" Value="{StaticResource TextBrush}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="Scrapped">
                                    <Setter TargetName="badge"     Property="Background" Value="{StaticResource SurfaceBrush}"/>
                                    <Setter TargetName="badgeText" Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                    <Setter TargetName="badgeText" Property="TextDecorations" Value="Strikethrough"/>
                                </DataTrigger>
                                <!-- Initial version overrides everything above -->
                                <DataTrigger Binding="{Binding IsInitial}" Value="True">
                                    <Setter TargetName="badge"     Property="Background" Value="{StaticResource SurfaceBrush}"/>
                                    <Setter TargetName="badgeText" Property="Text"       Value="Initial"/>
                                    <Setter TargetName="badgeText" Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Scan Date" Width="150"
                                    Binding="{Binding ScanDate, StringFormat='yyyy-MM-dd  HH:mm'}"/>

                <DataGridTextColumn Header="Files"         Width="70"
                                    Binding="{Binding PackageFileCount}"/>

                <DataGridTextColumn Header="Debug"         Width="60"
                                    Binding="{Binding DebugFileCount}"/>

                <!-- Added -->
                <DataGridTemplateColumn Header="Added" Width="70">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock VerticalAlignment="Center" Margin="12,0" FontWeight="SemiBold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text"       Value="{Binding AddedCount}"/>
                                        <Setter Property="Foreground" Value="{StaticResource AddedBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasDiff}" Value="False">
                                                <Setter Property="Text"       Value="—"/>
                                                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                                <Setter Property="FontWeight" Value="Normal"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Modified -->
                <DataGridTemplateColumn Header="Modified" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock VerticalAlignment="Center" Margin="12,0" FontWeight="SemiBold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text"       Value="{Binding ModifiedCount}"/>
                                        <Setter Property="Foreground" Value="{StaticResource ModifiedBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasDiff}" Value="False">
                                                <Setter Property="Text"       Value="—"/>
                                                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                                <Setter Property="FontWeight" Value="Normal"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Removed -->
                <DataGridTemplateColumn Header="Removed" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock VerticalAlignment="Center" Margin="12,0" FontWeight="SemiBold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text"       Value="{Binding RemovedCount}"/>
                                        <Setter Property="Foreground" Value="{StaticResource RemovedBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasDiff}" Value="False">
                                                <Setter Property="Text"       Value="—"/>
                                                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                                <Setter Property="FontWeight" Value="Normal"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Manifest -->
                <DataGridTemplateColumn Header="Manifest" Width="90">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock VerticalAlignment="Center" Margin="12,0" FontWeight="SemiBold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text"       Value="No"/>
                                        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasManifest}" Value="True">
                                                <Setter Property="Text"       Value="Yes"/>
                                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Package -->
                <DataGridTemplateColumn Header="Package" Width="90">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock VerticalAlignment="Center" Margin="12,0" FontWeight="SemiBold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text"       Value="No"/>
                                        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasPackage}" Value="True">
                                                <Setter Property="Text"       Value="Yes"/>
                                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>
        </DataGrid>

        <!-- Empty state -->
        <TextBlock Grid.Row="2" VerticalAlignment="Center" HorizontalAlignment="Center"
                   Text="No versions yet — click Scan Now to register the initial version."
                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="14"
                   Visibility="{Binding Versions.Count, Converter={StaticResource ZeroToVisible}}"/>
    </Grid>
</UserControl>
