<UserControl x:Class="ForgeTekApplicationReleaseManager.Views.AppDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="28,24,28,16" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding AppName}" FontSize="22" FontWeight="Bold"
                               Foreground="{DynamicResource TextBrush}"/>
                    <TextBlock Text="{Binding AppPath}" FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>

                    <!-- GitHub status banner -->
                    <Border CornerRadius="6" Padding="10,7" Margin="0,10,0,0" HorizontalAlignment="Left"
                            Visibility="{Binding GitHubConfigured, Converter={StaticResource BoolToVisibility}}">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{DynamicResource SubtlePanelBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding GitHubNewer}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xEB3C;" FontFamily="Segoe Fluent Icons" FontSize="13"
                                       VerticalAlignment="Center" Margin="0,0,8,0"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Text="{Binding GitHubStatus}" FontSize="12" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextBrush}" TextTrimming="CharacterEllipsis" MaxWidth="560"/>
                            <Button Content="{DynamicResource Str.AppDetail.Recheck}" Style="{StaticResource SecondaryButton}"
                                    Padding="10,4" FontSize="11" Margin="12,0,0,0"
                                    Command="{Binding CheckGitHubCommand}"/>
                            <Button Content="{DynamicResource Str.AppDetail.BuildFromGitHub}" Style="{StaticResource SecondaryButton}"
                                    Padding="10,4" FontSize="11" Margin="8,0,0,0"
                                    Command="{Binding BuildFromGitHubCommand}"
                                    Visibility="{Binding Session.CanScan, Converter={StaticResource BoolToVisibility}}"/>
                            <Button Content="{DynamicResource Str.AppDetail.ReleaseNotes}" Style="{StaticResource SecondaryButton}"
                                    Padding="10,4" FontSize="11" Margin="8,0,0,0"
                                    Command="{Binding OpenReleaseNotesCommand}"/>
                        </StackPanel>
                    </Border>

                    <!-- Last GitHub commit -->
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0"
                                Visibility="{Binding HasLastCommit, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="&#xE81C;" FontFamily="Segoe Fluent Icons" FontSize="12"
                                   VerticalAlignment="Center" Margin="0,0,8,0"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="620">
                            <Run Text="{DynamicResource Str.AppDetail.LastCommit}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                            <Run Text="{Binding LastCommitSummary, Mode=OneWay}" Foreground="{DynamicResource TextBrush}" FontSize="12"/>
                            <Run Text="  —  " Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                            <Run Text="{Binding LastCommitMeta, Mode=OneWay}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                        </TextBlock>
                    </StackPanel>

                    <!-- Source: build from solution + dependency/license scans -->
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0"
                                Visibility="{Binding HasScanSource, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="&#xE943;" FontFamily="Segoe Fluent Icons" FontSize="12"
                                   VerticalAlignment="Center" Margin="0,0,8,0"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding SolutionPathDisplay}" FontSize="12" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis"
                                   MaxWidth="320" ToolTip="{Binding SolutionPathDisplay}"
                                   Visibility="{Binding HasSolution, Converter={StaticResource BoolToVisibility}}"/>
                        <Button Content="{DynamicResource Str.AppDetail.BuildFromSolution}" Style="{StaticResource SecondaryButton}"
                                Padding="10,4" FontSize="11" Margin="12,0,0,0"
                                ToolTip="{DynamicResource Str.AppDetail.BuildFromSolutionTip}"
                                Visibility="{Binding HasSolution, Converter={StaticResource BoolToVisibility}}"
                                Command="{Binding BuildFromSolutionCommand}"/>
                        <Button Content="{DynamicResource Str.AppDetail.ScanDependencies}" Style="{StaticResource SecondaryButton}"
                                Padding="10,4" FontSize="11" Margin="8,0,0,0"
                                ToolTip="{DynamicResource Str.AppDetail.ScanDependenciesTip}"
                                Command="{Binding ScanDependenciesCommand}"/>
                        <Button Content="{DynamicResource Str.AppDetail.Licenses}" Style="{StaticResource SecondaryButton}"
                                Padding="10,4" FontSize="11" Margin="8,0,0,0"
                                ToolTip="{DynamicResource Str.AppDetail.LicensesTip}"
                                Command="{Binding ScanLicensesCommand}"/>
                        <Button Content="{DynamicResource Str.AppDetail.Compare}" Style="{StaticResource SecondaryButton}"
                                Padding="10,4" FontSize="11" Margin="8,0,0,0"
                                ToolTip="{DynamicResource Str.AppDetail.CompareTip}"
                                Command="{Binding CompareSourcesCommand}"/>
                        <Button Content="{DynamicResource Str.AppDetail.CompareGitHub}" Style="{StaticResource SecondaryButton}"
                                Padding="10,4" FontSize="11" Margin="8,0,0,0"
                                ToolTip="{DynamicResource Str.AppDetail.CompareGitHubTip}"
                                Visibility="{Binding GitHubConfigured, Converter={StaticResource BoolToVisibility}}"
                                Command="{Binding CompareWithGitHubCommand}"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource SecondaryButton}"
                            Padding="14,8" Margin="0,0,8,0"
                            Command="{Binding OpenAppSettingsCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE713;" FontFamily="Segoe Fluent Icons" FontSize="13"
                                       VerticalAlignment="Center" Margin="0,0,7,0"/>
                            <TextBlock Text="{DynamicResource Str.AppDetail.Settings}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SecondaryButton}"
                            Padding="14,8" Margin="0,0,8,0"
                            Command="{Binding EditAppCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE70F;" FontFamily="Segoe Fluent Icons" FontSize="13"
                                       VerticalAlignment="Center" Margin="0,0,7,0"/>
                            <TextBlock Text="{DynamicResource Str.AppDetail.Edit}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource DangerButton}"
                            Padding="14,8"
                            Command="{Binding DeleteAppCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE74D;" FontFamily="Segoe Fluent Icons" FontSize="13"
                                       VerticalAlignment="Center" Margin="0,0,7,0"/>
                            <TextBlock Text="{DynamicResource Str.AppDetail.Delete}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Workflow rail: Scan → Review → Package → Publish + primary next action -->
        <Border Grid.Row="1" Padding="28,16,28,16"
                Background="{DynamicResource SidebarBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Stepper -->
                <Grid Grid.Column="0" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/><ColumnDefinition Width="56"/>
                        <ColumnDefinition Width="Auto"/><ColumnDefinition Width="56"/>
                        <ColumnDefinition Width="Auto"/><ColumnDefinition Width="56"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource StepCircle}" Tag="{Binding ScanState}">
                        <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE721;" Style="{StaticResource StepGlyph}" Tag="{Binding ScanState}"/>
                    </Border>
                    <Rectangle Grid.Row="0" Grid.Column="1" Style="{StaticResource StepConnector}" Tag="{Binding ScanState}"/>
                    <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource StepCircle}" Tag="{Binding ReviewState}">
                        <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE890;" Style="{StaticResource StepGlyph}" Tag="{Binding ReviewState}"/>
                    </Border>
                    <Rectangle Grid.Row="0" Grid.Column="3" Style="{StaticResource StepConnector}" Tag="{Binding ReviewState}"/>
                    <Border Grid.Row="0" Grid.Column="4" Style="{StaticResource StepCircle}" Tag="{Binding PackageState}">
                        <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE7B8;" Style="{StaticResource StepGlyph}" Tag="{Binding PackageState}"/>
                    </Border>
                    <Rectangle Grid.Row="0" Grid.Column="5" Style="{StaticResource StepConnector}" Tag="{Binding PackageState}"/>
                    <Border Grid.Row="0" Grid.Column="6" Style="{StaticResource StepCircle}" Tag="{Binding PublishState}">
                        <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE898;" Style="{StaticResource StepGlyph}" Tag="{Binding PublishState}"/>
                    </Border>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource Str.AppDetail.StepScan}"    Style="{StaticResource StepLabel}" Tag="{Binding ScanState}"/>
                    <TextBlock Grid.Row="1" Grid.Column="2" Text="{DynamicResource Str.AppDetail.StepReview}"  Style="{StaticResource StepLabel}" Tag="{Binding ReviewState}"/>
                    <TextBlock Grid.Row="1" Grid.Column="4" Text="{DynamicResource Str.AppDetail.StepPackage}" Style="{StaticResource StepLabel}" Tag="{Binding PackageState}"/>
                    <TextBlock Grid.Row="1" Grid.Column="6" Text="{DynamicResource Str.AppDetail.StepPublish}" Style="{StaticResource StepLabel}" Tag="{Binding PublishState}"/>
                </Grid>

                <!-- Stage hint -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="28,0,16,0">
                    <TextBlock Text="{Binding WorkflowStageTitle}" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextBrush}"/>
                    <TextBlock Text="{Binding WorkflowHint}" FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               TextWrapping="Wrap" Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Primary next action -->
                <Button Grid.Column="2" VerticalAlignment="Center"
                        Content="{Binding PrimaryActionText}" Style="{StaticResource PrimaryButton}"
                        Padding="22,11" FontSize="13"
                        Command="{Binding PrimaryActionCommand}"/>
            </Grid>
        </Border>

        <!-- Scanning overlay -->
        <Border Grid.Row="0" Grid.RowSpan="4"
                Background="#CC111113" Visibility="{Binding IsScanning, Converter={StaticResource BoolToVisibility}}"
                Panel.ZIndex="10">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="380">
                <TextBlock Text="{DynamicResource Str.AppDetail.ScanningFolder}" FontSize="18" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextBrush}" HorizontalAlignment="Center"/>
                <ProgressBar Minimum="0" Maximum="100" Height="6" Margin="0,18,0,6"
                             Value="{Binding ScanProgress.Percentage, Mode=OneWay}"/>
                <TextBlock HorizontalAlignment="Center" FontSize="13"
                           Foreground="{DynamicResource TextBrush}">
                    <Run Text="{Binding ScanProgress.ProcessedFiles, Mode=OneWay}"/>
                    <Run Text=" / "/>
                    <Run Text="{Binding ScanProgress.TotalFiles, Mode=OneWay}"/>
                    <Run Text="{DynamicResource Str.AppDetail.FilesSuffix}"/>
                </TextBlock>
                <TextBlock Text="{Binding ScanProgress.CurrentFile, Mode=OneWay}"
                           FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" Margin="0,4,0,0"
                           TextTrimming="CharacterEllipsis"/>
                <Button Content="{DynamicResource Str.Common.Cancel}" Command="{Binding CancelScanCommand}"
                        Style="{StaticResource SecondaryButton}"
                        Margin="0,18,0,0" Padding="28,8" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Diff overlay -->
        <Border Grid.Row="0" Grid.RowSpan="4"
                Background="#CC111113" Visibility="{Binding IsDiffing, Converter={StaticResource BoolToVisibility}}"
                Panel.ZIndex="10">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="320">
                <TextBlock Text="{DynamicResource Str.AppDetail.ComputingChanges}" FontSize="18" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextBrush}" HorizontalAlignment="Center"/>
                <ProgressBar Minimum="0" Maximum="100" Height="6" Margin="0,18,0,10"
                             Value="{Binding DiffProgress.Percentage, Mode=OneWay}"/>
                <TextBlock Text="{Binding DiffProgress.CurrentPhase, Mode=OneWay}"
                           FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- GitHub build overlay (streamed output) -->
        <Border Grid.Row="0" Grid.RowSpan="4" Background="#B3000000" Panel.ZIndex="15"
                Visibility="{Binding ShowBuildOverlay, Converter={StaticResource BoolToVisibility}}">
            <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="12"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    Padding="24" Width="720" MaxHeight="520"
                    VerticalAlignment="Center" HorizontalAlignment="Center">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="{DynamicResource Str.AppDetail.BuildFromGitHub}" Style="{StaticResource H2}" Margin="0,0,0,12"/>

                    <Border Grid.Row="1" Background="{DynamicResource BackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="10">
                        <ScrollViewer x:Name="BuildLogScroller" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding BuildLog}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="12"
                                                   Foreground="{DynamicResource TextBrush}" TextWrapping="Wrap"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                        <Button Content="{DynamicResource Str.Common.Cancel}" Style="{StaticResource SecondaryButton}" Padding="20,9" Margin="0,0,8,0"
                                Command="{Binding CancelBuildCommand}"
                                Visibility="{Binding IsBuilding, Converter={StaticResource BoolToVisibility}}"/>
                        <Button Content="{DynamicResource Str.Common.Close}" Style="{StaticResource SecondaryButton}" Padding="20,9" Margin="0,0,8,0"
                                Command="{Binding CloseBuildCommand}"
                                Visibility="{Binding BuildFinished, Converter={StaticResource BoolToVisibility}}"/>
                        <Button Content="{DynamicResource Str.AppDetail.ScanBuildOutput}" Style="{StaticResource PrimaryButton}" Padding="22,9"
                                Command="{Binding ScanArtifactCommand}"
                                Visibility="{Binding BuildSucceeded, Converter={StaticResource BoolToVisibility}}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Border>

        <!-- Section label row -->
        <Grid Grid.Row="2" Margin="28,20,28,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{DynamicResource Str.AppDetail.VersionHistory}"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center" Margin="0,0,16,0"/>
                <!-- Channel filter (remembered across sessions) -->
                <Button Content="{DynamicResource Str.AppDetail.ChannelBoth}" FontSize="11" Padding="12,4" Margin="0,0,6,0"
                        Command="{Binding SetChannelFilterCommand}" CommandParameter="All">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsChannelAll}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="{DynamicResource Str.AppDetail.ChannelStable}" FontSize="11" Padding="12,4" Margin="0,0,6,0"
                        Command="{Binding SetChannelFilterCommand}" CommandParameter="Stable">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsChannelStable}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="{DynamicResource Str.AppDetail.ChannelBeta}" FontSize="11" Padding="12,4"
                        Command="{Binding SetChannelFilterCommand}" CommandParameter="Beta">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsChannelBeta}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource ModifiedBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="{DynamicResource Str.AppDetail.StartPacking}" Style="{StaticResource PrimaryButton}"
                        Padding="14,6" FontSize="12" Margin="0,0,8,0"
                        Command="{Binding StartPackingCommand}"/>
                <Button Content="{DynamicResource Str.AppDetail.ViewChanges}" Style="{StaticResource SecondaryButton}"
                        Padding="14,6" FontSize="12" Margin="0,0,8,0"
                        Command="{Binding ViewVersionDiffCommand}"/>

                <!-- Overflow: secondary + destructive actions, so they're not one slip away. -->
                <Grid>
                    <ToggleButton x:Name="MoreBtn" Content="{DynamicResource Str.AppDetail.More}" Style="{StaticResource DropdownToggle}"/>
                    <Popup PlacementTarget="{Binding ElementName=MoreBtn}" Placement="Bottom"
                           VerticalOffset="4" StaysOpen="False" AllowsTransparency="True"
                           IsOpen="{Binding IsChecked, ElementName=MoreBtn, Mode=TwoWay}">
                        <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1" CornerRadius="6" Padding="4" MinWidth="180">
                            <StackPanel>
                                <Button Content="{DynamicResource Str.AppDetail.SignFiles}" Style="{StaticResource MenuItemButton}"
                                        HorizontalAlignment="Stretch" Click="MoreItem_Click"
                                        Command="{Binding SignFilesCommand}"
                                        ToolTip="{DynamicResource Str.AppDetail.SignFilesTip}"/>
                                <Button Content="{DynamicResource Str.AppDetail.ReviseFiles}" Style="{StaticResource MenuItemButton}"
                                        HorizontalAlignment="Stretch" Click="MoreItem_Click"
                                        Command="{Binding ReviseVersionCommand}"
                                        ToolTip="{DynamicResource Str.AppDetail.ReviseFilesTip}"/>
                                <Rectangle Height="1" Fill="{DynamicResource BorderBrush}" Margin="6,4"/>
                                <Button Content="{DynamicResource Str.AppDetail.Retract}" Style="{StaticResource MenuItemButton}"
                                        HorizontalAlignment="Stretch" Click="MoreItem_Click"
                                        Foreground="{DynamicResource RemovedBrush}"
                                        Command="{Binding RetractVersionCommand}"
                                        ToolTip="{DynamicResource Str.AppDetail.RetractTip}"/>
                                <Button Content="{DynamicResource Str.AppDetail.Scrap}" Style="{StaticResource MenuItemButton}"
                                        HorizontalAlignment="Stretch" Click="MoreItem_Click"
                                        Foreground="{DynamicResource RemovedBrush}"
                                        Command="{Binding ScrapVersionCommand}"
                                        ToolTip="{DynamicResource Str.AppDetail.ScrapTip}"/>
                                <Button Content="{DynamicResource Str.AppDetail.DeleteVersion}" Style="{StaticResource MenuItemButton}"
                                        HorizontalAlignment="Stretch" Click="MoreItem_Click"
                                        Foreground="{DynamicResource RemovedBrush}"
                                        Command="{Binding DeleteVersionCommand}"/>
                            </StackPanel>
                        </Border>
                    </Popup>
                </Grid>
            </StackPanel>
        </Grid>

        <!-- Version history DataGrid -->
        <DataGrid Grid.Row="3" Margin="28,0,28,24"
                  ItemsSource="{Binding Versions}"
                  SelectedItem="{Binding SelectedVersion}"
                  PreviewMouseLeftButtonDown="VersionsGrid_PreviewMouseLeftButtonDown"
                  PreviewKeyDown="VersionsGrid_PreviewKeyDown"
                  IsReadOnly="True" AutoGenerateColumns="False"
                  CanUserAddRows="False" CanUserDeleteRows="False"
                  SelectionMode="Single" SelectionUnit="FullRow"
                  GridLinesVisibility="Horizontal"
                  RowHeaderWidth="12"
                  HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">

            <DataGrid.Resources>
                <!-- The top-left corner is the SelectAll button, which carries its own keyed theme
                     style — so it must be overridden by that exact ComponentResourceKey (a plain
                     implicit Button style won't win). Recolor it to the accent so it matches the strip. -->
                <Style x:Key="{ComponentResourceKey TypeInTargetAssembly={x:Type DataGrid}, ResourceId=DataGridSelectAllButtonStyle}"
                       TargetType="Button">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{Binding DataContext.Entry.AccentColor,
                                            RelativeSource={RelativeSource AncestorType=DataGrid},
                                            Converter={StaticResource HexToBrush}}"/>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </DataGrid.Resources>

            <!-- Row-header strip painted with the selected app's accent color -->
            <DataGrid.RowHeaderStyle>
                <Style TargetType="DataGridRowHeader">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="DataGridRowHeader">
                                <Border Background="{Binding DataContext.Entry.AccentColor,
                                            RelativeSource={RelativeSource AncestorType=DataGrid},
                                            Converter={StaticResource HexToBrush}}"/>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </DataGrid.RowHeaderStyle>

            <DataGrid.Columns>

                <DataGridTextColumn Header="{DynamicResource Str.AppDetail.ColVersion}"   Width="110"
                                    Binding="{Binding VersionNumber, StringFormat='v\{0\}'}"/>

                <!-- Channel chip (Stable / Beta) -->
                <DataGridTemplateColumn Header="{DynamicResource Str.AppDetail.ColChannel}" Width="95">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border x:Name="chanChip" CornerRadius="4" Padding="6,2" Margin="8,0"
                                    HorizontalAlignment="Left" VerticalAlignment="Center"
                                    Background="{DynamicResource SurfaceBrush}">
                                <TextBlock x:Name="chanText" Text="{DynamicResource Str.AppDetail.ChannelStable}" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </Border>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding Channel}" Value="Beta">
                                    <Setter TargetName="chanChip" Property="Background" Value="{DynamicResource ModifiedBrush}"/>
                                    <Setter TargetName="chanText" Property="Text" Value="{DynamicResource Str.AppDetail.ChannelBeta}"/>
                                    <Setter TargetName="chanText" Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Package kind (Full / Incremental) -->
                <DataGridTextColumn Header="{DynamicResource Str.AppDetail.ColType}" Width="110"
                                    Binding="{Binding PackageKindLabel}"/>

                <!-- Status badge -->
                <DataGridTemplateColumn Header="{DynamicResource Str.AppDetail.ColStatus}" Width="140">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border x:Name="badge" CornerRadius="4" Padding="8,3"
                                    Margin="8,0" HorizontalAlignment="Left" VerticalAlignment="Center"
                                    Background="{DynamicResource SurfaceBrush}">
                                <TextBlock x:Name="badgeText" Text="{Binding Status}"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </Border>
                            <DataTemplate.Triggers>
                                <!-- Status-based colours (evaluated first, may be overridden by IsInitial below) -->
                                <DataTrigger Binding="{Binding Status}" Value="Signed">
                                    <Setter TargetName="badge"     Property="Background" Value="{DynamicResource AccentBrush}"/>
                                    <Setter TargetName="badgeText" Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="Packed">
                                    <Setter TargetName="badge"     Property="Background" Value="{DynamicResource ModifiedBrush}"/>
                                    <Setter TargetName="badgeText" Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="Published">
                                    <Setter TargetName="badge"     Property="Background" Value="{DynamicResource AddedBrush}"/>
                                    <Setter TargetName="badgeText" Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="Retracted">
                                    <Setter TargetName="badge"     Property="Background" Value="{DynamicResource RemovedBrush}"/>
                                    <Setter TargetName="badgeText" Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="Scrapped">
                                    <Setter TargetName="badge"     Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                                    <Setter TargetName="badgeText" Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                    <Setter TargetName="badgeText" Property="TextDecorations" Value="Strikethrough"/>
                                </DataTrigger>
                                <!-- Initial version overrides everything above -->
                                <DataTrigger Binding="{Binding IsInitial}" Value="True">
                                    <Setter TargetName="badge"     Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                                    <Setter TargetName="badgeText" Property="Text"       Value="{DynamicResource Str.AppDetail.Initial}"/>
                                    <Setter TargetName="badgeText" Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="{DynamicResource Str.AppDetail.ColScanDate}" Width="180"
                                    Binding="{Binding ScanDate, StringFormat='yyyy-MM-dd  HH:mm'}"/>

                <DataGridTextColumn Header="{DynamicResource Str.AppDetail.ColFiles}"         Width="80"
                                    Binding="{Binding PackageFileCount}"/>

                <DataGridTextColumn Header="{DynamicResource Str.AppDetail.ColDebug}"         Width="80"
                                    Binding="{Binding DebugFileCount}"/>

                <!-- Added -->
                <DataGridTemplateColumn Header="{DynamicResource Str.AppDetail.ColAdded}" Width="85">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock VerticalAlignment="Center" Margin="12,0" FontWeight="SemiBold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text"       Value="{Binding AddedCount}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource AddedBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasDiff}" Value="False">
                                                <Setter Property="Text"       Value="—"/>
                                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                                <Setter Property="FontWeight" Value="Normal"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Modified -->
                <DataGridTemplateColumn Header="{DynamicResource Str.AppDetail.ColModified}" Width="95">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock VerticalAlignment="Center" Margin="12,0" FontWeight="SemiBold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text"       Value="{Binding ModifiedCount}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource ModifiedBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasDiff}" Value="False">
                                                <Setter Property="Text"       Value="—"/>
                                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                                <Setter Property="FontWeight" Value="Normal"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Removed -->
                <DataGridTemplateColumn Header="{DynamicResource Str.AppDetail.ColRemoved}" Width="95">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock VerticalAlignment="Center" Margin="12,0" FontWeight="SemiBold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text"       Value="{Binding RemovedCount}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource RemovedBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasDiff}" Value="False">
                                                <Setter Property="Text"       Value="—"/>
                                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                                <Setter Property="FontWeight" Value="Normal"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Manifest -->
                <DataGridTemplateColumn Header="{DynamicResource Str.AppDetail.ColManifest}" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock VerticalAlignment="Center" Margin="12,0" FontWeight="SemiBold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text"       Value="{DynamicResource Str.Common.No}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasManifest}" Value="True">
                                                <Setter Property="Text"       Value="{DynamicResource Str.Common.Yes}"/>
                                                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsInitial}" Value="True">
                                                <Setter Property="Text"       Value="—"/>
                                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                                <Setter Property="FontWeight" Value="Normal"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Package -->
                <DataGridTemplateColumn Header="{DynamicResource Str.AppDetail.ColPackage}" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock VerticalAlignment="Center" Margin="12,0" FontWeight="SemiBold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text"       Value="{DynamicResource Str.Common.No}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasPackage}" Value="True">
                                                <Setter Property="Text"       Value="{DynamicResource Str.Common.Yes}"/>
                                                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsInitial}" Value="True">
                                                <Setter Property="Text"       Value="—"/>
                                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                                <Setter Property="FontWeight" Value="Normal"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Setup generated (date a setup bundle that shipped this version was built) -->
                <DataGridTemplateColumn Header="{DynamicResource Str.AppDetail.ColSetupBuilt}" Width="160">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock VerticalAlignment="Center" Margin="12,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight"  Value="SemiBold"/>
                                        <Setter Property="Foreground"  Value="{DynamicResource AccentBrush}"/>
                                        <Setter Property="Text"
                                                Value="{Binding SetupGeneratedDate, StringFormat='yyyy-MM-dd  HH:mm'}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SetupGeneratedDate}" Value="{x:Null}">
                                                <Setter Property="Text"       Value="—"/>
                                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                                <Setter Property="FontWeight" Value="Normal"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Changelog -->
                <DataGridTemplateColumn Header="{DynamicResource Str.AppDetail.ColChangelog}" Width="*" MinWidth="110">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="{DynamicResource Str.AppDetail.View}"
                                    Command="{Binding DataContext.ViewChangelogCommand,
                                            RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    CommandParameter="{Binding}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                        <Setter Property="Padding" Value="8,4"/>
                                        <Setter Property="FontSize" Value="11"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasChangelog}" Value="False">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>
        </DataGrid>

        <!-- Empty state -->
        <StackPanel Grid.Row="3" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Visibility="{Binding Versions.Count, Converter={StaticResource ZeroToVisible}}">
            <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE721;" FontSize="40"
                       HorizontalAlignment="Center"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
            <TextBlock Text="{DynamicResource Str.AppDetail.NoVersionsYet}" FontSize="16" FontWeight="SemiBold"
                       HorizontalAlignment="Center" Margin="0,12,0,0"
                       Foreground="{DynamicResource TextBrush}"/>
            <TextBlock Text="{DynamicResource Str.AppDetail.NoVersionsHint}"
                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13"
                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
            <Button Content="{DynamicResource Str.AppDetail.ScanNow}" Style="{StaticResource PrimaryButton}"
                    Padding="22,9" Margin="0,16,0,0" HorizontalAlignment="Center"
                    Command="{Binding ScanNowCommand}"/>
        </StackPanel>

        <!-- Release approvals: Admin + QA Tester sign-off on the selected version (shown only when the
             "require release approval" option is on and protection is enabled). -->
        <Border Grid.Row="4" Margin="28,0,28,24" Padding="16"
                Background="{DynamicResource SurfaceBrush}" CornerRadius="6"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                Visibility="{Binding ShowApprovalPanel, Converter={StaticResource BoolToVisibility}}">
            <StackPanel>
                <TextBlock Text="{DynamicResource Str.AppDetail.ReleaseApprovals}" FontWeight="SemiBold" FontSize="14"
                           Foreground="{DynamicResource TextBrush}"/>
                <TextBlock Text="{Binding ApprovalSummary}" Margin="0,4,0,0"
                           Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>

                <ItemsControl ItemsSource="{Binding ApprovalThread}" Margin="0,10,0,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" Margin="0,2" FontSize="12"
                                       Foreground="{DynamicResource TextBrush}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBox Text="{Binding ReviewNoteDraft, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,10,0,0" Padding="8,6"
                         ToolTip="{DynamicResource Str.AppDetail.ReviewNoteTip}"/>

                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <Button Content="{DynamicResource Str.AppDetail.Approve}" Style="{StaticResource SuccessButton}" Padding="16,7"
                            Command="{Binding ApproveSelectedCommand}"
                            Visibility="{Binding CanCastVote, Converter={StaticResource BoolToVisibility}}"/>
                    <Button Content="{DynamicResource Str.AppDetail.Reject}" Style="{StaticResource DangerButton}" Padding="16,7" Margin="8,0,0,0"
                            Command="{Binding RejectSelectedCommand}"
                            Visibility="{Binding CanCastVote, Converter={StaticResource BoolToVisibility}}"/>
                    <Button Content="{DynamicResource Str.AppDetail.AddNote}" Style="{StaticResource SecondaryButton}" Padding="16,7" Margin="8,0,0,0"
                            Command="{Binding AddReviewNoteCommand}"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
