<UserControl x:Class="ForgeTekUpdatePackager.Views.AppDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="28,24,28,16" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding AppName}" FontSize="22" FontWeight="Bold"
                               Foreground="{DynamicResource TextBrush}"/>
                    <TextBlock Text="{Binding AppPath}" FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>

                    <!-- GitHub status banner -->
                    <Border CornerRadius="6" Padding="10,7" Margin="0,10,0,0" HorizontalAlignment="Left"
                            Visibility="{Binding GitHubConfigured, Converter={StaticResource BoolToVisibility}}">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{DynamicResource SubtlePanelBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding GitHubNewer}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xEB3C;" FontFamily="Segoe Fluent Icons" FontSize="13"
                                       VerticalAlignment="Center" Margin="0,0,8,0"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Text="{Binding GitHubStatus}" FontSize="12" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextBrush}" TextTrimming="CharacterEllipsis" MaxWidth="560"/>
                            <Button Content="Re-check" Style="{StaticResource SecondaryButton}"
                                    Padding="10,4" FontSize="11" Margin="12,0,0,0"
                                    Command="{Binding CheckGitHubCommand}"/>
                            <Button Content="Build from GitHub" Style="{StaticResource SecondaryButton}"
                                    Padding="10,4" FontSize="11" Margin="8,0,0,0"
                                    Command="{Binding BuildFromGitHubCommand}"
                                    Visibility="{Binding Session.CanScan, Converter={StaticResource BoolToVisibility}}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Settings" Style="{StaticResource SecondaryButton}"
                            Padding="14,8" Margin="0,0,8,0"
                            Command="{Binding OpenAppSettingsCommand}"/>
                    <Button Content="Edit" Style="{StaticResource SecondaryButton}"
                            Padding="14,8" Margin="0,0,8,0"
                            Command="{Binding EditAppCommand}"/>
                    <Button Content="Delete" Style="{StaticResource DangerButton}"
                            Padding="14,8"
                            Command="{Binding DeleteAppCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Workflow rail: Scan → Review → Package → Publish + primary next action -->
        <Border Grid.Row="1" Padding="28,16,28,16"
                Background="{DynamicResource SidebarBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Stepper -->
                <Grid Grid.Column="0" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/><ColumnDefinition Width="56"/>
                        <ColumnDefinition Width="Auto"/><ColumnDefinition Width="56"/>
                        <ColumnDefinition Width="Auto"/><ColumnDefinition Width="56"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource StepCircle}" Tag="{Binding ScanState}">
                        <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE721;" Style="{StaticResource StepGlyph}" Tag="{Binding ScanState}"/>
                    </Border>
                    <Rectangle Grid.Row="0" Grid.Column="1" Style="{StaticResource StepConnector}" Tag="{Binding ScanState}"/>
                    <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource StepCircle}" Tag="{Binding ReviewState}">
                        <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE890;" Style="{StaticResource StepGlyph}" Tag="{Binding ReviewState}"/>
                    </Border>
                    <Rectangle Grid.Row="0" Grid.Column="3" Style="{StaticResource StepConnector}" Tag="{Binding ReviewState}"/>
                    <Border Grid.Row="0" Grid.Column="4" Style="{StaticResource StepCircle}" Tag="{Binding PackageState}">
                        <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE7B8;" Style="{StaticResource StepGlyph}" Tag="{Binding PackageState}"/>
                    </Border>
                    <Rectangle Grid.Row="0" Grid.Column="5" Style="{StaticResource StepConnector}" Tag="{Binding PackageState}"/>
                    <Border Grid.Row="0" Grid.Column="6" Style="{StaticResource StepCircle}" Tag="{Binding PublishState}">
                        <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE898;" Style="{StaticResource StepGlyph}" Tag="{Binding PublishState}"/>
                    </Border>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Scan"    Style="{StaticResource StepLabel}" Tag="{Binding ScanState}"/>
                    <TextBlock Grid.Row="1" Grid.Column="2" Text="Review"  Style="{StaticResource StepLabel}" Tag="{Binding ReviewState}"/>
                    <TextBlock Grid.Row="1" Grid.Column="4" Text="Package" Style="{StaticResource StepLabel}" Tag="{Binding PackageState}"/>
                    <TextBlock Grid.Row="1" Grid.Column="6" Text="Publish" Style="{StaticResource StepLabel}" Tag="{Binding PublishState}"/>
                </Grid>

                <!-- Stage hint -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="28,0,16,0">
                    <TextBlock Text="{Binding WorkflowStageTitle}" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextBrush}"/>
                    <TextBlock Text="{Binding WorkflowHint}" FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               TextWrapping="Wrap" Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Primary next action -->
                <Button Grid.Column="2" VerticalAlignment="Center"
                        Content="{Binding PrimaryActionText}" Style="{StaticResource PrimaryButton}"
                        Padding="22,11" FontSize="13"
                        Command="{Binding PrimaryActionCommand}"/>
            </Grid>
        </Border>

        <!-- Scanning overlay -->
        <Border Grid.Row="0" Grid.RowSpan="4"
                Background="#CC111113" Visibility="{Binding IsScanning, Converter={StaticResource BoolToVisibility}}"
                Panel.ZIndex="10">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="380">
                <TextBlock Text="Scanning folder…" FontSize="18" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextBrush}" HorizontalAlignment="Center"/>
                <ProgressBar Minimum="0" Maximum="100" Height="6" Margin="0,18,0,6"
                             Value="{Binding ScanProgress.Percentage, Mode=OneWay}"/>
                <TextBlock HorizontalAlignment="Center" FontSize="13"
                           Foreground="{DynamicResource TextBrush}">
                    <Run Text="{Binding ScanProgress.ProcessedFiles, Mode=OneWay}"/>
                    <Run Text=" / "/>
                    <Run Text="{Binding ScanProgress.TotalFiles, Mode=OneWay}"/>
                    <Run Text=" files"/>
                </TextBlock>
                <TextBlock Text="{Binding ScanProgress.CurrentFile, Mode=OneWay}"
                           FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" Margin="0,4,0,0"
                           TextTrimming="CharacterEllipsis"/>
                <Button Content="Cancel" Command="{Binding CancelScanCommand}"
                        Style="{StaticResource SecondaryButton}"
                        Margin="0,18,0,0" Padding="28,8" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Diff overlay -->
        <Border Grid.Row="0" Grid.RowSpan="4"
                Background="#CC111113" Visibility="{Binding IsDiffing, Converter={StaticResource BoolToVisibility}}"
                Panel.ZIndex="10">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="320">
                <TextBlock Text="Computing changes…" FontSize="18" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextBrush}" HorizontalAlignment="Center"/>
                <ProgressBar Minimum="0" Maximum="100" Height="6" Margin="0,18,0,10"
                             Value="{Binding DiffProgress.Percentage, Mode=OneWay}"/>
                <TextBlock Text="{Binding DiffProgress.CurrentPhase, Mode=OneWay}"
                           FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- GitHub build overlay (streamed output) -->
        <Border Grid.Row="0" Grid.RowSpan="4" Background="#B3000000" Panel.ZIndex="15"
                Visibility="{Binding ShowBuildOverlay, Converter={StaticResource BoolToVisibility}}">
            <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="12"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    Padding="24" Width="720" MaxHeight="520"
                    VerticalAlignment="Center" HorizontalAlignment="Center">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Build from GitHub" Style="{StaticResource H2}" Margin="0,0,0,12"/>

                    <Border Grid.Row="1" Background="{DynamicResource BackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="10">
                        <ScrollViewer x:Name="BuildLogScroller" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding BuildLog}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="12"
                                                   Foreground="{DynamicResource TextBrush}" TextWrapping="Wrap"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                        <Button Content="Cancel" Style="{StaticResource SecondaryButton}" Padding="20,9" Margin="0,0,8,0"
                                Command="{Binding CancelBuildCommand}"
                                Visibility="{Binding IsBuilding, Converter={StaticResource BoolToVisibility}}"/>
                        <Button Content="Close" Style="{StaticResource SecondaryButton}" Padding="20,9" Margin="0,0,8,0"
                                Command="{Binding CloseBuildCommand}"
                                Visibility="{Binding BuildFinished, Converter={StaticResource BoolToVisibility}}"/>
                        <Button Content="Scan build output" Style="{StaticResource PrimaryButton}" Padding="22,9"
                                Command="{Binding ScanArtifactCommand}"
                                Visibility="{Binding BuildSucceeded, Converter={StaticResource BoolToVisibility}}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Border>

        <!-- Section label row -->
        <Grid Grid.Row="2" Margin="28,20,28,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="VERSION HISTORY"
                       FontSize="11" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="Start Packing" Style="{StaticResource PrimaryButton}"
                        Padding="14,6" FontSize="12" Margin="0,0,8,0"
                        Command="{Binding StartPackingCommand}"/>
                <Button Content="View Changes" Style="{StaticResource SecondaryButton}"
                        Padding="14,6" FontSize="12" Margin="0,0,8,0"
                        Command="{Binding ViewVersionDiffCommand}"/>

                <!-- Overflow: secondary + destructive actions, so they're not one slip away. -->
                <Grid>
                    <ToggleButton x:Name="MoreBtn" Content="More  ▾" Style="{StaticResource DropdownToggle}"/>
                    <Popup PlacementTarget="{Binding ElementName=MoreBtn}" Placement="Bottom"
                           VerticalOffset="4" StaysOpen="False" AllowsTransparency="True"
                           IsOpen="{Binding IsChecked, ElementName=MoreBtn, Mode=TwoWay}">
                        <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1" CornerRadius="6" Padding="4" MinWidth="180">
                            <StackPanel>
                                <Button Content="Sign Files" Style="{StaticResource MenuItemButton}"
                                        HorizontalAlignment="Stretch" Click="MoreItem_Click"
                                        Command="{Binding SignFilesCommand}"
                                        ToolTip="Code-sign selected files of this version before packing into a setup"/>
                                <Button Content="Revise Files" Style="{StaticResource MenuItemButton}"
                                        HorizontalAlignment="Stretch" Click="MoreItem_Click"
                                        Command="{Binding ReviseVersionCommand}"
                                        ToolTip="Edit which files are included for this version"/>
                                <Rectangle Height="1" Fill="{DynamicResource BorderBrush}" Margin="6,4"/>
                                <Button Content="Retract" Style="{StaticResource MenuItemButton}"
                                        HorizontalAlignment="Stretch" Click="MoreItem_Click"
                                        Foreground="{DynamicResource RemovedBrush}"
                                        Command="{Binding RetractVersionCommand}"
                                        ToolTip="Delete uploaded FTP files and un-publish this version"/>
                                <Button Content="Scrap" Style="{StaticResource MenuItemButton}"
                                        HorizontalAlignment="Stretch" Click="MoreItem_Click"
                                        Foreground="{DynamicResource RemovedBrush}"
                                        Command="{Binding ScrapVersionCommand}"
                                        ToolTip="Permanently discard this retracted version"/>
                                <Button Content="Delete Version" Style="{StaticResource MenuItemButton}"
                                        HorizontalAlignment="Stretch" Click="MoreItem_Click"
                                        Foreground="{DynamicResource RemovedBrush}"
                                        Command="{Binding DeleteVersionCommand}"/>
                            </StackPanel>
                        </Border>
                    </Popup>
                </Grid>
            </StackPanel>
        </Grid>

        <!-- Version history DataGrid -->
        <DataGrid Grid.Row="3" Margin="28,0,28,24"
                  ItemsSource="{Binding Versions}"
                  SelectedItem="{Binding SelectedVersion}"
                  PreviewMouseLeftButtonDown="VersionsGrid_PreviewMouseLeftButtonDown"
                  PreviewKeyDown="VersionsGrid_PreviewKeyDown"
                  IsReadOnly="True" AutoGenerateColumns="False"
                  CanUserAddRows="False" CanUserDeleteRows="False"
                  SelectionMode="Single" SelectionUnit="FullRow"
                  GridLinesVisibility="Horizontal"
                  RowHeaderWidth="12"
                  HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">

            <DataGrid.Resources>
                <!-- The top-left corner is the SelectAll button, which carries its own keyed theme
                     style — so it must be overridden by that exact ComponentResourceKey (a plain
                     implicit Button style won't win). Recolor it to the accent so it matches the strip. -->
                <Style x:Key="{ComponentResourceKey TypeInTargetAssembly={x:Type DataGrid}, ResourceId=DataGridSelectAllButtonStyle}"
                       TargetType="Button">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{Binding DataContext.Entry.AccentColor,
                                            RelativeSource={RelativeSource AncestorType=DataGrid},
                                            Converter={StaticResource HexToBrush}}"/>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </DataGrid.Resources>

            <!-- Row-header strip painted with the selected app's accent color -->
            <DataGrid.RowHeaderStyle>
                <Style TargetType="DataGridRowHeader">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="DataGridRowHeader">
                                <Border Background="{Binding DataContext.Entry.AccentColor,
                                            RelativeSource={RelativeSource AncestorType=DataGrid},
                                            Converter={StaticResource HexToBrush}}"/>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </DataGrid.RowHeaderStyle>

            <DataGrid.Columns>

                <DataGridTextColumn Header="Version"   Width="90"
                                    Binding="{Binding VersionNumber, StringFormat='v\{0\}'}"/>

                <!-- Channel chip (only shown for Beta) -->
                <DataGridTemplateColumn Header="Channel" Width="70">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border CornerRadius="4" Padding="6,2" Margin="8,0"
                                    HorizontalAlignment="Left" VerticalAlignment="Center"
                                    Background="{DynamicResource ModifiedBrush}"
                                    Visibility="Collapsed" x:Name="betaChip">
                                <TextBlock Text="Beta" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}"/>
                            </Border>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding Channel}" Value="Beta">
                                    <Setter TargetName="betaChip" Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Status badge -->
                <DataGridTemplateColumn Header="Status" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border x:Name="badge" CornerRadius="4" Padding="8,3"
                                    Margin="8,0" HorizontalAlignment="Left" VerticalAlignment="Center"
                                    Background="{DynamicResource SurfaceBrush}">
                                <TextBlock x:Name="badgeText" Text="{Binding Status}"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </Border>
                            <DataTemplate.Triggers>
                                <!-- Status-based colours (evaluated first, may be overridden by IsInitial below) -->
                                <DataTrigger Binding="{Binding Status}" Value="Signed">
                                    <Setter TargetName="badge"     Property="Background" Value="{DynamicResource AccentBrush}"/>
                                    <Setter TargetName="badgeText" Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="Packed">
                                    <Setter TargetName="badge"     Property="Background" Value="{DynamicResource ModifiedBrush}"/>
                                    <Setter TargetName="badgeText" Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="Published">
                                    <Setter TargetName="badge"     Property="Background" Value="{DynamicResource AddedBrush}"/>
                                    <Setter TargetName="badgeText" Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="Retracted">
                                    <Setter TargetName="badge"     Property="Background" Value="{DynamicResource RemovedBrush}"/>
                                    <Setter TargetName="badgeText" Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="Scrapped">
                                    <Setter TargetName="badge"     Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                                    <Setter TargetName="badgeText" Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                    <Setter TargetName="badgeText" Property="TextDecorations" Value="Strikethrough"/>
                                </DataTrigger>
                                <!-- Initial version overrides everything above -->
                                <DataTrigger Binding="{Binding IsInitial}" Value="True">
                                    <Setter TargetName="badge"     Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                                    <Setter TargetName="badgeText" Property="Text"       Value="Initial"/>
                                    <Setter TargetName="badgeText" Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Scan Date" Width="150"
                                    Binding="{Binding ScanDate, StringFormat='yyyy-MM-dd  HH:mm'}"/>

                <DataGridTextColumn Header="Files"         Width="70"
                                    Binding="{Binding PackageFileCount}"/>

                <DataGridTextColumn Header="Debug"         Width="60"
                                    Binding="{Binding DebugFileCount}"/>

                <!-- Added -->
                <DataGridTemplateColumn Header="Added" Width="70">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock VerticalAlignment="Center" Margin="12,0" FontWeight="SemiBold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text"       Value="{Binding AddedCount}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource AddedBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasDiff}" Value="False">
                                                <Setter Property="Text"       Value="—"/>
                                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                                <Setter Property="FontWeight" Value="Normal"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Modified -->
                <DataGridTemplateColumn Header="Modified" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock VerticalAlignment="Center" Margin="12,0" FontWeight="SemiBold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text"       Value="{Binding ModifiedCount}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource ModifiedBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasDiff}" Value="False">
                                                <Setter Property="Text"       Value="—"/>
                                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                                <Setter Property="FontWeight" Value="Normal"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Removed -->
                <DataGridTemplateColumn Header="Removed" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock VerticalAlignment="Center" Margin="12,0" FontWeight="SemiBold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text"       Value="{Binding RemovedCount}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource RemovedBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasDiff}" Value="False">
                                                <Setter Property="Text"       Value="—"/>
                                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                                <Setter Property="FontWeight" Value="Normal"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Manifest -->
                <DataGridTemplateColumn Header="Manifest" Width="90">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock VerticalAlignment="Center" Margin="12,0" FontWeight="SemiBold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text"       Value="No"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasManifest}" Value="True">
                                                <Setter Property="Text"       Value="Yes"/>
                                                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsInitial}" Value="True">
                                                <Setter Property="Text"       Value="—"/>
                                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                                <Setter Property="FontWeight" Value="Normal"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Package -->
                <DataGridTemplateColumn Header="Package" Width="90">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock VerticalAlignment="Center" Margin="12,0" FontWeight="SemiBold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text"       Value="No"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasPackage}" Value="True">
                                                <Setter Property="Text"       Value="Yes"/>
                                                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsInitial}" Value="True">
                                                <Setter Property="Text"       Value="—"/>
                                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                                <Setter Property="FontWeight" Value="Normal"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Changelog -->
                <DataGridTemplateColumn Header="Changelog" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="View"
                                    Command="{Binding DataContext.ViewChangelogCommand,
                                            RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    CommandParameter="{Binding}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                        <Setter Property="Padding" Value="8,4"/>
                                        <Setter Property="FontSize" Value="11"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasChangelog}" Value="False">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>
        </DataGrid>

        <!-- Empty state -->
        <StackPanel Grid.Row="3" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Visibility="{Binding Versions.Count, Converter={StaticResource ZeroToVisible}}">
            <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE721;" FontSize="40"
                       HorizontalAlignment="Center"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
            <TextBlock Text="No versions yet" FontSize="16" FontWeight="SemiBold"
                       HorizontalAlignment="Center" Margin="0,12,0,0"
                       Foreground="{DynamicResource TextBrush}"/>
            <TextBlock Text="Scan the app folder to register the initial version."
                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13"
                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
            <Button Content="Scan Now" Style="{StaticResource PrimaryButton}"
                    Padding="22,9" Margin="0,16,0,0" HorizontalAlignment="Center"
                    Command="{Binding ScanNowCommand}"/>
        </StackPanel>
    </Grid>
</UserControl>
