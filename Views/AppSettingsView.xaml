<UserControl x:Class="ForgeTekApplicationReleaseManager.Views.AppSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="28,24,28,16"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel>
                <TextBlock FontSize="22" FontWeight="Bold" Foreground="{DynamicResource TextBrush}">
                    <Run Text="{DynamicResource Str.AppSettings.HeaderPrefix}"/><Run Text="{Binding AppName, Mode=OneWay}"/>
                </TextBlock>
                <TextBlock Text="{DynamicResource Str.AppSettings.Subtitle}" FontSize="12"
                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Pipeline template bar -->
        <Border Grid.Row="1" Padding="28,12,28,12"
                Background="{DynamicResource SidebarBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{DynamicResource Str.AppSettings.Template}" FontSize="12" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="0,0,10,0"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <ComboBox Width="240" Height="32" VerticalContentAlignment="Center"
                              ItemsSource="{Binding Templates}"
                              SelectedItem="{Binding SelectedTemplate, Mode=TwoWay}"
                              DisplayMemberPath="Name"
                              ToolTip="{DynamicResource Str.AppSettings.TemplateTip}"/>
                    <Button Content="{DynamicResource Str.AppSettings.Apply}" Style="{StaticResource SecondaryButton}"
                            Padding="14,6" Margin="8,0,0,0" FontSize="12"
                            Command="{Binding ApplyTemplateCommand}"/>
                    <Button Content="{DynamicResource Str.AppSettings.SaveAs}" Style="{StaticResource SecondaryButton}"
                            Padding="14,6" Margin="8,0,0,0" FontSize="12"
                            Command="{Binding SaveAsTemplateCommand}"/>
                    <Button Content="{DynamicResource Str.Common.Delete}" Style="{StaticResource SecondaryButton}"
                            Padding="14,6" Margin="8,0,0,0" FontSize="12"
                            Command="{Binding DeleteTemplateCommand}"/>
                    <TextBlock Text="{Binding TemplateStatus}" FontSize="11" VerticalAlignment="Center"
                               Margin="14,0,0,0" Foreground="{DynamicResource TextSecondaryBrush}"
                               TextTrimming="CharacterEllipsis" MaxWidth="360"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Body: settings grouped into tabs -->
        <TabControl Grid.Row="2" Margin="28,16,28,0">

            <!-- ══ GENERAL ══════════════════════════════════════════════════ -->
            <TabItem Header="{DynamicResource Str.AppSettings.TabGeneral}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,8,12,16">

                        <!-- OUTPUT FOLDER -->
                        <TextBlock Text="{DynamicResource Str.AppSettings.OutputFolder}" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>

                        <TextBlock FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,0,0,6" TextWrapping="Wrap">
                            <Run Text="{DynamicResource Str.AppSettings.DefaultPrefix}"/>
                            <Run Text="{Binding DefaultOutputBase, Mode=OneWay}"
                                 Foreground="{DynamicResource TextBrush}"/>
                            <Run Text="\{version}"/>
                        </TextBlock>

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding OutputFolder, UpdateSourceTrigger=PropertyChanged}"
                                     Height="36" Margin="0,0,8,0"/>
                            <Button Grid.Column="1" Content="{DynamicResource Str.Common.Browse}" Style="{StaticResource SecondaryButton}"
                                    Padding="14,8" Margin="0,0,8,0"
                                    Command="{Binding BrowseOutputFolderCommand}"/>
                            <Button Grid.Column="2" Content="{DynamicResource Str.Common.Clear}" Style="{StaticResource SecondaryButton}"
                                    Padding="10,8"
                                    Command="{Binding ClearOutputFolderCommand}"/>
                        </Grid>

                        <TextBlock Text="{DynamicResource Str.AppSettings.OutputFolderHint}"
                                   FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,0,0,28" TextWrapping="Wrap"/>

                        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Margin="0,0,0,28"/>

                        <!-- PACKAGE EXTENSION -->
                        <TextBlock Text="{DynamicResource Str.AppSettings.PackageExt}" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>

                        <TextBlock FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,0,0,6" TextWrapping="Wrap">
                            <Run Text="{DynamicResource Str.AppSettings.PackageExtDescPre}"/><Run Text=".ftu" Foreground="{DynamicResource TextBrush}"/><Run Text="."/>
                        </TextBlock>

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="160"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="." FontSize="15" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="0,0,2,0"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding PackageExtension, UpdateSourceTrigger=PropertyChanged}"
                                     Height="36"/>
                        </Grid>

                        <TextBlock Text="{DynamicResource Str.AppSettings.PackageExtExample}"
                                   FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,0,0,28" TextWrapping="Wrap"/>

                        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Margin="0,0,0,28"/>

                        <!-- PACKAGE FILE NAME -->
                        <TextBlock Text="{DynamicResource Str.AppSettings.PackageName}" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                        <TextBlock FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,0,0,6" TextWrapping="Wrap">
                            <Run Text="{DynamicResource Str.AppSettings.PackageNameDescPre}"/><Run Text="{}{AppName}-{Version}" Foreground="{DynamicResource TextBrush}"/><Run Text="."/>
                        </TextBlock>
                        <TextBox Text="{Binding PackageNameTemplate, UpdateSourceTrigger=PropertyChanged}"
                                 Height="36" Margin="0,0,0,4"
                                 ToolTip="{DynamicResource Str.AppSettings.PackageNameTip}"/>
                        <TextBlock Text="{DynamicResource Str.AppSettings.PackageNameVars}"
                                   FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,0,0,8" TextWrapping="Wrap"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ══ SIGNING ══════════════════════════════════════════════════ -->
            <TabItem Header="{DynamicResource Str.AppSettings.TabSigning}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,8,12,16">

                        <TextBlock Text="{DynamicResource Str.AppSettings.DefaultCert}" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>

                        <!-- Global cert override banner -->
                        <Border CornerRadius="6" Padding="12,10" Margin="0,0,0,12"
                                Background="{DynamicResource AccentSoftBrush}" BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1"
                                Visibility="{Binding GlobalCertOverrideActive, Converter={StaticResource BoolToVisibility}}">
                            <StackPanel>
                                <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}"
                                           Text="{DynamicResource Str.Package.GlobalCertActive}"/>
                                <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,3,0,0" TextWrapping="Wrap">
                                    <Run Text="{DynamicResource Str.Package.UsingPrefix}"/>
                                    <Run Text="{Binding GlobalCertOverrideName, Mode=OneWay}"
                                         Foreground="{DynamicResource TextBrush}" FontWeight="SemiBold"/>
                                    <Run Text="{DynamicResource Str.AppSettings.CertDisabledSuffix}"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="{DynamicResource Str.AppSettings.CertPrefill}"
                                   FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,0,0,6" TextWrapping="Wrap"
                                   Visibility="{Binding GlobalCertOverrideInactive, Converter={StaticResource BoolToVisibility}}"/>

                        <!-- Default cert path + Windows Store toggle -->
                        <Grid Margin="0,0,0,12" IsEnabled="{Binding GlobalCertOverrideInactive}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding DefaultCertPath, UpdateSourceTrigger=PropertyChanged}"
                                     Height="36" Margin="0,0,8,0"/>
                            <Button Grid.Column="1" Content="{DynamicResource Str.Common.Browse}" Style="{StaticResource SecondaryButton}"
                                    Padding="14,8" Margin="0,0,8,0"
                                    Command="{Binding BrowseCertCommand}"/>
                            <Button Grid.Column="2" Content="{DynamicResource Str.Common.Clear}" Style="{StaticResource SecondaryButton}"
                                    Padding="10,8"
                                    Command="{Binding ClearCertCommand}"/>
                        </Grid>

                        <TextBlock Text="{DynamicResource Str.AppSettings.CertPassword}" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>

                        <PasswordBox x:Name="CertPasswordBox" Height="36" Margin="0,0,0,6"
                                     IsEnabled="{Binding GlobalCertOverrideInactive}"
                                     PasswordChanged="CertPasswordBox_PasswordChanged"/>

                        <TextBlock Margin="0,0,0,6" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextWrapping="Wrap">
                            <Run Text="{DynamicResource Str.AppSettings.CertPwNote1}"/>
                            <Run Text="{DynamicResource Str.AppSettings.CertPwNote2}"/>
                        </TextBlock>

                        <!-- Windows Store certificate source -->
                        <StackPanel Margin="0,0,0,12" IsEnabled="{Binding GlobalCertOverrideInactive}">
                            <CheckBox IsChecked="{Binding UseStoreCert}" FontSize="13"
                                      Content="{DynamicResource Str.AppSettings.UseStoreCert}"/>
                            <StackPanel Margin="20,8,0,0"
                                        Visibility="{Binding UseStoreCert, Converter={StaticResource BoolToVisibility}}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ListBox Grid.Column="0" Height="100" Margin="0,0,8,0"
                                             ItemsSource="{Binding StoreCertificates}"
                                             SelectedValue="{Binding SelectedStoreThumbprint, Mode=TwoWay}"
                                             SelectedValuePath="Thumbprint"
                                             Background="{DynamicResource SurfaceBrush}" BorderThickness="0">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Subject}" FontSize="12"
                                                               Foreground="{DynamicResource TextBrush}"/>
                                                    <TextBlock Text="{Binding DisplayName}" FontSize="11"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                    <Button Grid.Column="1" Content="{DynamicResource Str.Common.Refresh}" Style="{StaticResource SecondaryButton}"
                                            Padding="14,8" VerticalAlignment="Top"
                                            Command="{Binding RefreshStoreCertListCommand}"/>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ══ PUBLISHING ═══════════════════════════════════════════════ -->
            <TabItem Header="{DynamicResource Str.AppSettings.TabPublishing}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,8,12,16">

                        <TextBlock FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,0,0,12" TextWrapping="Wrap"
                                   Text="{DynamicResource Str.AppSettings.PublishingDesc}"/>

                        <TextBlock Text="{DynamicResource Str.AppSettings.Provider}" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                        <ComboBox SelectedValue="{Binding PublishProvider, Mode=TwoWay}" SelectedValuePath="Tag"
                                  Height="36" Margin="0,0,0,14" Width="240" HorizontalAlignment="Left">
                            <ComboBoxItem Content="FTP" Tag="Ftp"/>
                            <ComboBoxItem Content="SFTP (SSH)" Tag="Sftp"/>
                            <ComboBoxItem Content="S3-compatible (S3 / R2 / MinIO)" Tag="S3"/>
                            <ComboBoxItem Content="GitHub Releases" Tag="GitHubReleases"/>
                        </ComboBox>

                        <!-- ── FTP ── -->
                        <StackPanel Visibility="{Binding IsFtp, Converter={StaticResource BoolToVisibility}}">
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="90"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock Text="{DynamicResource Str.AppSettings.Host}" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                                    <TextBox Text="{Binding FtpHost, UpdateSourceTrigger=PropertyChanged}" Height="36"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{DynamicResource Str.AppSettings.Port}" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                                    <TextBox Text="{Binding FtpPort, UpdateSourceTrigger=PropertyChanged}" Height="36"/>
                                </StackPanel>
                            </Grid>
                            <TextBlock Text="{DynamicResource Str.AppSettings.Username}" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding FtpUsername, UpdateSourceTrigger=PropertyChanged}"
                                     Height="36" Margin="0,0,0,10"/>
                            <TextBlock Text="{DynamicResource Str.AppSettings.FtpPassword}" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                            <PasswordBox x:Name="FtpPasswordBox" Height="36" Margin="0,0,0,10"
                                         PasswordChanged="FtpPasswordBox_PasswordChanged"/>
                            <TextBlock Text="{DynamicResource Str.AppSettings.RemoteBasePath}" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding FtpRemotePath, UpdateSourceTrigger=PropertyChanged}"
                                     Height="36" Margin="0,0,0,4"/>
                            <TextBlock Text="{DynamicResource Str.AppSettings.FtpRemoteHint}"
                                       FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,0,0,10" TextWrapping="Wrap"/>
                            <TextBlock Text="{DynamicResource Str.AppSettings.BaseDownloadUrl}" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding BaseDownloadUrl, UpdateSourceTrigger=PropertyChanged}"
                                     Height="36" Margin="0,0,0,4"/>
                            <TextBlock Text="{DynamicResource Str.AppSettings.FtpUrlHint}"
                                       FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,0,0,14" TextWrapping="Wrap"/>
                        </StackPanel>

                        <!-- ── SFTP ── -->
                        <StackPanel Visibility="{Binding IsSftp, Converter={StaticResource BoolToVisibility}}">
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="90"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock Text="{DynamicResource Str.AppSettings.Host}" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                                    <TextBox Text="{Binding SftpHost, UpdateSourceTrigger=PropertyChanged}" Height="36"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{DynamicResource Str.AppSettings.Port}" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                                    <TextBox Text="{Binding SftpPort, UpdateSourceTrigger=PropertyChanged}" Height="36"/>
                                </StackPanel>
                            </Grid>
                            <TextBlock Text="{DynamicResource Str.AppSettings.Username}" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding SftpUsername, UpdateSourceTrigger=PropertyChanged}"
                                     Height="36" Margin="0,0,0,10"/>
                            <TextBlock Text="{DynamicResource Str.AppSettings.Password}" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                            <PasswordBox x:Name="SftpPasswordBox" Height="36" Margin="0,0,0,10"
                                         PasswordChanged="SftpPasswordBox_PasswordChanged"/>
                            <TextBlock Text="{DynamicResource Str.AppSettings.RemoteBasePath}" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding SftpRemotePath, UpdateSourceTrigger=PropertyChanged}"
                                     Height="36" Margin="0,0,0,10"/>
                            <TextBlock Text="{DynamicResource Str.AppSettings.BaseDownloadUrl}" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding SftpBaseDownloadUrl, UpdateSourceTrigger=PropertyChanged}"
                                     Height="36" Margin="0,0,0,14"/>
                        </StackPanel>

                        <!-- ── S3-compatible ── -->
                        <StackPanel Visibility="{Binding IsS3, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="{DynamicResource Str.AppSettings.S3Endpoint}" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding S3Endpoint, UpdateSourceTrigger=PropertyChanged}"
                                     Height="36" Margin="0,0,0,10" ToolTip="{DynamicResource Str.AppSettings.S3EndpointTip}"/>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="160"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock Text="{DynamicResource Str.AppSettings.S3Bucket}" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                                    <TextBox Text="{Binding S3Bucket, UpdateSourceTrigger=PropertyChanged}" Height="36"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{DynamicResource Str.AppSettings.S3Region}" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                                    <TextBox Text="{Binding S3Region, UpdateSourceTrigger=PropertyChanged}" Height="36"
                                             ToolTip="{DynamicResource Str.AppSettings.S3RegionTip}"/>
                                </StackPanel>
                            </Grid>
                            <TextBlock Text="{DynamicResource Str.AppSettings.S3AccessKey}" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding S3AccessKey, UpdateSourceTrigger=PropertyChanged}"
                                     Height="36" Margin="0,0,0,10"/>
                            <TextBlock Text="{DynamicResource Str.AppSettings.S3SecretKey}" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                            <PasswordBox x:Name="S3SecretKeyBox" Height="36" Margin="0,0,0,10"
                                         PasswordChanged="S3SecretKeyBox_PasswordChanged"/>
                            <TextBlock Text="{DynamicResource Str.AppSettings.S3Prefix}" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding S3Prefix, UpdateSourceTrigger=PropertyChanged}"
                                     Height="36" Margin="0,0,0,10"/>
                            <TextBlock Text="{DynamicResource Str.AppSettings.S3PublicUrl}" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding S3PublicBaseUrl, UpdateSourceTrigger=PropertyChanged}"
                                     Height="36" Margin="0,0,0,4"/>
                            <TextBlock Text="{DynamicResource Str.AppSettings.S3UrlHint}"
                                       FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,0,0,14" TextWrapping="Wrap"/>
                        </StackPanel>

                        <!-- ── GitHub Releases ── -->
                        <StackPanel Visibility="{Binding IsGitHubReleases, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,0,0,10" TextWrapping="Wrap"
                                       Text="{DynamicResource Str.AppSettings.GhReleasesDesc}"/>
                            <TextBlock Text="{DynamicResource Str.AppSettings.GhPkgTag}" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding GitHubReleaseTag, UpdateSourceTrigger=PropertyChanged}"
                                     Height="36" Margin="0,0,0,4" ToolTip="{DynamicResource Str.AppSettings.GhPkgTagTip}"/>
                            <TextBlock Text="{DynamicResource Str.AppSettings.GhPkgTagHint}"
                                       FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,0,0,10" TextWrapping="Wrap"/>
                            <TextBlock Text="{DynamicResource Str.AppSettings.GhCatalogTag}" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding GitHubCatalogTag, UpdateSourceTrigger=PropertyChanged}"
                                     Height="36" Margin="0,0,0,4"/>
                            <TextBlock Text="{DynamicResource Str.AppSettings.GhCatalogTagHint}"
                                       FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,0,0,14" TextWrapping="Wrap"/>
                        </StackPanel>

                        <!-- Test connection -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <Button Content="{DynamicResource Str.AppSettings.TestConnection}" Style="{StaticResource SecondaryButton}"
                                    Padding="14,8" Margin="0,0,12,0"
                                    Command="{Binding TestConnectionCommand}"/>
                            <TextBlock Text="{DynamicResource Str.AppSettings.Testing}" FontSize="13"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsTestingConnection}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>

                        <TextBlock Text="{Binding ConnectionTestResult}" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,0,0,8" TextWrapping="Wrap"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ══ GITHUB ═══════════════════════════════════════════════════ -->
            <TabItem Header="{DynamicResource Str.AppSettings.TabGitHub}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,8,12,16">

                        <TextBlock FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextWrapping="Wrap" Margin="0,0,0,12"
                                   Text="{DynamicResource Str.AppSettings.GhTabDesc}"/>

                        <TextBlock Text="{DynamicResource Str.AppSettings.Repository}" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding GitHubRepo, UpdateSourceTrigger=PropertyChanged}"
                                 Height="36" Margin="0,0,0,12" ToolTip="{DynamicResource Str.AppSettings.RepositoryTip}"/>

                        <TextBlock Text="{DynamicResource Str.AppSettings.PerAppToken}"
                                   FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                        <PasswordBox x:Name="GitHubTokenBox" Height="36" Margin="0,0,0,12"
                                     PasswordChanged="GitHubTokenBox_PasswordChanged"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Button Content="{DynamicResource Str.AppSettings.TestConnLower}" Style="{StaticResource SecondaryButton}"
                                    Padding="16,8" Command="{Binding TestGitHubCommand}"/>
                            <TextBlock Text="{DynamicResource Str.AppSettings.Checking}" FontSize="12" VerticalAlignment="Center" Margin="12,0,0,0"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Visibility="{Binding IsTestingGitHub, Converter={StaticResource BoolToVisibility}}"/>
                        </StackPanel>
                        <TextBlock Text="{Binding GitHubTestResult}" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,0,0,20" TextWrapping="Wrap"/>

                        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Margin="0,0,0,20"/>

                        <TextBlock Text="{DynamicResource Str.AppSettings.BuildRunner}" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                        <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextWrapping="Wrap" Margin="0,0,0,10"
                                   Text="{DynamicResource Str.AppSettings.BuildRunnerDesc}"/>

                        <TextBlock Text="{DynamicResource Str.AppSettings.LocalRepoPath}" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding GitHubLocalPath, UpdateSourceTrigger=PropertyChanged}"
                                     Height="36" Margin="0,0,8,0" ToolTip="{DynamicResource Str.AppSettings.LocalRepoTip}"/>
                            <Button Grid.Column="1" Content="{DynamicResource Str.Common.Browse}" Style="{StaticResource SecondaryButton}"
                                    Padding="14,8" Command="{Binding BrowseGitHubLocalPathCommand}"/>
                        </Grid>

                        <TextBlock Text="{DynamicResource Str.AppSettings.BuildCommand}" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding GitHubBuildCommand, UpdateSourceTrigger=PropertyChanged}"
                                 Height="36" Margin="0,0,0,12"
                                 ToolTip="{DynamicResource Str.AppSettings.BuildCommandTip}"/>

                        <TextBlock Text="{DynamicResource Str.AppSettings.ArtifactFolder}" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding GitHubArtifactPath, UpdateSourceTrigger=PropertyChanged}"
                                     Height="36" Margin="0,0,8,0"
                                     ToolTip="{DynamicResource Str.AppSettings.ArtifactFolderTip}"/>
                            <Button Grid.Column="1" Content="{DynamicResource Str.Common.Browse}" Style="{StaticResource SecondaryButton}"
                                    Padding="14,8" Command="{Binding BrowseGitHubArtifactPathCommand}"/>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>

        <!-- Footer -->
        <Border Grid.Row="3" Background="{DynamicResource SidebarBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="28,14">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="{DynamicResource Str.Common.Cancel}" Style="{StaticResource SecondaryButton}"
                        Padding="14,8" Margin="0,0,8,0"
                        Command="{Binding CancelCommand}"/>
                <Button Content="{DynamicResource Str.Common.Save}" Style="{StaticResource PrimaryButton}"
                        Padding="18,8"
                        Command="{Binding SaveCommand}"/>
            </StackPanel>
        </Border>

    </Grid>
</UserControl>
