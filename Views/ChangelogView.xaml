<Window x:Class="ForgeTekApplicationReleaseManager.Views.ChangelogView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Str.Changelog.Title}" Height="500" Width="700"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="24,20,24,16"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <TextBlock FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextBrush}">
                <Run Text="{DynamicResource Str.Changelog.HeaderPrefix}"/>
                <Run Text="{Binding VersionNumber, Mode=OneTime}"/>
            </TextBlock>
        </Border>

        <ScrollViewer Grid.Row="1" Margin="24,16,24,16"
                      VerticalScrollBarVisibility="Auto">
            <TextBox Text="{Binding Content, Mode=OneTime}"
                     IsReadOnly="True" TextWrapping="Wrap"
                     Background="Transparent" BorderThickness="0"
                     Foreground="{DynamicResource TextBrush}"
                     FontFamily="Consolas" FontSize="13"/>
        </ScrollViewer>

        <Border Grid.Row="2" Background="{DynamicResource SidebarBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="24,12">
            <Button Content="{DynamicResource Str.Common.Close}" Style="{StaticResource SecondaryButton}"
                    Padding="18,8" HorizontalAlignment="Right"
                    Click="Close_Click"/>
        </Border>
    </Grid>
</Window>
