<UserControl x:Class="ForgeTekUpdatePackager.Views.DiffView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="28,24,28,16"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel>
                <TextBlock Text="{Binding ViewTitle}" FontSize="22" FontWeight="Bold"
                           Foreground="{DynamicResource TextBrush}"/>
                <TextBlock Text="{Binding BaseVersionLabel}" FontSize="12"
                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                <TextBlock Text="{Binding SummaryText}" FontSize="13"
                           Foreground="{DynamicResource AccentBrush}" Margin="0,8,0,0" FontWeight="SemiBold"/>
                <TextBlock FontSize="11" Foreground="{DynamicResource AccentBrush}" Margin="0,4,0,0">
                    <Run Text="💡 In Added/Modified tabs, check "/>
                    <Run Text="Debug" FontWeight="SemiBold"/>
                    <Run Text=" to exclude files from packaging."/>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Tab view -->
        <TabControl Grid.Row="1" Margin="28,16,28,0">

            <!-- ADDED -->
            <TabItem Header="{Binding AddedHeader}">
                <Grid>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Added}" Margin="0,8">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="160"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="+" FontWeight="Bold"
                                                   Foreground="{DynamicResource AddedBrush}" VerticalAlignment="Center"/>
                                        <CheckBox Grid.Column="1" IsChecked="{Binding IsDebug, Converter={StaticResource InvertBool}, Mode=TwoWay}"
                                                  VerticalAlignment="Center"
                                                  ToolTip="Include in the package. Uncheck to exclude (e.g. debug files)."/>
                                        <TextBlock Grid.Column="2" Text="{Binding Path}" FontSize="13"
                                                   Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="3" FontSize="12"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"
                                                   Text="{Binding DateModified, StringFormat='yyyy-MM-dd HH:mm'}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    <TextBlock Text="No new files." VerticalAlignment="Center" HorizontalAlignment="Center"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Visibility="{Binding Added.Count, Converter={StaticResource ZeroToVisible}}"/>
                </Grid>
            </TabItem>

            <!-- MODIFIED -->
            <TabItem Header="{Binding ModifiedHeader}">
                <Grid>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Modified}" Margin="0,8">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="160"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="~" FontWeight="Bold"
                                                   Foreground="{DynamicResource ModifiedBrush}" VerticalAlignment="Center"/>
                                        <CheckBox Grid.Column="1" IsChecked="{Binding IsDebug, Converter={StaticResource InvertBool}, Mode=TwoWay}"
                                                  VerticalAlignment="Center"
                                                  ToolTip="Include in the package. Uncheck to exclude (e.g. debug files)."/>
                                        <TextBlock Grid.Column="2" Text="{Binding Path}" FontSize="13"
                                                   Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="3" FontSize="12"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"
                                                   Text="{Binding DateModified, StringFormat='yyyy-MM-dd HH:mm'}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    <TextBlock Text="No modified files." VerticalAlignment="Center" HorizontalAlignment="Center"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Visibility="{Binding Modified.Count, Converter={StaticResource ZeroToVisible}}"/>
                </Grid>
            </TabItem>

            <!-- REMOVED -->
            <TabItem Header="{Binding RemovedHeader}">
                <Grid>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Removed}" Margin="0,8">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="160"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="−" FontWeight="Bold"
                                                   Foreground="{DynamicResource RemovedBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Path}" FontSize="13"
                                                   Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="2" FontSize="12"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"
                                                   Text="{Binding DateModified, StringFormat='yyyy-MM-dd HH:mm'}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    <TextBlock Text="No removed files." VerticalAlignment="Center" HorizontalAlignment="Center"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Visibility="{Binding Removed.Count, Converter={StaticResource ZeroToVisible}}"/>
                </Grid>
            </TabItem>

            <!-- UNCHANGED -->
            <TabItem Header="{Binding UnchangedHeader}">
                <Grid>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Unchanged}" Margin="0,8">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="160"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="=" FontWeight="Bold"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Path}" FontSize="13"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="2" FontSize="12"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"
                                                   Text="{Binding DateModified, StringFormat='yyyy-MM-dd HH:mm'}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    <TextBlock Text="No unchanged files." VerticalAlignment="Center" HorizontalAlignment="Center"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Visibility="{Binding Unchanged.Count, Converter={StaticResource ZeroToVisible}}"/>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Footer: approve bar (live scan mode) -->
        <Border Grid.Row="2" Background="{DynamicResource SidebarBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="28,14"
                Visibility="{Binding IsApprovalMode, Converter={StaticResource BoolToVisibility}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="New Version:" VerticalAlignment="Center"
                           FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" Margin="0,0,10,0"/>
                <TextBox Grid.Column="1" Text="{Binding VersionNumber, UpdateSourceTrigger=PropertyChanged}"
                         Height="36" FontSize="14"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                    <CheckBox Content="Beta (pre-release)" IsChecked="{Binding IsBeta}"
                              VerticalAlignment="Center"
                              ToolTip="Publish to the Beta channel — only beta clients receive it."/>
                    <TextBlock Text="{Binding VersionMismatchText}"
                               FontSize="11" Foreground="{DynamicResource ModifiedBrush}"
                               VerticalAlignment="Center" Margin="14,0,0,0"
                               Visibility="{Binding HasVersionMismatch, Converter={StaticResource BoolToVisibility}}"/>
                </StackPanel>
                <StackPanel Grid.Column="3" Orientation="Horizontal">
                    <Button Content="Approve &amp; Save Version" Style="{StaticResource PrimaryButton}"
                            Padding="18,8" Margin="0,0,8,0"
                            Command="{Binding ApproveCommand}"/>
                    <Button Content="Cancel" Style="{StaticResource SecondaryButton}"
                            Padding="14,8" Command="{Binding CancelCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Footer: back button (read-only / history mode) -->
        <Border Grid.Row="2" Background="{DynamicResource SidebarBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="28,14"
                Visibility="{Binding IsReadOnly, Converter={StaticResource BoolToVisibility}}">
            <Button Content="← Back to App" Style="{StaticResource SecondaryButton}"
                    Padding="18,8" HorizontalAlignment="Left"
                    Command="{Binding CancelCommand}"/>
        </Border>
    </Grid>
</UserControl>
