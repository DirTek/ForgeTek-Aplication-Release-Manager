<UserControl x:Class="ForgeTekUpdatePackager.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:ForgeTekUpdatePackager.ViewModels">
    <UserControl.Resources>
        <!-- Clickable app status card: accent wash + hover + accent outline -->
        <Style x:Key="AppCardButton" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" CornerRadius="10" BorderThickness="1"
                                BorderBrush="{DynamicResource BorderBrush}"
                                Background="{DynamicResource SurfaceBrush}">
                            <Grid>
                                <Border CornerRadius="10" Background="{Binding AccentGradientBrush}"/>
                                <Border x:Name="ov" CornerRadius="10" Background="Transparent" Padding="16,14">
                                    <ContentPresenter/>
                                </Border>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ov" Property="Background" Value="#1A808080"/>
                                <Setter TargetName="bg" Property="BorderBrush" Value="{Binding AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Flat clickable row (recent activity) -->
        <Style x:Key="RowButton" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" CornerRadius="8" BorderThickness="1"
                                BorderBrush="{DynamicResource BorderBrush}"
                                Background="{DynamicResource SurfaceBrush}" Padding="12,9">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource SurfaceHoverBrush}"/>
                                <Setter TargetName="b" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource BackgroundBrush}" ClipToBounds="True">

        <!-- ══ EMPTY STATE (no apps) — logo hero ══════════════════════════ -->
        <Grid Visibility="{Binding HasApps, Converter={StaticResource InvertVisibility}}">
            <Ellipse Width="460" Height="460" Fill="{DynamicResource AccentBrush}" Opacity="0.10"
                     HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-150,-150,0" IsHitTestVisible="False">
                <Ellipse.Effect><BlurEffect Radius="150"/></Ellipse.Effect>
            </Ellipse>
            <Ellipse Width="420" Height="420" Fill="{DynamicResource AddedBrush}" Opacity="0.07"
                     HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="-150,0,0,-150" IsHitTestVisible="False">
                <Ellipse.Effect><BlurEffect Radius="150"/></Ellipse.Effect>
            </Ellipse>

            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Border Width="104" Height="104" CornerRadius="24" HorizontalAlignment="Center"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="28" ShadowDepth="0" Opacity="0.35" Color="#000000"/>
                    </Border.Effect>
                    <Viewbox Width="64" Height="64">
                        <Canvas Width="120" Height="120">
                            <Canvas.Resources>
                                <LinearGradientBrush x:Key="GOuter" MappingMode="Absolute" StartPoint="14,110" EndPoint="106,14">
                                    <GradientStop Offset="0"    Color="#00C9E5"/>
                                    <GradientStop Offset="0.34" Color="#51D8EC"/>
                                    <GradientStop Offset="0.68" Color="#FFB066"/>
                                    <GradientStop Offset="1"    Color="#F58220"/>
                                </LinearGradientBrush>
                                <LinearGradientBrush x:Key="GInner" MappingMode="Absolute" StartPoint="60,80" EndPoint="60,44">
                                    <GradientStop Offset="0"   Color="#00C9E5"/>
                                    <GradientStop Offset="0.5" Color="#51D8EC"/>
                                    <GradientStop Offset="0.8" Color="#FFB066"/>
                                    <GradientStop Offset="1"   Color="#F58220"/>
                                </LinearGradientBrush>
                                <RadialGradientBrush x:Key="GHot" Center="0.5,0.5" GradientOrigin="0.5,0.5" RadiusX="0.5" RadiusY="0.5">
                                    <GradientStop Offset="0"    Color="#F2FFB46E"/>
                                    <GradientStop Offset="0.45" Color="#B3F58220"/>
                                    <GradientStop Offset="1"    Color="#00F58220"/>
                                </RadialGradientBrush>
                                <RadialGradientBrush x:Key="GHot2" Center="0.5,0.5" GradientOrigin="0.5,0.5" RadiusX="0.5" RadiusY="0.5">
                                    <GradientStop Offset="0" Color="#87F58220"/>
                                    <GradientStop Offset="1" Color="#00F58220"/>
                                </RadialGradientBrush>
                            </Canvas.Resources>
                            <Path Data="M52 15.5 L16.7 35 L16.7 85 L60 110 L103.3 85 L103.3 35 L68 15.5"
                                  Stroke="{StaticResource GOuter}" StrokeThickness="9"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                            <Ellipse Canvas.Left="57"   Canvas.Top="4.5"  Width="22"   Height="22"   Fill="{StaticResource GHot}"/>
                            <Ellipse Canvas.Left="61.4" Canvas.Top="8.9"  Width="13.2" Height="13.2" Fill="#F58220"/>
                            <Ellipse Canvas.Left="65.4" Canvas.Top="12.9" Width="5.2"  Height="5.2"  Fill="#FFD9B0"/>
                            <Path Data="M38 78 L82 78 C88.6133 78 88.6133 67.3333 82 67.3333 L38 67.3333 C31.3867 67.3333 31.3867 56.6667 38 56.6667 L82 56.6667 C88.6133 56.6667 88.6133 46 82 46 L38 46"
                                  Stroke="{StaticResource GInner}" StrokeThickness="6"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                            <Ellipse Canvas.Left="30"   Canvas.Top="38"   Width="16"  Height="16"  Fill="{StaticResource GHot2}"/>
                            <Ellipse Canvas.Left="33.6" Canvas.Top="41.6" Width="8.8" Height="8.8" Fill="#F58220"/>
                            <Ellipse Canvas.Left="36.2" Canvas.Top="44.2" Width="3.6" Height="3.6" Fill="#FFE4C4"/>
                        </Canvas>
                    </Viewbox>
                </Border>

                <TextBlock Text="ForgeTek Release Manager" FontSize="28" FontWeight="Bold"
                           Foreground="{DynamicResource TextBrush}" HorizontalAlignment="Center" Margin="0,22,0,0"/>
                <TextBlock Text="Add your first application to get started."
                           FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" Margin="0,10,0,0"/>
                <Button Content="+ Add Application" Style="{StaticResource PrimaryButton}"
                        Padding="22,10" Margin="0,20,0,0" HorizontalAlignment="Center"
                        Command="{Binding AddAppCommand}"/>
            </StackPanel>
        </Grid>

        <!-- ══ POPULATED DASHBOARD ════════════════════════════════════════ -->
        <ScrollViewer Visibility="{Binding HasApps, Converter={StaticResource BoolToVisibility}}"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="32,28,32,28">

                <!-- Header + quick actions -->
                <Grid Margin="0,0,0,22">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Dashboard" FontSize="24" FontWeight="Bold"
                                   Foreground="{DynamicResource TextBrush}"/>
                        <TextBlock Text="Your apps at a glance — pick one from the sidebar to manage it."
                                   FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                    <!-- GitHub connection status -->
                    <Border Grid.Column="1" VerticalAlignment="Center" CornerRadius="6" Padding="10,6"
                            Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="9" Height="9" VerticalAlignment="Center" Margin="0,0,8,0">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="{DynamicResource TextSecondaryBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding GitHubConnected}" Value="True">
                                                <Setter Property="Fill" Value="{DynamicResource AddedBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock Text="{Binding GitHubStatusText}" FontSize="12"
                                       Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Summary stat chips -->
                <UniformGrid Columns="4" Margin="0,0,0,24">
                    <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" CornerRadius="10" Padding="16,14" Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="{Binding TotalApps}" FontSize="26" FontWeight="Bold" Foreground="{DynamicResource TextBrush}"/>
                            <TextBlock Text="Apps" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" CornerRadius="10" Padding="16,14" Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="{Binding PublishedCount}" FontSize="26" FontWeight="Bold" Foreground="{DynamicResource AddedBrush}"/>
                            <TextBlock Text="Published" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" CornerRadius="10" Padding="16,14" Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="{Binding InProgressCount}" FontSize="26" FontWeight="Bold" Foreground="{DynamicResource ModifiedBrush}"/>
                            <TextBlock Text="In progress" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" CornerRadius="10" Padding="16,14">
                        <StackPanel>
                            <TextBlock Text="{Binding SetupCount}" FontSize="26" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"/>
                            <TextBlock Text="Setups" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- Your apps -->
                <TextBlock Text="YOUR APPS" Style="{StaticResource SectionHeader}" Margin="0,0,0,10"/>
                <ItemsControl ItemsSource="{Binding Apps}" Margin="0,0,0,24">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:AppEntryViewModel}">
                            <Button Style="{StaticResource AppCardButton}" Width="252" Margin="0,0,10,10"
                                    Command="{Binding DataContext.OpenAppCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}">
                                <StackPanel>
                                    <DockPanel LastChildFill="True">
                                        <Ellipse Width="9" Height="9" DockPanel.Dock="Right" VerticalAlignment="Center"
                                                 Fill="{DynamicResource AccentBrush}"
                                                 Visibility="{Binding NeedsAttention, Converter={StaticResource BoolToVisibility}}"/>
                                        <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextBrush}" TextTrimming="CharacterEllipsis"/>
                                    </DockPanel>
                                    <TextBlock Text="{Binding VersionLine}" FontSize="12" Margin="0,4,0,0"
                                               Foreground="{DynamicResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis"/>
                                    <Grid Margin="0,12,0,0">
                                        <Border CornerRadius="4" Padding="7,2" HorizontalAlignment="Left" VerticalAlignment="Center"
                                                Background="{DynamicResource SurfaceHoverBrush}">
                                            <TextBlock Text="{Binding StatusBadge}" FontSize="11"
                                                       Foreground="{DynamicResource TextBrush}"/>
                                        </Border>
                                        <Button Content="{Binding NextActionLabel}" Style="{StaticResource SecondaryButton}"
                                                Padding="12,5" FontSize="11" HorizontalAlignment="Right"
                                                Command="{Binding DataContext.OpenAppCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                    </Grid>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Recent activity -->
                <StackPanel Visibility="{Binding HasActivity, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="RECENT ACTIVITY" Style="{StaticResource SectionHeader}" Margin="0,0,0,10"/>
                    <ItemsControl ItemsSource="{Binding RecentActivity}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:ActivityItem}">
                                <Button Style="{StaticResource RowButton}"
                                        Command="{Binding DataContext.OpenActivityCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Glyph}" FontFamily="Segoe Fluent Icons"
                                                   FontSize="15" VerticalAlignment="Center" Margin="0,0,12,0"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Title}" FontSize="13"
                                                       Foreground="{DynamicResource TextBrush}" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Subtitle}" FontSize="11"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" VerticalAlignment="Center" FontSize="11"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   Text="{Binding When, StringFormat='{}{0:yyyy-MM-dd  HH:mm}'}"/>
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
