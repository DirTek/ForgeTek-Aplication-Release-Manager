<Window x:Class="AppUpdater.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Updater" Height="420" Width="560"
        MinHeight="360" MinWidth="460"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Loaded="Window_Loaded">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header: icon + title -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,18">
            <Image x:Name="AppIconImage" Width="40" Height="40" Margin="0,0,14,0"
                   VerticalAlignment="Center" Visibility="Collapsed"/>
            <StackPanel VerticalAlignment="Center">
                <TextBlock x:Name="TitleText" Text="Updater"
                           FontSize="20" FontWeight="Bold"
                           Foreground="{DynamicResource TextBrush}"/>
                <TextBlock x:Name="SubtitleText" Text="Applying the latest update…"
                           FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,3,0,0"/>
            </StackPanel>
        </StackPanel>

        <!-- Status line -->
        <TextBlock x:Name="StatusText" Grid.Row="1" Text="Starting…"
                   FontSize="13" Foreground="{DynamicResource TextBrush}"
                   Margin="0,0,0,10" TextTrimming="CharacterEllipsis"/>

        <!-- Progress -->
        <ProgressBar x:Name="Bar" Grid.Row="2" Height="6" Margin="0,0,0,16"
                     Minimum="0" Maximum="1" IsIndeterminate="True"/>

        <!-- Detail log -->
        <Border Grid.Row="3" Background="{DynamicResource SurfaceBrush}" CornerRadius="6"
                BorderThickness="1" BorderBrush="{StaticResource BorderBrush}" Padding="12,8">
            <ScrollViewer x:Name="LogScroller" VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="LogText" TextWrapping="Wrap" FontSize="11.5"
                           FontFamily="Consolas, Cascadia Mono, monospace"
                           Foreground="{StaticResource TextSecondaryBrush}" LineHeight="17"/>
            </ScrollViewer>
        </Border>

        <!-- Footer -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button x:Name="CloseBtn" Content="Close"
                    Style="{StaticResource PrimaryButton}"
                    Padding="22,9" Visibility="Collapsed" Click="CloseBtn_Click"/>
        </StackPanel>
    </Grid>
</Window>
